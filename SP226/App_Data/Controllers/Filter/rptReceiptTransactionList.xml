  <script>
    <text>
      &JavascriptReportFilter;
      &OutlineEntry;
      &SetReportFormLimitRight;
      <![CDATA[/* <flatten type="Javascript"> */
function onChange$VoucherFilter$Tab(f, e) {f.parentForm.focusWhenTabChanged(['ma_vt', ['transactionGrid'], 'ma_nx']);}
/* </flatten> */
function active$VoucherFilter$(f) {
  f.add_onResponseComplete(on$Filter$ResponseComplete);
  f._tabContainer.add_activeTabChanged(onChange$VoucherFilter$Tab);
  f._tabContainer._loaded = true;
  changeLookupReadonly(f, 'ma_dvcs');
  var o = f.getItem('maxLength');
  o.value = o.maxLength;
  var a = f.getItem('maxLength_mo');
  a.value = a.maxLength;]]>&FilterExpression;<![CDATA[
}
/* <flatten type="Javascript"> */
function close$VoucherFilter$(f) {
  try {f.remove_onResponseComplete(on$Filter$ResponseComplete);} catch (ex) {}
  try {f._tabContainer.remove_activeTabChanged(onChange$VoucherFilter$Tab);} catch (ex) {}
}
function on$Filter$ResponseComplete(sender, e) {
  var f = e.object, context = e.type.Context, result = e.type.Result;
  switch (context) {
    case 'Checking':
      var wile = $func.findMemvarIndex('transactionGrid', f._memvars);
      if (wile > -1) Array.removeAt(f._memvars, wile);
      var g = f.grid, dFrom = f.getItem('tu_ngay').value, dTo = f.getItem('den_ngay').value, x = f.getItemValue('mau_bc');
      g._alterTitle = [null, [['%d1', dFrom, true], ['%d2', dTo, true]]];
      g._hiddenFields = [
        {Fields: 'gia, tien', Value: (x == '10')},
        {Fields: 'gia_nt, tien_nt, ma_nt, ty_gia', Value: (x == '10' || x == '20')}
      ];
      if (f._hidden$GridForm) g._hiddenForms = [{Form: f._hidden$GridForm, Value: 1}];
      remove$GridReport$Filter(g);
    break;
  default:
    break;
  }
}/* </flatten> */
]]>
    </text>
  </script>

  &OutlineCss;
