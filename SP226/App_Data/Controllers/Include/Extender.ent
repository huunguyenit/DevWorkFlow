declare @invoke nvarchar(2000), @script nvarchar(1000), @fileTicket nvarchar(256)
select @invoke = '', @script = '', @fileTicket = ''
">
<!ENTITY ListWarning "if @$warning &lt;&gt; '' select @script = @script + 'objectBehavior$Voucher$Number.warning(this, ''' + replace(replace(@$warning, '\', '\\'), '''', '\''') + ''');'">
<!ENTITY ListQuery "if @invoke + @script &lt;&gt; '' select '' as message, '' as field&ExtenderInvoke;, @script as script">

