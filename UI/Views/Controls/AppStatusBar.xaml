<UserControl x:Class="UI.Views.Controls.AppStatusBar"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:md="http://materialdesigninxaml.net/winfx/xaml/themes">

    <Border Style="{StaticResource StatusBarStyle}" Padding="8,2">
        <Grid>
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="Auto"/>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="Auto"/>
            </Grid.ColumnDefinitions>

            <StackPanel Grid.Column="0" Orientation="Horizontal" VerticalAlignment="Center">
                <TextBlock Text="{Binding Shell.StatusReady, FallbackValue=Ready}"
                           Foreground="White" FontSize="11" Margin="0,0,12,0"/>
                <TextBlock Text="{Binding StatusCaret, FallbackValue='Ln 1, Col 1'}"
                           Foreground="#E0E0E0" FontSize="11" Margin="0,0,12,0"/>
                <Border Background="#FFEBEE" CornerRadius="2" Padding="4,0" Margin="0,0,4,0">
                    <TextBlock Text="{Binding StatusErrorCount, StringFormat=E {0}}"
                               Foreground="#FFCDD2" FontSize="10" FontWeight="SemiBold"/>
                </Border>
                <Border Background="#FFF8E1" CornerRadius="2" Padding="4,0" Margin="0,0,4,0">
                    <TextBlock Text="{Binding StatusWarningCount, StringFormat=W {0}}"
                               Foreground="#FFF9C4" FontSize="10" FontWeight="SemiBold"/>
                </Border>
                <Border Background="#E3F2FD" CornerRadius="2" Padding="4,0" Margin="0,0,8,0">
                    <TextBlock Text="{Binding StatusHintCount, StringFormat=H {0}}"
                               Foreground="#BBDEFB" FontSize="10" FontWeight="SemiBold"/>
                </Border>
                <TextBlock Text="{Binding AppStatus}"
                           Foreground="#E0E0E0" FontSize="11"
                           TextTrimming="CharacterEllipsis" MaxWidth="360"/>
            </StackPanel>

            <StackPanel Grid.Column="2" Orientation="Horizontal" VerticalAlignment="Center">
                <TextBlock Text="{Binding StatusEditorMode, FallbackValue='Insight Mode'}"
                           Foreground="#90CAF9" FontSize="11" Margin="0,0,12,0"/>
                <ComboBox ItemsSource="{Binding EditorLanguages}"
                          SelectedItem="{Binding SelectedEditorLanguage, Mode=TwoWay}"
                          FontSize="11" Height="18" MinWidth="82" Margin="0,0,12,0"
                          Padding="6,0" VerticalContentAlignment="Center"
                          ToolTip="Đổi định dạng tô màu editor (XML / JavaScript / SQL)"/>
                <TextBlock Text="{Binding StatusEncoding}" Foreground="#E0E0E0" FontSize="11" Margin="0,0,12,0"/>
                <Image Source="pack://application:,,,/DevWorkFlow.png"
                       Width="12" Height="12"
                       Stretch="Uniform"
                       SnapsToDevicePixels="True"
                       RenderOptions.BitmapScalingMode="HighQuality"
                       VerticalAlignment="Center"/>
                <TextBlock Text="DevWorkFlow" Foreground="White" FontSize="11"
                           Margin="4,0,0,0" VerticalAlignment="Center"/>
            </StackPanel>
        </Grid>
    </Border>
</UserControl>
