  <views>
    <view id="Dir" height="136">
      <item value="120, 30, 70, 100, 200, 30"/>
      <item value="11011-: [ngay_ct1].Description, [ngay_ct1], [ngay_ct2], [maxLength]"/>
      <item value="11011-: [so_ct1].Label, [so_ct1], [so_ct2], [loai_ct]"/>
      <item value="110100: [ma_kh].Label, [ma_kh], [ten_kh%l]"/>
      <item value="110100: [ma_kho].Label, [ma_kho], [ten_kho%l]"/>
      <item value="110100: [ma_vt].Label, [ma_vt], [ten_vt%l]"/>
      <item value="110100: [tk_vt].Label, [tk_vt], [ten_tk_vt%l]"/>
      <item value="110100: [tk_gv].Label, [tk_gv], [ten_tk_gv%l]"/>
      <item value="110100: [tk_dt].Label, [tk_dt], [ten_tk_dt%l]"/>

      <item value="110100: [ma_nt].Label, [ma_nt], [ten_nt%l]"/>
      <item value="111000: [status].Label, [status], [status].Description"/>

      <item value="110100: [ma_dvcs].Label, [ma_dvcs], [ten_dvcs%l]"/>
      <item value="111001: [user_id0].Label, [user_id0], [user_id0].Description, [keys]"/>

      <categories>
        <category index="1" columns="120, 30, 70, 100, 200, 30">
          <header v="Chi tiết" e="Detail"/>
        </category>
        <category index="9" columns="120, 30, 70, 100, 200, 30">
          <header v="Khác" e="Other"/>
        </category>
      </categories>
    </view>
  </views>

  <commands>
    <command event="Initialize">
      <text>
        <![CDATA[
declare @userFilterType varchar(1)
select @userFilterType = rtrim(m_loc_nsd) from dmct where ma_ct = ']]>&VoucherCode;<![CDATA['
if @userFilterType is not null begin
  select '$func.findField(''user_id0'', this.grid._searchInfor.Fields).ClientDefault = ''' + @userFilterType + '''' as message
  return
end
]]>
      </text>
    </command>

    <command event="Loading">
      <text>
        <![CDATA[
select 'active$VoucherFilter$(this);' as message
return
]]>
      </text>
    </command>
    &XMLWhenFilterClosing;

    <command event="Processing">
      <text>
        <![CDATA[
exec rs_rptPrintSVTran @ngay_ct1, @ngay_ct2, @so_ct1, @so_ct2, @maxLength, @ma_kh, @ma_kho, @ma_vt, @tk_vt, @tk_gv, @tk_dt, @ma_nt, @ma_dvcs, @status, @user_id0, @@language, @@userID, @@admin, 1
]]>
      </text>
    </command>
  </commands>

  <script>
    <text>
      <![CDATA[/* <flatten type="Javascript"> */
function onChange$VoucherFilter$Tab(sender, e) {sender.parentForm.focusWhenTabChanged(['ma_kho', 'ma_nt']);}
function active$VoucherFilter$(f) {
  f.add_onResponseComplete(on$Filter$ResponseComplete);
  f._tabContainer.add_activeTabChanged(onChange$VoucherFilter$Tab);
  f._tabContainer._loaded = true;
  var o = f.getItem('maxLength');
  o.value = o.maxLength;
}
function close$VoucherFilter$(f) {
  try {f.remove_onResponseComplete(on$Filter$ResponseComplete);} catch (ex) {}
  if (f._tabContainer) try {f._tabContainer.remove_activeTabChanged(onChange$VoucherFilter$Tab);} catch (ex) {}
}
function on$Filter$ResponseComplete(sender, e) {
  var f = e.object, context = e.type.Context, result = e.type.Result;
  switch (context) {
    case 'Checking':
      var g = f.grid, dFrom = f.getItem('ngay_ct1').value, dTo = f.getItem('ngay_ct2').value;
      g._alterTitle = [null, [['%d1', dFrom, true], ['%d2', dTo, true]]];
      if (g._$k != null) g._$k = [];
      break;
    default:
      break;
  }
}
/* </flatten> */]]>
    </text>
  </script>
</dir>