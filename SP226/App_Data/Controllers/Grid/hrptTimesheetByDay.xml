  <script>
    <text>
      <![CDATA[/* <flatten type="Javascript"> */
function load$GridReport$(g) {g.add_onRender(on$GridReport$Render);}
function dispose$GridReport$(g) {try {g.remove_onRender(on$GridReport$Render);} catch (ex) {}}
function on$GridReport$Render(sender, eventArgs) {
  var g = eventArgs.grid, g._h = '';
  if (g._hiddenFields) {
    var a = g._hiddenFields;
    for (var i = 0; i < a.length; i++) {
      setGridHiddenFields(g, a[i].Fields, a[i].Value);
      if (a[i].Value) g._h = a[i].Fields;
    }
  }
  setHeaderColor(g, g._d, g._nonWorking, '#4695d6', '#e6400d');
  setGridColor(g, g._d, g._nonWorking, '#e6edf7', '#e9edf1');

  for (var i = 1; i <= g._c.length; i++) { g._setColumnVisible(g._getColumnOrder($func.trim(('c' + (i <= 9 ? '0' : '') + i))), (i <= g._count)); }
  changeHeader$GridReport(g, g._c, true);
  g._externalHiddenFields = g._h;
}

function setGridHiddenFields(g, c, v) {
  var a = c.split(',');
  for (var i = 0; i < a.length; i++) {
    if (a[i] != '') g._setColumnVisible(g._getColumnOrder($func.trim(a[i])), !v);
  }
}

function init$GridReport$(g) {
  g._externalHeaderFields = [];
  g._d = ('n01, n02, n03, n04, n05, n06, n07, n08, n09, n10, n11, n12, n13, n14, n15, n16, n17, n18, n19, n20, n21, n22, n23, n24, n25, n26, n27, n28, n29, n30, n31, n32, n33, n34, n35, n36, n37, n38, n39, n40').split(',');
  g._c = ('c01, c02, c03, c04, c05, c06, c07, c08, c09, c10, c11, c12, c13, c14, c15, c16, c17, c18, c19, c20').split(',');
  changeHeader$GridReport(g, g._d, false);
}

function changeHeader$GridReport(g, a, v) {
  var field, d = g._dateFrom;
  for (var i = 0; i < a.length; i++) {
    field = g._fields[g._getColumnOrder($func.trim(a[i])) - 1];
    if (i < g._lengthShow) { field.HeaderText = d.getDate() + (d.getDate() != 1 ? '' : '/' + (d.getMonth() + 1)); }
    else field.HeaderText = '';
    d = addDays(d, 1);
    Array.add(g._externalHeaderFields, {Index: field.Index, Header: field.HeaderText});
  }

  if (v) {
    var id = g.get_id(), h = g._itemText.split(String.fromCharCode(255));
    for (var i = 0; i < a.length; i++) {
      field = g._fields[g._getColumnOrder($func.trim(a[i])) - 1];
      if (i < g._count) {
        field.HeaderText = h[i];
        $get(id + '_HeaderText_' + a[i].trim()).innerHTML = h[i];
      }
      else {
        field.HeaderText = '';
        $get(id + '_HeaderText_' + a[i].trim()).innerHTML = '';
        g._h += (g._h == '' ? '' : ',') + field.Name;
      }
      Array.add(g._externalHeaderFields, {Index: field.Index, Header: field.HeaderText});
    }
  }
}

function setGridColor(g, a, b, c1, c2) {
  var id = g.get_id(), t, v;
  for (var r = 1; r <= g._rowCount; r++) {
    d = g._dateFrom;
    for (var i = 0; i < a.length; i++) {
      t = d.getDay();
      if (t == 6 || t == 0) {$get(id + '_gridCell_' + r.toString() + '.' + g._getColumnOrder($func.trim(a[i]))).style.backgroundColor = (t == 6 ? c1 : c2);}
      v = d.getFullYear().toString() + convertNumberToString(d.getMonth() + 1).toString() + convertNumberToString(d.getDate()).toString();
      if (b.indexOf(v) > -1) {$get(id + '_gridCell_' + r.toString() + '.' + g._getColumnOrder($func.trim(a[i]))).style.backgroundColor = c2;}
      d = addDays(d, 1);
    }
  }
}

function setHeaderColor(g, a, b, c1, c2) {
  var id = g.get_id(), d = g._dateFrom, t, v;
  for (var i = 0; i < a.length; i++) {
    t = d.getDay();
    if (t == 6 || t == 0) {$get(id + '_HeaderText_' + a[i].trim()).style.color = (t == 6 ? c1 : c2);}
    v = d.getFullYear().toString() + convertNumberToString(d.getMonth() + 1).toString() + convertNumberToString(d.getDate()).toString();
    if (b.indexOf(v) > -1) {$get(id + '_HeaderText_' + a[i].trim()).style.color = c2;}
    d = addDays(d, 1);
  }
}

function addDays(d, n) {
  var r = new Date(d);
  r.setDate(r.getDate() + n);
  return r;
}
function convertNumberToString(a) {return(a > 9 ? a : '0' + a);}
/* </flatten> */]]>
    </text>
