<UserControl x:Class="UI.Views.Bottom.OutputPanel"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:md="http://materialdesigninxaml.net/winfx/xaml/themes"
             xmlns:bottom="clr-namespace:UI.ViewModels.Bottom">

    <DockPanel Background="{StaticResource EditorBgBrush}">
        <Border DockPanel.Dock="Top" Background="{StaticResource CodePaneHeaderBrush}"
                Padding="8,3" BorderBrush="{StaticResource IdeBorderBrush}" BorderThickness="0,0,0,1">
            <DockPanel>
                <TextBlock Text="OUTPUT" FontSize="11" FontWeight="SemiBold"
                           Foreground="{StaticResource FgMutedBrush}" VerticalAlignment="Center"/>
                <Button DockPanel.Dock="Right" Content="Clear" FontSize="10" Padding="8,2"
                        Command="{Binding ClearOutputCommand}"
                        Style="{StaticResource IdeRibbonButtonStyle}"
                        HorizontalAlignment="Right"/>
            </DockPanel>
        </Border>

        <ListBox ItemsSource="{Binding OutputEntries}"
                 BorderThickness="0" Background="Transparent"
                 FontFamily="Consolas" FontSize="11"
                 ScrollViewer.HorizontalScrollBarVisibility="Disabled">
            <ListBox.ItemTemplate>
                <DataTemplate DataType="{x:Type bottom:LogEntryVm}">
                    <TextBlock Text="{Binding Display}" TextWrapping="Wrap" Margin="2,1"
                               Foreground="{StaticResource FgBrush}"/>
                </DataTemplate>
            </ListBox.ItemTemplate>
        </ListBox>
    </DockPanel>
</UserControl>
