<UserControl x:Class="UI.Views.Explorer.OutlinePanel"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:md="http://materialdesigninxaml.net/winfx/xaml/themes"
             xmlns:ex="clr-namespace:UI.Views.Explorer">

    <UserControl.Resources>
        <BooleanToVisibilityConverter x:Key="BoolToVis"/>
    </UserControl.Resources>

    <DockPanel Background="{StaticResource SidebarBgBrush}" Margin="0,0,0,8">
        <Border DockPanel.Dock="Top" Style="{StaticResource IdeDockHeaderStyle}">
            <DockPanel>
                <TextBlock Text="{Binding Header}" FontSize="11" FontWeight="SemiBold"
                           Foreground="{StaticResource FgMutedBrush}"
                           TextTrimming="CharacterEllipsis"/>
                <Button DockPanel.Dock="Right" Style="{StaticResource IconButtonStyle}"
                        Width="22" Height="22" Command="{Binding RefreshCommand}"
                        ToolTip="Refresh outline" HorizontalAlignment="Right">
                    <md:PackIcon Kind="Refresh" Width="12" Height="12"/>
                </Button>
            </DockPanel>
        </Border>

        <TextBlock DockPanel.Dock="Top"
                   Text="{Binding EmptyMessage}"
                   Style="{StaticResource IdePlaceholderTextStyle}"
                   Margin="8,8,8,4"
                   Visibility="{Binding IsEmpty, Converter={StaticResource BoolToVis}}"/>

        <ex:ExplorerTreePanel Margin="0,0,0,8"
                              Visibility="{Binding HasNodes, Converter={StaticResource BoolToVis}}"
                              NodeActivated="ExplorerTreePanel_NodeActivated"/>
    </DockPanel>
</UserControl>
