<Window x:Class="UI.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:md="http://materialdesigninxaml.net/winfx/xaml/themes"
        xmlns:ctrl="clr-namespace:UI.Views.Controls"
        xmlns:shellViews="clr-namespace:UI.Views.Shell"
        xmlns:ex="clr-namespace:UI.Views.Explorer"
        xmlns:props="clr-namespace:UI.Views.Properties"
        xmlns:tb="clr-namespace:UI.Views.Toolbox"
        xmlns:bottom="clr-namespace:UI.Views.Bottom"
        xmlns:insight="clr-namespace:UI.Views.Insight"
        xmlns:vm="clr-namespace:UI.ViewModels"
        xmlns:dock="clr-namespace:UI.Docking"
        xmlns:shell="clr-namespace:System.Windows.Shell;assembly=PresentationFramework"
        TextElement.Foreground="{StaticResource FgBrush}"
        Background="{StaticResource WorkspaceBgBrush}"
        FontFamily="{StaticResource AppFont}"
        Title="{Binding WindowTitle, FallbackValue='FBO Studio'}"
        WindowStyle="None"
        ResizeMode="CanResize"
        WindowState="Maximized"
        WindowStartupLocation="CenterScreen"
        MinHeight="640" MinWidth="1024"
        BorderBrush="{StaticResource BorderBrush}"
        BorderThickness="1">

    <shell:WindowChrome.WindowChrome>
        <shell:WindowChrome CaptionHeight="32"
                            ResizeBorderThickness="6"
                            GlassFrameThickness="0"
                            CornerRadius="0"
                            UseAeroCaptionButtons="False"/>
    </shell:WindowChrome.WindowChrome>

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="32"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <!-- Title bar -->
        <Border Grid.Row="0" Style="{StaticResource TopBarStyle}">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>

                <StackPanel Grid.Column="0" Orientation="Horizontal" Margin="8,0,0,0"
                            shell:WindowChrome.IsHitTestVisibleInChrome="True">
                    <Button Style="{StaticResource IconButtonStyle}"
                            Command="{Binding ToggleSidebarCommand}"
                            ToolTip="Ẩn / hiện Explorer"
                            Width="28" Height="28"
                            shell:WindowChrome.IsHitTestVisibleInChrome="True">
                        <md:PackIcon Kind="Menu" Width="16" Height="16"
                                     Foreground="{StaticResource FgBrush}"/>
                    </Button>
                    <md:PackIcon Kind="ApplicationBracketsOutline" Width="16" Height="16"
                                 Foreground="{StaticResource PrimaryBrush}"
                                 VerticalAlignment="Center" Margin="6,0,0,0"/>
                    <TextBlock Text="{Binding WindowTitle, FallbackValue='FBO Studio'}"
                               Foreground="{StaticResource FgBrightBrush}"
                               FontSize="12" FontWeight="SemiBold"
                               VerticalAlignment="Center" Margin="6,0,0,0"/>
                    <Border Background="#1565C0" CornerRadius="2" Padding="6,1" Margin="10,0,0,0"
                            VerticalAlignment="Center"
                            Visibility="{Binding IsInsightModeActive, Converter={StaticResource BoolToVisibilityConverter}}">
                        <TextBlock Text="INSIGHT MODE" Foreground="White" FontSize="9" FontWeight="Bold"/>
                    </Border>
                </StackPanel>

                <TextBlock Grid.Column="1"
                           Text="{Binding CurrentPageTitle}"
                           Foreground="{StaticResource FgMutedBrush}"
                           FontSize="11"
                           HorizontalAlignment="Center"
                           VerticalAlignment="Center"
                           IsHitTestVisible="False"/>

                <StackPanel Grid.Column="2" Orientation="Horizontal"
                            shell:WindowChrome.IsHitTestVisibleInChrome="True">
                    <Button Style="{StaticResource WindowChromeButtonStyle}"
                            Command="{Binding HideCommand}"
                            ToolTip="Ẩn">
                        <md:PackIcon Kind="WindowMinimize" Width="14" Height="14"/>
                    </Button>
                    <Button Style="{StaticResource WindowCloseButtonStyle}"
                            Command="{Binding ExitCommand}"
                            ToolTip="Đóng">
                        <md:PackIcon Kind="WindowClose" Width="14" Height="14"/>
                    </Button>
                </StackPanel>
            </Grid>
        </Border>

        <!-- Menu -->
        <shellViews:IdeMenuBar Grid.Row="1"
                               DataContext="{Binding}"
                               shell:WindowChrome.IsHitTestVisibleInChrome="True"/>

        <!-- Ribbon -->
        <shellViews:IdeRibbon Grid.Row="2"
                              DataContext="{Binding}"
                              shell:WindowChrome.IsHitTestVisibleInChrome="True"/>

        <!-- Body: Left full-height | Center+Right+Bottom -->
        <Grid Grid.Row="3">
            <Grid.ColumnDefinitions>
                <ColumnDefinition MinWidth="0">
                    <ColumnDefinition.Style>
                        <Style TargetType="ColumnDefinition">
                            <Setter Property="Width" Value="300"/>
                            <Setter Property="MinWidth" Value="220"/>
                            <Style.Triggers>
                                <DataTrigger Binding="{Binding Shell.IsLeftDockOpen}" Value="False">
                                    <Setter Property="Width" Value="0"/>
                                    <Setter Property="MinWidth" Value="0"/>
                                </DataTrigger>
                            </Style.Triggers>
                        </Style>
                    </ColumnDefinition.Style>
                </ColumnDefinition>
                <ColumnDefinition Width="Auto"/>
                <ColumnDefinition Width="*" MinWidth="200"/>
            </Grid.ColumnDefinitions>

            <!-- Left dock: full body height (không bị bottom đè) -->
            <Border Grid.Column="0"
                    HorizontalAlignment="Stretch"
                    Background="{StaticResource SidebarBgBrush}"
                    BorderBrush="{StaticResource IdeBorderBrush}"
                    BorderThickness="0,0,1,0"
                    Visibility="{Binding Shell.IsLeftDockOpen, Converter={StaticResource BoolToVisibilityConverter}}">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="2*" MinHeight="120"/>
                        <RowDefinition Height="4"/>
                        <RowDefinition Height="*" MinHeight="100"/>
                    </Grid.RowDefinitions>

                    <!-- Explorer host: 3 tabs -->
                    <DockPanel Grid.Row="0">
                        <Border DockPanel.Dock="Top"
                                Background="{StaticResource IdeDockHeaderBgBrush}"
                                BorderBrush="{StaticResource IdeBorderBrush}"
                                BorderThickness="0,0,0,1">
                            <StackPanel Orientation="Horizontal">
                                <Button Content="Explorer"
                                        Command="{Binding SelectLeftExplorerTabCommand}"
                                        CommandParameter="{x:Static vm:LeftExplorerTab.Tree}"
                                        Padding="10,5" FontSize="11" Margin="0,0,1,0"
                                        Cursor="Hand" BorderThickness="0,0,0,2"
                                        Background="Transparent">
                                    <Button.Style>
                                        <Style TargetType="Button">
                                            <Setter Property="Foreground" Value="{StaticResource FgMutedBrush}"/>
                                            <Setter Property="BorderBrush" Value="Transparent"/>
                                            <Style.Triggers>
                                                <DataTrigger Binding="{Binding IsTreeExplorerSelected}" Value="True">
                                                    <Setter Property="Foreground" Value="{StaticResource PrimaryBrush}"/>
                                                    <Setter Property="BorderBrush" Value="{StaticResource PrimaryBrush}"/>
                                                    <Setter Property="FontWeight" Value="SemiBold"/>
                                                </DataTrigger>
                                            </Style.Triggers>
                                        </Style>
                                    </Button.Style>
                                </Button>
                                <Button Content="Menu"
                                        Command="{Binding SelectLeftExplorerTabCommand}"
                                        CommandParameter="{x:Static vm:LeftExplorerTab.Menu}"
                                        Padding="10,5" FontSize="11" Margin="0,0,1,0"
                                        Cursor="Hand" BorderThickness="0,0,0,2"
                                        Background="Transparent">
                                    <Button.Style>
                                        <Style TargetType="Button">
                                            <Setter Property="Foreground" Value="{StaticResource FgMutedBrush}"/>
                                            <Setter Property="BorderBrush" Value="Transparent"/>
                                            <Style.Triggers>
                                                <DataTrigger Binding="{Binding IsMenuExplorerSelected}" Value="True">
                                                    <Setter Property="Foreground" Value="{StaticResource PrimaryBrush}"/>
                                                    <Setter Property="BorderBrush" Value="{StaticResource PrimaryBrush}"/>
                                                    <Setter Property="FontWeight" Value="SemiBold"/>
                                                </DataTrigger>
                                            </Style.Triggers>
                                        </Style>
                                    </Button.Style>
                                </Button>
                                <Button Content="Database"
                                        Command="{Binding SelectLeftExplorerTabCommand}"
                                        CommandParameter="{x:Static vm:LeftExplorerTab.Database}"
                                        Padding="10,5" FontSize="11"
                                        Cursor="Hand" BorderThickness="0,0,0,2"
                                        Background="Transparent">
                                    <Button.Style>
                                        <Style TargetType="Button">
                                            <Setter Property="Foreground" Value="{StaticResource FgMutedBrush}"/>
                                            <Setter Property="BorderBrush" Value="Transparent"/>
                                            <Style.Triggers>
                                                <DataTrigger Binding="{Binding IsDatabaseExplorerSelected}" Value="True">
                                                    <Setter Property="Foreground" Value="{StaticResource PrimaryBrush}"/>
                                                    <Setter Property="BorderBrush" Value="{StaticResource PrimaryBrush}"/>
                                                    <Setter Property="FontWeight" Value="SemiBold"/>
                                                </DataTrigger>
                                            </Style.Triggers>
                                        </Style>
                                    </Button.Style>
                                </Button>
                            </StackPanel>
                        </Border>

                        <Grid>
                            <Grid Visibility="{Binding IsTreeExplorerSelected, Converter={StaticResource BoolToVisibilityConverter}}">
                                <ex:ExplorerPanel DataContext="{Binding ExplorerVm}"/>
                            </Grid>
                            <Grid Visibility="{Binding IsMenuExplorerSelected, Converter={StaticResource BoolToVisibilityConverter}}">
                                <ex:MenuExplorerPanel DataContext="{Binding NavigationVm}"/>
                            </Grid>
                            <Grid Visibility="{Binding IsDatabaseExplorerSelected, Converter={StaticResource BoolToVisibilityConverter}}">
                                <ex:DatabaseExplorerPanel DataContext="{Binding DatabaseExplorerVm}"/>
                            </Grid>
                        </Grid>
                    </DockPanel>

                    <GridSplitter Grid.Row="1" Height="4"
                                  Background="{StaticResource IdeBorderBrush}"
                                  ResizeBehavior="PreviousAndNext" ResizeDirection="Rows"/>

                    <ex:OutlinePanel Grid.Row="2" DataContext="{Binding OutlineVm}"/>
                </Grid>
            </Border>

            <GridSplitter Grid.Column="1" Width="4" HorizontalAlignment="Center"
                          Background="{StaticResource IdeBorderBrush}"
                          Visibility="{Binding Shell.IsLeftDockOpen, Converter={StaticResource BoolToVisibilityConverter}}"
                          ResizeBehavior="PreviousAndNext" ResizeDirection="Columns"/>

            <!-- Center + Right + Bottom (bottom không đè Left) -->
            <Grid Grid.Column="2">
                <Grid.RowDefinitions>
                    <RowDefinition Height="*" MinHeight="80"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition MinHeight="0">
                        <RowDefinition.Style>
                            <Style TargetType="RowDefinition">
                                <Setter Property="Height" Value="220"/>
                                <Setter Property="MinHeight" Value="120"/>
                                <Style.Triggers>
                                    <DataTrigger Binding="{Binding Shell.IsBottomDockOpen}" Value="False">
                                        <Setter Property="Height" Value="0"/>
                                        <Setter Property="MinHeight" Value="0"/>
                                    </DataTrigger>
                                </Style.Triggers>
                            </Style>
                        </RowDefinition.Style>
                    </RowDefinition>
                </Grid.RowDefinitions>

                <Grid Grid.Row="0">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*" MinWidth="200"/>
                        <ColumnDefinition Width="Auto"/>
                        <ColumnDefinition MinWidth="0">
                            <ColumnDefinition.Style>
                                <Style TargetType="ColumnDefinition">
                                    <Setter Property="Width" Value="300"/>
                                    <Setter Property="MinWidth" Value="200"/>
                                    <Style.Triggers>
                                        <DataTrigger Binding="{Binding Shell.IsRightDockOpen}" Value="False">
                                            <Setter Property="Width" Value="0"/>
                                            <Setter Property="MinWidth" Value="0"/>
                                        </DataTrigger>
                                    </Style.Triggers>
                                </Style>
                            </ColumnDefinition.Style>
                        </ColumnDefinition>
                    </Grid.ColumnDefinitions>

                    <DockPanel Grid.Column="0">
                        <shellViews:DocumentTabBar DockPanel.Dock="Top"
                                                   DataContext="{Binding Shell}"/>
                        <ctrl:WorkspaceHost DataContext="{Binding Shell.ActiveContent}"/>
                    </DockPanel>

                    <GridSplitter Grid.Column="1" Width="4" HorizontalAlignment="Center"
                                  Background="{StaticResource IdeBorderBrush}"
                                  Visibility="{Binding Shell.IsRightDockOpen, Converter={StaticResource BoolToVisibilityConverter}}"
                                  ResizeBehavior="PreviousAndNext" ResizeDirection="Columns"/>

                    <Border Grid.Column="2"
                            HorizontalAlignment="Stretch"
                            Background="{StaticResource SidebarBgBrush}"
                            BorderBrush="{StaticResource IdeBorderBrush}"
                            BorderThickness="1,0,0,0"
                            Visibility="{Binding Shell.IsRightDockOpen, Converter={StaticResource BoolToVisibilityConverter}}">
                        <DockPanel>
                            <ItemsControl DockPanel.Dock="Top" ItemsSource="{Binding Shell.RightPanes}">
                                <ItemsControl.ItemsPanel>
                                    <ItemsPanelTemplate>
                                        <StackPanel Orientation="Horizontal"/>
                                    </ItemsPanelTemplate>
                                </ItemsControl.ItemsPanel>
                                <ItemsControl.ItemTemplate>
                                    <DataTemplate>
                                        <Button Content="{Binding Title}"
                                                Command="{Binding DataContext.Shell.SelectRightPaneCommand, RelativeSource={RelativeSource AncestorType=Window}}"
                                                CommandParameter="{Binding}"
                                                Padding="8,4" FontSize="11" Margin="0,0,1,0"
                                                Cursor="Hand" BorderThickness="0,0,0,2"
                                                Background="{StaticResource IdeDockHeaderBgBrush}">
                                            <Button.Style>
                                                <Style TargetType="Button">
                                                    <Setter Property="Foreground" Value="{StaticResource FgMutedBrush}"/>
                                                    <Setter Property="BorderBrush" Value="Transparent"/>
                                                    <Style.Triggers>
                                                        <DataTrigger Binding="{Binding IsSelected}" Value="True">
                                                            <Setter Property="Foreground" Value="{StaticResource PrimaryBrush}"/>
                                                            <Setter Property="BorderBrush" Value="{StaticResource PrimaryBrush}"/>
                                                            <Setter Property="FontWeight" Value="SemiBold"/>
                                                        </DataTrigger>
                                                    </Style.Triggers>
                                                </Style>
                                            </Button.Style>
                                        </Button>
                                    </DataTemplate>
                                </ItemsControl.ItemTemplate>
                            </ItemsControl>
                            <Grid>
                                <Grid Visibility="{Binding Shell.IsInsightSelected, Converter={StaticResource BoolToVisibilityConverter}}">
                                    <insight:InsightPanel DataContext="{Binding InsightPanelVm}"/>
                                </Grid>
                                <Grid Visibility="{Binding Shell.IsSymbolInfoSelected, Converter={StaticResource BoolToVisibilityConverter}}">
                                    <insight:SymbolInfoPanel DataContext="{Binding SymbolInfoVm}"/>
                                </Grid>
                                <Grid Visibility="{Binding Shell.IsPropertiesSelected, Converter={StaticResource BoolToVisibilityConverter}}">
                                    <props:PropertyGridPanel DataContext="{Binding PropertyGridVm}"/>
                                </Grid>
                                <Grid Visibility="{Binding Shell.IsToolboxSelected, Converter={StaticResource BoolToVisibilityConverter}}">
                                    <tb:ToolboxPanel DataContext="{Binding ToolboxVm}"/>
                                </Grid>
                                <Grid Visibility="{Binding Shell.IsRightPlaceholderSelected, Converter={StaticResource BoolToVisibilityConverter}}">
                                    <dock:DockPanelHost DataContext="{Binding Shell.SelectedRightPane}"/>
                                </Grid>
                            </Grid>
                        </DockPanel>
                    </Border>
                </Grid>

                <GridSplitter Grid.Row="1" Height="4" HorizontalAlignment="Stretch"
                              VerticalAlignment="Center"
                              Background="{StaticResource IdeBorderBrush}"
                              Visibility="{Binding Shell.IsBottomDockOpen, Converter={StaticResource BoolToVisibilityConverter}}"
                              ResizeBehavior="PreviousAndNext" ResizeDirection="Rows"
                              ShowsPreview="True"/>

                <Border Grid.Row="2"
                        MinHeight="120"
                        VerticalAlignment="Stretch"
                        Background="{StaticResource EditorBgBrush}"
                        BorderBrush="{StaticResource IdeBorderBrush}"
                        BorderThickness="0,1,0,0"
                        Visibility="{Binding Shell.IsBottomDockOpen, Converter={StaticResource BoolToVisibilityConverter}}">
                    <DockPanel LastChildFill="True">
                        <ItemsControl DockPanel.Dock="Top" ItemsSource="{Binding Shell.BottomPanes}">
                            <ItemsControl.ItemsPanel>
                                <ItemsPanelTemplate>
                                    <StackPanel Orientation="Horizontal"/>
                                </ItemsPanelTemplate>
                            </ItemsControl.ItemsPanel>
                            <ItemsControl.ItemTemplate>
                                <DataTemplate>
                                    <Button Content="{Binding Title}"
                                            Command="{Binding DataContext.Shell.SelectBottomPaneCommand, RelativeSource={RelativeSource AncestorType=Window}}"
                                            CommandParameter="{Binding}"
                                            Padding="10,4" FontSize="11" Margin="0,0,1,0"
                                            Cursor="Hand" BorderThickness="0,0,0,2"
                                            Background="{StaticResource IdeDockHeaderBgBrush}">
                                        <Button.Style>
                                            <Style TargetType="Button">
                                                <Setter Property="Foreground" Value="{StaticResource FgMutedBrush}"/>
                                                <Setter Property="BorderBrush" Value="Transparent"/>
                                                <Style.Triggers>
                                                    <DataTrigger Binding="{Binding IsSelected}" Value="True">
                                                        <Setter Property="Foreground" Value="{StaticResource PrimaryBrush}"/>
                                                        <Setter Property="BorderBrush" Value="{StaticResource PrimaryBrush}"/>
                                                        <Setter Property="FontWeight" Value="SemiBold"/>
                                                    </DataTrigger>
                                                </Style.Triggers>
                                            </Style>
                                        </Button.Style>
                                    </Button>
                                </DataTemplate>
                            </ItemsControl.ItemTemplate>
                        </ItemsControl>
                        <Grid>
                            <Grid Visibility="{Binding Shell.IsProblemsSelected, Converter={StaticResource BoolToVisibilityConverter}}">
                                <bottom:ProblemsPanel DataContext="{Binding DiagnosticsVm}"/>
                            </Grid>
                            <Grid Visibility="{Binding Shell.IsOutputSelected, Converter={StaticResource BoolToVisibilityConverter}}">
                                <bottom:OutputPanel DataContext="{Binding DiagnosticsVm}"/>
                            </Grid>
                            <Grid Visibility="{Binding Shell.IsReferencesSelected, Converter={StaticResource BoolToVisibilityConverter}}">
                                <bottom:ReferencesPanel DataContext="{Binding DiagnosticsVm}"/>
                            </Grid>
                            <Grid Visibility="{Binding Shell.IsLogSelected, Converter={StaticResource BoolToVisibilityConverter}}">
                                <bottom:LogPanel DataContext="{Binding DiagnosticsVm}"/>
                            </Grid>
                            <Grid Visibility="{Binding Shell.IsXmlBottomSelected, Converter={StaticResource BoolToVisibilityConverter}}">
                                <bottom:XmlBottomPanel DataContext="{Binding XmlBottomVm}"/>
                            </Grid>
                            <Grid Visibility="{Binding Shell.IsErrorListSelected, Converter={StaticResource BoolToVisibilityConverter}}">
                                <bottom:ErrorListPanel DataContext="{Binding DiagnosticsVm}"/>
                            </Grid>
                            <Grid Visibility="{Binding Shell.IsBottomPlaceholderSelected, Converter={StaticResource BoolToVisibilityConverter}}">
                                <dock:DockPanelHost DataContext="{Binding Shell.SelectedBottomPane}"/>
                            </Grid>
                        </Grid>
                    </DockPanel>
                </Border>
            </Grid>
        </Grid>

        <ctrl:AppStatusBar Grid.Row="4" DataContext="{Binding}"/>
    </Grid>
</Window>
