<UserControl x:Class="UI.Views.Controls.InsightEditorSurface"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:md="http://materialdesigninxaml.net/winfx/xaml/themes"
             xmlns:ctrl="clr-namespace:UI.Views.Controls">

    <!-- Một editor duy nhất, đổi nội dung theo mode (không panel song song):
         Source  → XML storage nguyên bản.
         Insight → ClearText đã expand entity, read-only, tô màu theo nguồn entity. -->
    <DockPanel Background="{StaticResource EditorBgBrush}">
        <Border DockPanel.Dock="Top" Style="{StaticResource IdeEditorColumnHeaderStyle}">
            <StackPanel Orientation="Horizontal">
                <md:PackIcon Kind="CodeTags" Width="12" Height="12"
                             Foreground="{StaticResource FgMutedBrush}" VerticalAlignment="Center"/>
                <TextBlock Text="{Binding EditorSurfaceHeader}" FontSize="11" FontWeight="SemiBold"
                           Foreground="{StaticResource FgMutedBrush}" Margin="6,0,0,0"/>
            </StackPanel>
        </Border>
        <ctrl:MonacoEditorHost x:Name="SourceEditor"
            BoundText="{Binding EditorText, UpdateSourceTrigger=PropertyChanged, Mode=TwoWay}"
            IsReadOnly="{Binding IsEditorReadOnly}"
            ShowInsights="{Binding ShowInsights}"
            ClearTextSegments="{Binding ClearTextSegments}"
            EditorLanguage="{Binding EditorLanguage, Mode=OneWay}"
            EditorMarkers="{Binding EditorMarkers, Mode=OneWay}"
            ScrollToLine="{Binding CaretLine, Mode=OneWay}"
            ScrollToOffset="{Binding CaretOffset, Mode=OneWay}"
            SelectedScript="{Binding SelectedScript, Mode=OneWayToSource}"/>
    </DockPanel>
</UserControl>
