<?xml version="1.0" encoding="utf-8"?>

<dir table="hrnv" code="stt_rec" order="stt_rec" xmlns="urn:schemas-fast-com:data-dir">
  <title v="thông tin hộ chiếu, thị thực" e="Passport, Visa Information"></title>

  <fields>
    <field name="stt_rec" isPrimaryKey="true" hidden="true" readOnly="true">
      <header v="" e=""></header>
    </field>
    <field name="ho_chieu_so">
      <header v="Số hộ chiếu" e="Passport No."></header>
    </field>
    <field name="ho_chieu_ngay_hl" type="DateTime" dataFormatString="@datetimeFormat">
      <header v="Ngày cấp hộ chiếu" e="Date of Issue"></header>
    </field>
    <field name="ho_chieu_noi_cap">
      <header v="Nơi cấp" e="Place of Issue"></header>
      <items style="AutoComplete" controller="hrNationality" reference="hc_nc%l" key="status ='1'" check="1=1" information="ma_qt$dmqt.ten_qt%l" new="Nationality"/>
    </field>
    <field name="hc_nc%l" readOnly="true" external="true" defaultValue="''">
      <header v="" e=""></header>
    </field>
    <field name="ho_chieu_ngay_hh" type="DateTime" dataFormatString="@datetimeFormat">
      <header v="Ngày hết hạn" e="Expiry Date"></header>
    </field>
    <field name="visa_so">
      <header v="Số thị thực &lt;span class=&quot;LabelDescription&quot;&gt;(Visa)" e="Visa Number"></header>
    </field>
    <field name="visa_ngay_hl" type="DateTime" dataFormatString="@datetimeFormat">
      <header v="Ngày cấp" e="Date of Issue"></header>
    </field>
    <field name="visa_noi_cap">
      <header v="Nơi cấp thị thực" e="Place of Issue"></header>
      <items style="AutoComplete" controller="hrNationality" reference="visa_nc%l" key="status ='1'" check="1=1" information="ma_qt$dmqt.ten_qt%l" new="Nationality"/>
    </field>
    <field name="visa_nc%l" readOnly="true" external="true" defaultValue="''">
      <header v="" e=""></header>
    </field>
    <field name="visa_ngay_hh" type="DateTime" dataFormatString="@datetimeFormat">
      <header v="Ngày hết hạn" e="Expiry Date"></header>
    </field>
  </fields>

  <views>
    <view id="Dir">
      <item value="120, 100, 100, 100, 130"/>
      <item value="111--: [ho_chieu_so].Label, [ho_chieu_so], [stt_rec]"/>
      <item value="11---: [ho_chieu_ngay_hl].Label, [ho_chieu_ngay_hl]"/>
      <item value="11100: [ho_chieu_noi_cap].Label, [ho_chieu_noi_cap], [hc_nc%l]"/>
      <item value="11---: [ho_chieu_ngay_hh].Label, [ho_chieu_ngay_hh]"/>
      <item value="11---: [visa_so].Label, [visa_so]"/>
      <item value="11---: [visa_ngay_hl].Label, [visa_ngay_hl]"/>
      <item value="11100: [visa_noi_cap].Label, [visa_noi_cap], [visa_nc%l]"/>
      <item value="11---: [visa_ngay_hh].Label, [visa_ngay_hh]"/>
    </view>
  </views>

  <commands>
    <command event="Updated">
      <text>
        <![CDATA[
select '' as message, '' as field, 'show$ViewPanelEmployeeID(this);' as script
]]>
      </text>
    </command>
  </commands>

  <css>
    <text>
      <![CDATA[
.LabelDescription{color:#73A6DE;}
]]>
    </text>
  </css>
