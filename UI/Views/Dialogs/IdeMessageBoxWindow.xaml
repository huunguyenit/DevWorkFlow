<Window x:Class="UI.Views.Dialogs.IdeMessageBoxWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:md="http://materialdesigninxaml.net/winfx/xaml/themes"
        Title="{Binding TitleText}"
        Width="480" MinWidth="360" MinHeight="180"
        SizeToContent="Height"
        ResizeMode="NoResize"
        ShowInTaskbar="False"
        WindowStyle="SingleBorderWindow"
        Background="White"
        SnapsToDevicePixels="True"
        UseLayoutRounding="True"
        TextOptions.TextFormattingMode="Display"
        TextOptions.TextRenderingMode="ClearType"
        KeyDown="Window_KeyDown">

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <Border Grid.Row="0"
                Background="{Binding HeaderBrush}"
                Padding="16,12">
            <DockPanel>
                <md:PackIcon DockPanel.Dock="Left"
                             Kind="{Binding IconKind}"
                             Width="22" Height="22"
                             Foreground="{Binding AccentBrush}"
                             VerticalAlignment="Center"
                             Margin="0,0,10,0"/>
                <TextBlock Text="{Binding TitleText}"
                           FontSize="15"
                           FontWeight="SemiBold"
                           Foreground="#24292F"
                           VerticalAlignment="Center"/>
            </DockPanel>
        </Border>

        <ScrollViewer Grid.Row="1"
                      Margin="18,14,18,8"
                      VerticalScrollBarVisibility="Auto"
                      MaxHeight="280">
            <TextBlock Text="{Binding MessageText}"
                       TextWrapping="Wrap"
                       Foreground="#24292F"
                       FontSize="13"/>
        </ScrollViewer>

        <Border Grid.Row="2"
                BorderBrush="#E6E8EE"
                BorderThickness="0,1,0,0"
                Padding="16,10"
                Background="#FAFBFC">
            <Button Content="OK"
                    MinWidth="88"
                    Height="32"
                    Padding="16,0"
                    HorizontalAlignment="Right"
                    IsDefault="True"
                    IsCancel="True"
                    Click="Ok_Click"
                    Cursor="Hand"
                    Background="{Binding AccentBrush}"
                    Foreground="White"
                    BorderThickness="0"
                    FontWeight="SemiBold"/>
        </Border>
    </Grid>
</Window>
