<UserControl x:Class="UI.Views.Explorer.OutlinePanel"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:md="http://materialdesigninxaml.net/winfx/xaml/themes"
             xmlns:tree="clr-namespace:UI.Tree">

    <UserControl.Resources>
        <BooleanToVisibilityConverter x:Key="BoolToVis"/>
    </UserControl.Resources>

    <DockPanel Background="{StaticResource SidebarBgBrush}" Margin="0,0,0,8">
        <Border DockPanel.Dock="Top" Style="{StaticResource IdeDockHeaderStyle}">
            <DockPanel>
                <TextBlock Text="{Binding Header}" Style="{StaticResource IdeDockHeaderTitleStyle}"/>
                <Button DockPanel.Dock="Right"
                        Style="{StaticResource IdeDockHeaderIconButtonStyle}"
                        Command="{Binding RefreshCommand}"
                        ToolTip="Refresh outline">
                    <md:PackIcon Kind="Refresh" Style="{StaticResource IdeDockHeaderPackIconStyle}"/>
                </Button>
            </DockPanel>
        </Border>

        <TextBlock DockPanel.Dock="Top"
                   Text="{Binding EmptyMessage}"
                   Style="{StaticResource IdePlaceholderTextStyle}"
                   Margin="8,8,8,4"
                   Visibility="{Binding IsEmpty, Converter={StaticResource BoolToVis}}"/>

        <tree:TreeControl x:Name="Tree"
                          Margin="0,0,0,8"
                          Engine="{Binding TreeRendering}"
                          FilterText="{Binding FilterText, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                          StatusText="{Binding StatusText}"
                          ShowFilter="True"
                          Visibility="{Binding HasNodes, Converter={StaticResource BoolToVis}}"
                          NodeActivated="Tree_NodeActivated"/>
    </DockPanel>
</UserControl>
