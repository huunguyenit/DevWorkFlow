<UserControl x:Class="UI.Views.Insight.InsightPanel"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:md="http://materialdesigninxaml.net/winfx/xaml/themes"
             xmlns:insight="clr-namespace:UI.ViewModels.Insight">

    <ScrollViewer VerticalScrollBarVisibility="Auto" Background="{StaticResource SidebarBgBrush}">
        <StackPanel Margin="8">
            <TextBlock Text="INSIGHT" FontSize="11" FontWeight="SemiBold"
                       Foreground="{StaticResource FgMutedBrush}" Margin="0,0,0,8"/>

            <StackPanel Orientation="Horizontal" Margin="0,0,0,12">
                <Border Background="#FFEBEE" CornerRadius="2" Padding="6,2" Margin="0,0,4,0">
                    <TextBlock Text="{Binding ErrorCount, StringFormat=E {0}}" FontSize="10"
                               Foreground="#C62828" FontWeight="SemiBold"/>
                </Border>
                <Border Background="#FFF8E1" CornerRadius="2" Padding="6,2" Margin="0,0,4,0">
                    <TextBlock Text="{Binding WarningCount, StringFormat=W {0}}" FontSize="10"
                               Foreground="#F57F17" FontWeight="SemiBold"/>
                </Border>
                <Border Background="#E3F2FD" CornerRadius="2" Padding="6,2">
                    <TextBlock Text="{Binding HintCount, StringFormat=H {0}}" FontSize="10"
                               Foreground="#1565C0" FontWeight="SemiBold"/>
                </Border>
            </StackPanel>

            <TextBlock Text="Entity Resolution" FontSize="11" FontWeight="SemiBold"
                       Foreground="{StaticResource FgBrush}" Margin="0,0,0,4"/>
            <ItemsControl ItemsSource="{Binding EntityRows}" Margin="0,0,0,12">
                <ItemsControl.ItemTemplate>
                    <DataTemplate DataType="{x:Type insight:InsightEntityRowVm}">
                        <Border BorderBrush="{StaticResource IdeBorderBrush}" BorderThickness="0,0,0,1"
                                Padding="0,4">
                            <StackPanel>
                                <TextBlock Text="{Binding ReferenceText}" FontFamily="Consolas"
                                           FontSize="10" FontStyle="Italic" Foreground="#757575"/>
                                <DockPanel Margin="0,2,0,0">
                                    <Border DockPanel.Dock="Right" Padding="4,0" CornerRadius="2"
                                            Background="#E8F5E9" Margin="4,0,0,0">
                                        <TextBlock Text="{Binding StatusText}" FontSize="9"
                                                   Foreground="#2E7D32" FontWeight="SemiBold"/>
                                    </Border>
                                    <TextBlock Text="{Binding ResolvedValue}" FontSize="11"
                                               TextWrapping="Wrap" Foreground="{StaticResource FgBrush}"/>
                                </DockPanel>
                            </StackPanel>
                        </Border>
                    </DataTemplate>
                </ItemsControl.ItemTemplate>
            </ItemsControl>

            <TextBlock Text="Validation" FontSize="11" FontWeight="SemiBold"
                       Foreground="{StaticResource FgBrush}" Margin="0,0,0,4"/>
            <ItemsControl ItemsSource="{Binding ValidationRows}">
                <ItemsControl.ItemTemplate>
                    <DataTemplate DataType="{x:Type insight:InsightValidationRowVm}">
                        <StackPanel Orientation="Horizontal" Margin="0,2">
                            <TextBlock Text="{Binding SeverityBadge}" FontWeight="Bold" Width="16"
                                       Foreground="#1565C0"/>
                            <TextBlock Text="{Binding Message}" TextWrapping="Wrap" FontSize="11"
                                       Foreground="{StaticResource FgBrush}"/>
                        </StackPanel>
                    </DataTemplate>
                </ItemsControl.ItemTemplate>
            </ItemsControl>
        </StackPanel>
    </ScrollViewer>
</UserControl>
