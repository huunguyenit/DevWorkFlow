    <field name="thue_nt" type="Decimal" readOnly="true" dataFormatString="@foreignCurrencyAmountViewFormat" clientDefault="0" width="0" hidden="true">
      <header v="Thuế giá trị gia tăng nt" e="FC VAT Amount"></header>
      <items style="Numeric"/>
    </field>
    <field name="thue" type="Decimal" readOnly="true" dataFormatString="@baseCurrencyAmountViewFormat" clientDefault="0" width="0" hidden="true" allowContain="true">
      <header v="Thuế giá trị gia tăng" e="VAT Amount"></header>
      <items style="Numeric"/>
    </field>
    <field name="ma_vt0" width="0" hidden="true" readOnly="true" clientDefault="Default" aliasName="a">
      <header v="Mã hàng của ncc" e="Supplier Item Code"></header>
    </field>
    <field name="dh_so" align="right" readOnly="true" width="0" hidden="true" aliasName="a">
      <header v="Đơn hàng" e="Import Purchase Order"></header>
    </field>
    <field name="dh_ln" type="Int32" dataFormatString="#####" readOnly="true" width="0" hidden="true" aliasName="a">
