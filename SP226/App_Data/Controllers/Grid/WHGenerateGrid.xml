<?xml version="1.0" encoding="utf-8"?>

<!DOCTYPE grid [
  <!ENTITY XMLFlowGridCommand SYSTEM "..\Include\XML\FlowGridCommand.txt">
  <!ENTITY ScriptFlowGridFunction SYSTEM "..\Include\Javascript\FlowGridFunction.txt">

  <!ENTITY Identity "WHGenerate">
]>

<grid table="wrkin" code="ma_vi_tri, ma_lo" order="ma_vi_tri, ma_lo" type="Detail" freezeColumns="3" id="PXR" xmlns="urn:schemas-fast-com:data-grid">
  <title v="" e=""></title>
  <subTitle v="" e=""></subTitle>
  <fields>
    <field name="ma_vi_tri" isPrimaryKey="true" readOnly="true" width="100">
      <header v="Mã vị trí" e="Location"></header>
    </field>
    <field name="ma_lo" isPrimaryKey="true" readOnly="true" width="100">
      <header v="Mã lô" e="Lot"></header>
    </field>
    <field name="sl_tt0" type="Decimal" dataFormatString="@quantityInputFormat" width="100" readOnly="true">
      <header v="Tồn kho" e="Stock"></header>
      <items style="Numeric"/>
    </field>
    <field name="sl_pb" type="Decimal" dataFormatString="@quantityInputFormat" width="100">
      <header v="Số lượng" e="Quantity"></header>
      <items style="Numeric"/>
    </field>
    <field name="ngay_nhap" type="DateTime" dataFormatString="@datetimeFormat" width="100" readOnly="true">
      <header v="Ngày nhập" e="Receipt Date"></header>
    </field>
    <field name="ngay_hhsd" type="DateTime" dataFormatString="@datetimeFormat" width="100" readOnly="true">
      <header v="Hạn sử dụng" e="Expiry Date"></header>
    </field>
    <field name="nhieu_dvt" type="Boolean" width="0" hidden="true">
      <header v="" e=""></header>
    </field>
    <field name="stt_rec0" width="0" hidden="true">
      <header v="" e=""></header>
    </field>
  </fields>

  <views>
    <view id="Grid">
      <field name="ma_vi_tri"/>
      <field name="ma_lo"/>
      <field name="sl_tt0"/>
      <field name="sl_pb"/>
      <field name="ngay_nhap"/>
      <field name="ngay_hhsd"/>
      <field name="nhieu_dvt"/>
      <field name="stt_rec0"/>
    </view>
  </views>

  <commands>
    &XMLFlowGridCommand;
  </commands>

  <script>
    <text>
      &ScriptFlowGridFunction;
    </text>
  </script>

  <queries>
    <query event="Loading">
      <text>
        <![CDATA[
exec FastBusiness$Voucher$Generate$Lot @ma_vt, @ma_kho, @dvt1, @he_so1, @sl_xuat1, @stt_rec, @ma_ct, @@language, @@userID, @@admin
]]>
      </text>
    </query>
  </queries>

  <toolbar>
    <button command="Export">
      <title v="Toolbar.Export" e="Toolbar.Export"></title>
    </button>
    <button command="Freeze">
      <title v="Toolbar.Freeze" e="Toolbar.Freeze"></title>
    </button>
  </toolbar>

</grid>