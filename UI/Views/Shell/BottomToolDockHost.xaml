<UserControl x:Class="UI.Views.Shell.BottomToolDockHost"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:bottom="clr-namespace:UI.Views.Bottom"
             xmlns:dock="clr-namespace:UI.Docking"
             xmlns:md="http://materialdesigninxaml.net/winfx/xaml/themes">

    <UserControl.Resources>
        <DataTemplate x:Key="SqlRunHeaderTemplate">
            <Border Background="{StaticResource IdeDockHeaderBgBrush}"
                    BorderBrush="{StaticResource IdeBorderBrush}"
                    BorderThickness="0,0,0,1"
                    Padding="8,3">
                <DockPanel>
                    <TextBlock Text="{Binding Status}" DockPanel.Dock="Right"
                               VerticalAlignment="Center"
                               Foreground="{StaticResource FgMutedBrush}" FontSize="11"
                               TextTrimming="CharacterEllipsis" Margin="12,0,0,0"/>
                    <Button Content="Stop" DockPanel.Dock="Right"
                            Command="{Binding CancelCommand}"
                            Style="{StaticResource IdeDockTabButtonStyle}"
                            Margin="8,0,0,0"
                            Visibility="{Binding IsBusy, Converter={StaticResource BoolToVisibilityConverter}}"/>
                    <TextBlock Text="{Binding Title}" VerticalAlignment="Center"
                               FontWeight="SemiBold" FontSize="11"
                               Foreground="{StaticResource FgBrush}"
                               TextTrimming="CharacterEllipsis"/>
                    <TextBlock Text="{Binding TargetDbLabel}" VerticalAlignment="Center"
                               Margin="8,0,0,0" FontSize="11"
                               Foreground="{StaticResource FgMutedBrush}"/>
                </DockPanel>
            </Border>
        </DataTemplate>

        <Style x:Key="SqlEmptyHintStyle" TargetType="TextBlock">
            <Setter Property="Foreground" Value="{StaticResource FgMutedBrush}"/>
            <Setter Property="FontSize" Value="12"/>
            <Setter Property="Margin" Value="12"/>
            <Setter Property="TextWrapping" Value="Wrap"/>
        </Style>
    </UserControl.Resources>

    <DockPanel Background="{StaticResource EditorBgBrush}">
        <Border DockPanel.Dock="Top"
                Background="{StaticResource IdeDockHeaderBgBrush}"
                BorderBrush="{StaticResource IdeBorderBrush}"
                BorderThickness="0,0,0,1"
                Padding="4,2">
            <ItemsControl ItemsSource="{Binding Shell.BottomPanes}">
                    <ItemsControl.ItemsPanel>
                        <ItemsPanelTemplate>
                            <StackPanel Orientation="Horizontal"/>
                        </ItemsPanelTemplate>
                    </ItemsControl.ItemsPanel>
                    <ItemsControl.ItemTemplate>
                        <DataTemplate>
                            <Button Content="{Binding Title}"
                                    Command="{Binding DataContext.Shell.SelectBottomPaneCommand, RelativeSource={RelativeSource AncestorType=UserControl}}"
                                    CommandParameter="{Binding}">
                                <Button.Style>
                                    <Style TargetType="Button" BasedOn="{StaticResource IdeDockTabButtonStyle}">
                                        <Style.Triggers>
                                            <DataTrigger Binding="{Binding IsSelected}" Value="True">
                                                <Setter Property="Foreground" Value="{StaticResource FgBrightBrush}"/>
                                                <Setter Property="BorderBrush" Value="{StaticResource PrimaryBrush}"/>
                                                <Setter Property="FontWeight" Value="SemiBold"/>
                                                <Setter Property="Background" Value="White"/>
                                            </DataTrigger>
                                        </Style.Triggers>
                                    </Style>
                                </Button.Style>
                            </Button>
                        </DataTemplate>
                    </ItemsControl.ItemTemplate>
            </ItemsControl>
        </Border>
        <Grid DataContext="{Binding}">
            <!-- PROBLEMS: đủ nội dung + badge lọc Error/Warning/Hint -->
            <Grid Visibility="{Binding Shell.IsProblemsSelected, Converter={StaticResource BoolToVisibilityConverter}}">
                <bottom:BottomToolPanel DataContext="{Binding DiagnosticsVm.ProblemsPane}"/>
            </Grid>

            <!-- SEARCH: Ln + content dòng -->
            <Grid Visibility="{Binding Shell.IsSearchResultSelected, Converter={StaticResource BoolToVisibilityConverter}}">
                <bottom:BottomToolPanel DataContext="{Binding DiagnosticsVm.SearchPane}"/>
            </Grid>

            <!-- MESSAGE: gộp Log/Output/SQL messages; error đỏ; click navigate (line) sau -->
            <Grid Visibility="{Binding Shell.IsSqlMessageSelected, Converter={StaticResource BoolToVisibilityConverter}}">
                <bottom:BottomToolPanel DataContext="{Binding DiagnosticsVm.MessagePane}"/>
            </Grid>

            <!-- RESULT: table + filter + sort header + status row/col -->
            <Grid Visibility="{Binding Shell.IsSqlResultSelected, Converter={StaticResource BoolToVisibilityConverter}}">
                <TextBlock Style="{StaticResource SqlEmptyHintStyle}"
                           Text="Chưa chạy SQL. F5 trong tab SQL, hoặc bôi đen SQL ở Form Source rồi F5."
                           Visibility="{Binding ActiveSqlDocument, Converter={StaticResource NullToVisibilityConverter}, ConverterParameter=Inverse}"/>
                <DockPanel DataContext="{Binding ActiveSqlDocument}"
                           Visibility="{Binding DataContext.ActiveSqlDocument, RelativeSource={RelativeSource AncestorType=UserControl}, Converter={StaticResource NullToVisibilityConverter}}">
                    <ContentPresenter DockPanel.Dock="Top" Content="{Binding}"
                                      ContentTemplate="{StaticResource SqlRunHeaderTemplate}"/>

                    <Border DockPanel.Dock="Top" Padding="8,4"
                            Background="{StaticResource CodePaneHeaderBrush}"
                            BorderBrush="{StaticResource IdeBorderBrush}"
                            BorderThickness="0,0,0,1">
                        <DockPanel>
                            <md:PackIcon Kind="FilterOutline" Width="14" Height="14"
                                         Foreground="{StaticResource FgMutedBrush}"
                                         VerticalAlignment="Center" Margin="0,0,6,0"/>
                            <TextBox Text="{Binding ResultFilter, UpdateSourceTrigger=PropertyChanged}"
                                     FontSize="11" Padding="4,2"
                                     VerticalContentAlignment="Center"
                                     ToolTip="Lọc mọi cột (substring)"/>
                        </DockPanel>
                    </Border>

                    <Border DockPanel.Dock="Bottom" Padding="8,3"
                            Background="{StaticResource IdeDockHeaderBgBrush}"
                            BorderBrush="{StaticResource IdeBorderBrush}"
                            BorderThickness="0,1,0,0">
                        <TextBlock FontSize="11" Foreground="{StaticResource FgMutedBrush}"
                                   Text="{Binding ResultFocusStatus}"
                                   TextTrimming="CharacterEllipsis"/>
                    </Border>

                    <ListBox DockPanel.Dock="Left" Width="140"
                             ItemsSource="{Binding ResultSets}"
                             SelectedItem="{Binding SelectedResultSet}"
                             DisplayMemberPath="Header"
                             BorderThickness="0,0,1,0"
                             BorderBrush="{StaticResource IdeBorderBrush}"
                             Background="Transparent"/>

                    <DataGrid x:Name="SqlResultGrid"
                              ItemsSource="{Binding SelectedResultView}"
                              AutoGenerateColumns="True"
                              IsReadOnly="True"
                              CanUserAddRows="False"
                              CanUserDeleteRows="False"
                              CanUserSortColumns="True"
                              CanUserResizeColumns="True"
                              HeadersVisibility="Column"
                              GridLinesVisibility="Horizontal"
                              AlternatingRowBackground="#F7F9FC"
                              SelectionUnit="Cell"
                              SelectionMode="Single"
                              BorderThickness="0"
                              FontSize="12"
                              EnableRowVirtualization="True"
                              EnableColumnVirtualization="True"
                              CurrentCellChanged="SqlResultGrid_CurrentCellChanged"/>
                </DockPanel>
            </Grid>
        </Grid>
    </DockPanel>
</UserControl>
