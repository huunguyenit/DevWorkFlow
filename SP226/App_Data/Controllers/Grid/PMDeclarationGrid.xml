  <commands>
    &XMLFlowGridCommand;
  </commands>

  <script>
    <text>
      &ScriptFlowGridFunction;
    </text>
  </script>

  <queries>
    <query event="Loading">
      <text>
        &CheckRelativeProcess;
        &EnvironmentTaxInheritanceQuery;
        <![CDATA[
select @@fieldExternal into #temp from ]]>&EnvironmentTaxPrimePartitionCurrent;<![CDATA[ a left join dmvt b on a.ma_vt = b.ma_vt left join dmtk c on a.tk_thue = c.tk ]]>&EnvironmentTaxInheritanceLoadingJoin;<![CDATA[ where a.stt_rec = @stt_rec
update #temp set tk_thue_nk = isnull(b.tk_thue, '') from #temp a left join dmthuenk b on a.ma_thue_nk = b.ma_thue
update #temp set tk_thue_ttdb = isnull(b.tk_thue, '') from #temp a left join dmthuettdb b on a.ma_thue_ttdb = b.ma_thue
update #temp set tk_thue = isnull(b.tk_thue_no3, '') from #temp a left join dmthue b on a.ma_thue = b.ma_thue
select * from #temp order by @@orderByClause
drop table #temp
]]>
      </text>
    </query>
  </queries>

  <toolbar>
    <button command="Export">
      <title v="Toolbar.Export" e="Toolbar.Export"></title>
    </button>
    <button command="Freeze">
      <title v="Toolbar.Freeze" e="Toolbar.Freeze"></title>
    </button>
  </toolbar>

</grid>