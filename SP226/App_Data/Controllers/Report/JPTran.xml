  <query>
    <text>
      <![CDATA[
if dbo.FastBusiness$Function$CheckSQLInjection(@stt_rec) = 0 return
]]>&GLTranReportSql;<![CDATA[
else begin
    declare @m_ma_nt0 varchar(10), @bilingual tinyint, @l char(1)
   if @@form in ('030', '040', '130', '140') select @bilingual = 1, @l = 'V' else select @bilingual = 0, @l = @@language    
    select @m_ma_nt0 = val from options where name = 'm_ma_nt0' 
    select ltrim(so_ct) as so_ct,t_ps_no, t_ps_no_nt, t_ps_co, t_ps_co_nt, 
		    dbo.FastBusiness$Function$System$ReadCurrency(@m_ma_nt0, t_ps_no, @l) as t_ps_no_in_word, 
		    dbo.FastBusiness$Function$System$ReadCurrency(ma_nt, t_ps_no_nt, @l) as t_ps_no_nt_in_word,
        case when @bilingual = 1 then dbo.FastBusiness$Function$System$ReadCurrency(@m_ma_nt0, t_ps_no, 'E') else '' end as t_ps_no_in_word2, 
		    case when @bilingual = 1 then  dbo.FastBusiness$Function$System$ReadCurrency(ma_nt, t_ps_no_nt, 'E') else '' end as t_ps_no_nt_in_word2,
		    dbo.FastBusiness$Function$System$ReadCurrency(@m_ma_nt0, t_ps_co, @@language) as t_ps_co_in_word,
		    dbo.FastBusiness$Function$System$ReadCurrency(ma_nt, t_ps_co_nt, @@language) as t_ps_co_nt_in_word,
		    replace(str(day(ngay_ct),2),' ','0') ngay, replace(str(month(ngay_ct),2),' ','0') thang, cast(year(ngay_ct) as char(4)) nam
	    from @@prime$partition$current a with(nolock)
	    where stt_rec = @stt_rec

    declare @key varchar(128)
    select @key = 'a.stt_rec = ''' + @stt_rec + ''''
    exec rs_PrintGLTran @@language, @key, 'd39$$partition$current', @@id
end
]]>
      &Conditional.Unit.Profile.Query.Declare;
      &Conditional.Unit.Profile.Query.Select;
      &Conditional.Unit.Profile.Query.Result;
    </text>
  </query>

