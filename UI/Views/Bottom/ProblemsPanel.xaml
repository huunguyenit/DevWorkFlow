<UserControl x:Class="UI.Views.Bottom.ProblemsPanel"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:md="http://materialdesigninxaml.net/winfx/xaml/themes"
             xmlns:bottom="clr-namespace:UI.ViewModels.Bottom">

    <DockPanel Background="{StaticResource EditorBgBrush}">
        <Border DockPanel.Dock="Top" Background="{StaticResource CodePaneHeaderBrush}"
                Padding="8,3" BorderBrush="{StaticResource IdeBorderBrush}" BorderThickness="0,0,0,1">
            <DockPanel>
                <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                    <TextBlock Text="PROBLEMS" FontSize="11" FontWeight="SemiBold"
                               VerticalAlignment="Center"
                               Foreground="{StaticResource FgMutedBrush}"/>
                    <Border Background="#FFEBEE" CornerRadius="8" Padding="7,1" Margin="10,0,0,0">
                        <StackPanel Orientation="Horizontal">
                            <md:PackIcon Kind="CloseCircle" Width="11" Height="11"
                                         Foreground="#C62828" VerticalAlignment="Center"/>
                            <TextBlock Text="{Binding ErrorCount}" FontSize="10" Margin="3,0,0,0"
                                       Foreground="#C62828" FontWeight="SemiBold" VerticalAlignment="Center"/>
                        </StackPanel>
                    </Border>
                    <Border Background="#FFF8E1" CornerRadius="8" Padding="7,1" Margin="4,0,0,0">
                        <StackPanel Orientation="Horizontal">
                            <md:PackIcon Kind="Alert" Width="11" Height="11"
                                         Foreground="#F57F17" VerticalAlignment="Center"/>
                            <TextBlock Text="{Binding WarningCount}" FontSize="10" Margin="3,0,0,0"
                                       Foreground="#F57F17" FontWeight="SemiBold" VerticalAlignment="Center"/>
                        </StackPanel>
                    </Border>
                    <Border Background="#E3F2FD" CornerRadius="8" Padding="7,1" Margin="4,0,0,0">
                        <StackPanel Orientation="Horizontal">
                            <md:PackIcon Kind="LightbulbOutline" Width="11" Height="11"
                                         Foreground="#1565C0" VerticalAlignment="Center"/>
                            <TextBlock Text="{Binding HintCount}" FontSize="10" Margin="3,0,0,0"
                                       Foreground="#1565C0" FontWeight="SemiBold" VerticalAlignment="Center"/>
                        </StackPanel>
                    </Border>
                </StackPanel>
                <Button DockPanel.Dock="Right" Content="Clear" FontSize="10" Padding="8,2"
                        Command="{Binding ClearProblemsCommand}"
                        Style="{StaticResource IdeToolButtonStyle}"
                        HorizontalAlignment="Right" Margin="0"/>
            </DockPanel>
        </Border>

        <ListBox x:Name="ProblemsList"
                 ItemsSource="{Binding Problems}"
                 Background="Transparent"
                 BorderThickness="0"
                 FontSize="11"
                 HorizontalContentAlignment="Stretch"
                 ScrollViewer.HorizontalScrollBarVisibility="Disabled"
                 VirtualizingPanel.ScrollUnit="Pixel"
                 MouseDoubleClick="ProblemsList_MouseDoubleClick">
            <ListBox.ItemContainerStyle>
                <Style TargetType="ListBoxItem">
                    <Setter Property="Padding" Value="8,4"/>
                    <Setter Property="Cursor" Value="Hand"/>
                    <Setter Property="SnapsToDevicePixels" Value="True"/>
                    <Setter Property="Template">
                        <Setter.Value>
                            <ControlTemplate TargetType="ListBoxItem">
                                <Border x:Name="Bd" Background="Transparent"
                                        Padding="{TemplateBinding Padding}">
                                    <ContentPresenter/>
                                </Border>
                                <ControlTemplate.Triggers>
                                    <Trigger Property="IsMouseOver" Value="True">
                                        <Setter TargetName="Bd" Property="Background" Value="#F0F6FC"/>
                                    </Trigger>
                                    <Trigger Property="IsSelected" Value="True">
                                        <Setter TargetName="Bd" Property="Background" Value="#CCE8FF"/>
                                    </Trigger>
                                </ControlTemplate.Triggers>
                            </ControlTemplate>
                        </Setter.Value>
                    </Setter>
                </Style>
            </ListBox.ItemContainerStyle>
            <ListBox.ItemTemplate>
                <DataTemplate DataType="{x:Type bottom:ProblemItemVm}">
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="Auto"/>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="Auto"/>
                        </Grid.ColumnDefinitions>

                        <md:PackIcon x:Name="SeverityIcon" Grid.Column="0"
                                     Kind="LightbulbOutline" Width="14" Height="14"
                                     Margin="0,1,8,0" VerticalAlignment="Top"
                                     Foreground="#1565C0"/>

                        <StackPanel Grid.Column="1">
                            <TextBlock TextTrimming="CharacterEllipsis">
                                <TextBlock.ToolTip>
                                    <ToolTip MaxWidth="520">
                                        <StackPanel>
                                            <TextBlock Text="{Binding Description}" TextWrapping="Wrap"
                                                       FontWeight="SemiBold"/>
                                            <TextBlock x:Name="TipResolution"
                                                       Text="{Binding Resolution}" TextWrapping="Wrap"
                                                       Margin="0,4,0,0"/>
                                        </StackPanel>
                                    </ToolTip>
                                </TextBlock.ToolTip>
                                <Run Text="{Binding Description, Mode=OneWay}"/>
                                <Run Text="{Binding Code, Mode=OneWay}"
                                     Foreground="{StaticResource FgMutedBrush}"/>
                            </TextBlock>
                            <TextBlock x:Name="ResolutionText"
                                       Text="{Binding Resolution}"
                                       TextTrimming="CharacterEllipsis"
                                       FontSize="10" Margin="0,1,0,0"
                                       Foreground="{StaticResource FgMutedBrush}"
                                       ToolTip="{Binding Resolution}"/>
                        </StackPanel>

                        <TextBlock Grid.Column="2" Margin="12,0,0,0" VerticalAlignment="Top"
                                   FontSize="10" Foreground="{StaticResource FgMutedBrush}"
                                   ToolTip="{Binding File}">
                            <Run Text="{Binding File, Mode=OneWay}"/>
                            <Run Text="{Binding LocationText, Mode=OneWay}"/>
                        </TextBlock>
                    </Grid>
                    <DataTemplate.Triggers>
                        <DataTrigger Binding="{Binding SeverityBadge}" Value="E">
                            <Setter TargetName="SeverityIcon" Property="Kind" Value="CloseCircle"/>
                            <Setter TargetName="SeverityIcon" Property="Foreground" Value="#C62828"/>
                        </DataTrigger>
                        <DataTrigger Binding="{Binding SeverityBadge}" Value="W">
                            <Setter TargetName="SeverityIcon" Property="Kind" Value="Alert"/>
                            <Setter TargetName="SeverityIcon" Property="Foreground" Value="#F57F17"/>
                        </DataTrigger>
                        <DataTrigger Binding="{Binding Resolution}" Value="">
                            <Setter TargetName="ResolutionText" Property="Visibility" Value="Collapsed"/>
                            <Setter TargetName="TipResolution" Property="Visibility" Value="Collapsed"/>
                        </DataTrigger>
                    </DataTemplate.Triggers>
                </DataTemplate>
            </ListBox.ItemTemplate>
        </ListBox>
    </DockPanel>
</UserControl>
