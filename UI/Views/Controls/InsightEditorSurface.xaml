<UserControl x:Class="UI.Views.Controls.InsightEditorSurface"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:md="http://materialdesigninxaml.net/winfx/xaml/themes"
             xmlns:ctrl="clr-namespace:UI.Views.Controls"
             xmlns:design="clr-namespace:UI.ViewModels.Design">

    <UserControl.Resources>
        <BooleanToVisibilityConverter x:Key="BoolToVis"/>
    </UserControl.Resources>

    <Grid Background="{StaticResource EditorBgBrush}">
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="*" MinWidth="240"/>
            <ColumnDefinition Width="Auto"/>
            <ColumnDefinition Width="132" MinWidth="100"/>
            <ColumnDefinition Width="Auto"/>
            <ColumnDefinition Width="240" MinWidth="160"/>
        </Grid.ColumnDefinitions>

        <!-- Source -->
        <DockPanel Grid.Column="0">
            <Border DockPanel.Dock="Top" Style="{StaticResource IdeEditorColumnHeaderStyle}">
                <StackPanel Orientation="Horizontal">
                    <md:PackIcon Kind="CodeTags" Width="12" Height="12"
                                 Foreground="{StaticResource FgMutedBrush}" VerticalAlignment="Center"/>
                    <TextBlock Text="Source" FontSize="11" FontWeight="SemiBold"
                               Foreground="{StaticResource FgMutedBrush}" Margin="6,0,0,0"/>
                </StackPanel>
            </Border>
            <Border BorderBrush="{StaticResource IdeBorderBrush}" BorderThickness="0,0,1,0">
                <ctrl:BindableXmlEditor x:Name="SourceEditor"
                    BoundText="{Binding EditorText, UpdateSourceTrigger=PropertyChanged, Mode=TwoWay}"
                    ShowInsights="False"
                    ScrollToLine="{Binding CaretLine, Mode=OneWay}"
                    ScrollToOffset="{Binding CaretOffset, Mode=OneWay}"/>
            </Border>
        </DockPanel>

        <GridSplitter Grid.Column="1" Width="4"
                        Background="{StaticResource IdeBorderBrush}"
                        ResizeBehavior="PreviousAndNext" ResizeDirection="Columns"
                        Visibility="{Binding ShowInsightColumns, Converter={StaticResource BoolToVis}}"/>

        <!-- Semantic -->
        <DockPanel Grid.Column="2"
                   Visibility="{Binding ShowInsightColumns, Converter={StaticResource BoolToVis}}">
            <Border DockPanel.Dock="Top" Style="{StaticResource IdeEditorColumnHeaderStyle}">
                <StackPanel Orientation="Horizontal">
                    <md:PackIcon Kind="Sitemap" Width="12" Height="12"
                                 Foreground="#7B1FA2" VerticalAlignment="Center"/>
                    <TextBlock Text="Semantic" FontSize="11" FontWeight="SemiBold"
                               Foreground="{StaticResource FgMutedBrush}" Margin="6,0,0,0"/>
                </StackPanel>
            </Border>
            <ListBox ItemsSource="{Binding InsightEditorLines}"
                     SelectedItem="{Binding SelectedInsightLine, Mode=TwoWay}"
                     BorderThickness="0" Background="Transparent"
                     ScrollViewer.HorizontalScrollBarVisibility="Disabled">
                <ListBox.ItemContainerStyle>
                    <Style TargetType="ListBoxItem">
                        <Setter Property="Padding" Value="0"/>
                        <Setter Property="HorizontalContentAlignment" Value="Stretch"/>
                        <Setter Property="Template">
                            <Setter.Value>
                                <ControlTemplate TargetType="ListBoxItem">
                                    <Border x:Name="bd" Background="Transparent" Padding="2,1">
                                        <ContentPresenter/>
                                    </Border>
                                    <ControlTemplate.Triggers>
                                        <Trigger Property="IsMouseOver" Value="True">
                                            <Setter TargetName="bd" Property="Background" Value="#F5F0FA"/>
                                        </Trigger>
                                        <Trigger Property="IsSelected" Value="True">
                                            <Setter TargetName="bd" Property="Background" Value="{StaticResource IdeSemanticSoftBrush}"/>
                                        </Trigger>
                                    </ControlTemplate.Triggers>
                                </ControlTemplate>
                            </Setter.Value>
                        </Setter>
                    </Style>
                </ListBox.ItemContainerStyle>
                <ListBox.ItemTemplate>
                    <DataTemplate DataType="{x:Type design:InsightEditorLineVm}">
                        <Border Padding="4,3" Background="Transparent"
                                MouseLeftButtonUp="InsightLine_Click" Cursor="Hand">
                            <StackPanel Orientation="Horizontal">
                                <Border Background="{StaticResource IdeAccentSoftBrush}" CornerRadius="3" Padding="5,1" Margin="0,0,4,0">
                                    <StackPanel Orientation="Horizontal">
                                        <md:PackIcon Kind="{Binding KindIcon}" Width="11" Height="11"
                                                     Foreground="#1565C0" VerticalAlignment="Center"/>
                                        <TextBlock Text="{Binding KindBadge}" FontSize="10" FontWeight="SemiBold"
                                                   Foreground="#1565C0" Margin="3,0,0,0"/>
                                    </StackPanel>
                                </Border>
                                <TextBlock Text="{Binding DisplayLine}" FontSize="9"
                                           Foreground="{StaticResource FgMutedBrush}"
                                           VerticalAlignment="Center"/>
                            </StackPanel>
                        </Border>
                    </DataTemplate>
                </ListBox.ItemTemplate>
            </ListBox>
        </DockPanel>

        <GridSplitter Grid.Column="3" Width="4"
                        Background="{StaticResource IdeBorderBrush}"
                        ResizeBehavior="PreviousAndNext" ResizeDirection="Columns"
                        Visibility="{Binding ShowInsightColumns, Converter={StaticResource BoolToVis}}"/>

        <!-- Resolved -->
        <DockPanel Grid.Column="4"
                   Visibility="{Binding ShowInsightColumns, Converter={StaticResource BoolToVis}}">
            <Border DockPanel.Dock="Top" Style="{StaticResource IdeEditorColumnHeaderStyle}">
                <StackPanel Orientation="Horizontal">
                    <md:PackIcon Kind="Variable" Width="12" Height="12"
                                 Foreground="#6A1B9A" VerticalAlignment="Center"/>
                    <TextBlock Text="Resolved" FontSize="11" FontWeight="SemiBold"
                               Foreground="{StaticResource FgMutedBrush}" Margin="6,0,0,0"/>
                </StackPanel>
            </Border>
            <ListBox ItemsSource="{Binding InsightEditorLines}"
                     BorderThickness="0" Background="Transparent"
                     ScrollViewer.HorizontalScrollBarVisibility="Disabled">
                <ListBox.ItemContainerStyle>
                    <Style TargetType="ListBoxItem">
                        <Setter Property="Padding" Value="0"/>
                        <Setter Property="HorizontalContentAlignment" Value="Stretch"/>
                    </Style>
                </ListBox.ItemContainerStyle>
                <ListBox.ItemTemplate>
                    <DataTemplate DataType="{x:Type design:InsightEditorLineVm}">
                        <Border Padding="6,4" Margin="0,1">
                            <StackPanel>
                                <TextBlock Text="{Binding ReferenceText}" FontFamily="{StaticResource MonoFont}" FontSize="10"
                                           FontStyle="Italic" Foreground="#757575" Margin="0,0,0,3"
                                           Visibility="{Binding ReferenceText, Converter={StaticResource NullOrEmptyToVisibilityConverter}}"/>
                                <TextBox Text="{Binding ResolvedValue, UpdateSourceTrigger=PropertyChanged, Mode=TwoWay}"
                                         Style="{StaticResource IdeMonoInputStyle}"
                                         IsReadOnly="{Binding CanEdit, Converter={StaticResource InverseBoolConverter}}"
                                         AcceptsReturn="True" TextWrapping="Wrap"
                                         MinHeight="24"
                                         LostFocus="ResolvedValue_LostFocus"
                                         Tag="{Binding}"/>
                            </StackPanel>
                        </Border>
                    </DataTemplate>
                </ListBox.ItemTemplate>
            </ListBox>
        </DockPanel>
    </Grid>
</UserControl>
