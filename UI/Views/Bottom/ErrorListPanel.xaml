<UserControl x:Class="UI.Views.Bottom.ErrorListPanel"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:md="http://materialdesigninxaml.net/winfx/xaml/themes"
             xmlns:bottom="clr-namespace:UI.ViewModels.Bottom">

    <DockPanel Background="{StaticResource EditorBgBrush}">
        <Border DockPanel.Dock="Top" Background="{StaticResource CodePaneHeaderBrush}"
                Padding="8,3" BorderBrush="{StaticResource IdeBorderBrush}" BorderThickness="0,0,0,1">
            <DockPanel>
                <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                    <TextBlock Text="ERROR LIST" FontSize="11" FontWeight="SemiBold"
                               Foreground="{StaticResource FgMutedBrush}"/>
                    <TextBlock Text="{Binding Errors.Count, StringFormat=' ({0})'}"
                               FontSize="11" Foreground="#C50F1F" Margin="4,0,0,0"/>
                </StackPanel>
                <Button DockPanel.Dock="Right" Content="Clear" FontSize="10" Padding="8,2"
                        Command="{Binding ClearErrorsCommand}"
                        Style="{StaticResource IdeRibbonButtonStyle}"
                        HorizontalAlignment="Right"/>
            </DockPanel>
        </Border>

        <ListBox ItemsSource="{Binding Errors}"
                 BorderThickness="0" Background="Transparent" FontSize="11">
            <ListBox.ItemTemplate>
                <DataTemplate DataType="{x:Type bottom:ErrorItemVm}">
                    <StackPanel Orientation="Horizontal" Margin="2,2">
                        <md:PackIcon Kind="AlertCircleOutline" Width="14" Height="14"
                                     Foreground="#C50F1F" VerticalAlignment="Center" Margin="0,0,6,0"/>
                        <TextBlock Text="{Binding Display}" TextWrapping="Wrap"
                                   Foreground="{StaticResource FgBrush}"/>
                    </StackPanel>
                </DataTemplate>
            </ListBox.ItemTemplate>
        </ListBox>
    </DockPanel>
</UserControl>
