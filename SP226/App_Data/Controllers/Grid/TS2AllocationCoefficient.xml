<?xml version="1.0" encoding="utf-8"?>

<!DOCTYPE grid [
  <!ENTITY FilterCheckAccessUnit "(@@admin = 1 or exists(select 1 from sysunitrights r where r.user_id = @@userID and r.ma_dvcs = @@table.ma_dvcs and r.r_access=1))">

  <!ENTITY StandardListScript SYSTEM "..\Include\Javascript\StandardListScript.txt">
  <!ENTITY StandardCssImport SYSTEM "..\Include\XML\StandardCssImport.txt">
  <!ENTITY DowloadScript SYSTEM "..\Include\Javascript\DownloadScript.txt">

  <!ENTITY TransferID "TS2AllocationCoefficient">
  <!ENTITY FastBusiness.Encryption.Begin "">
  <!ENTITY CreateTicket "declare @ticket varchar(32), @filename varchar(128), @description nvarchar(128)
select @ticket = lower(replace(newid(),'-',''))
if @@language = 'v' select @filename = 'TS2AllocationCoefficient.xlsx', @description = N'Khai báo hệ số phân bổ CCDC'
else select @filename = 'TS2AllocationCoefficient2.xlsx', @description = N'Tool &amp; Supply Allocation Coefficient Definition'
insert into @@sysDatabaseName..ticket values(@ticket, @@userID, '&TransferID;', @filename, @description, '@@appDatabaseName', getdate());">
  <!ENTITY FastBusiness.Encryption.End "">

  <!ENTITY % Control.Filter SYSTEM "..\Include\Filter.ent">
  %Control.Filter;
]>

<grid table="vcthspbdc" code="ma_dc, ngay_hl_tu, ngay_hl_den, ma_bp_dc, ma_kh, tk_pb, tk_cp, ma_vv, ma_sp, ma_bp, so_lsx, ma_hd" filter="&FilterCheckAccessUnit;" order="ma_dc, ngay_hl_tu" xmlns="urn:schemas-fast-com:data-grid">
  <title v="Khai báo hệ số phân bổ CCDC" e="Tool &#38; Supply Allocation Coefficient Definition"></title>
  <subTitle v="Khai báo hệ số phân bổ CCDC: mới, sửa, xóa..." e="Add New, Edit, Delete Tool &#38; Supply Allocation Coefficient Definition..."></subTitle>

  <fields>
    <field name="ma_dc" isPrimaryKey="true" width="100" allowSorting="true" allowFilter="true">
      <header v="Mã công cụ" e="Tool &#38; Supply"></header>
    </field>
    <field name="ten_dc%l" width="300" allowSorting="true" allowFilter="true">
      <header v="Tên công cụ" e="Description"></header>
    </field>
    <field name="ngay_hl_tu" isPrimaryKey="true" type="DateTime" dataFormatString="@datetimeFormat" width="100" allowSorting="true" allowFilter="true">
      <header v="Ngày hiệu lực từ" e="Effective Date from"></header>
    </field>
    <field name="ngay_hl_den" isPrimaryKey="true" type="DateTime" dataFormatString="@datetimeFormat" width="100" allowSorting="true" allowFilter="true">
      <header v="Đến" e="To"></header>
    </field>
    <field name="he_so" type="Decimal" width="100" dataFormatString="### ### ### ###.000" align ="right" allowSorting="true" allowFilter="true">
      <header v="Hệ số" e="Coefficient"></header>
      <items style="Numeric"></items>
    </field>
    <field name="ma_bp_dc" isPrimaryKey="true" width="100" allowSorting="true" allowFilter="true">
      <header v="Bộ phận sử dụng" e="Using Department"></header>
    </field>

    <field name="tk_pb" isPrimaryKey="true" width="100" allowSorting="true" allowFilter="true">
      <header v="Tk chờ phân bổ" e="Allocation Acct."></header>
    </field>
    <field name="tk_cp" isPrimaryKey="true" width="100" allowSorting="true" allowFilter="true">
      <header v="Tk chi phí" e="Expense Acct."></header>
    </field>
    <field name="ma_kh" isPrimaryKey="true" width="100" allowFilter="true" allowSorting="true">
      <header v="Mã khách hàng" e="Customer ID"></header>
    </field>
    <field name="ten_kh%l" width="300" allowFilter="true" allowSorting="true">
      <header v="Tên khách hàng" e="Customer Name"></header>
    </field>
    <field name="ma_vv" isPrimaryKey="true" width="100" allowSorting="true" allowFilter="true">
      <header v="Mã vụ việc" e="Job"></header>
    </field>
    <field name="ma_sp" isPrimaryKey="true" width="100" allowSorting="true" allowFilter="true">
      <header v="Mã sản phẩm" e="Product"></header>
    </field>
    <field name="ma_bp" isPrimaryKey="true" width="100" allowSorting="true" allowFilter="true">
      <header v="Bộ phận" e="Department"></header>
    </field>
    <field name="so_lsx" isPrimaryKey="true" width="100" allowSorting="true" allowFilter="true">
      <header v="Số lsx" e="MO Number"></header>
    </field>
    <field name="ma_hd" isPrimaryKey="true" width="100" allowSorting="true" allowFilter="true">
      <header v="Mã hợp đồng" e="Contract"></header>
    </field>
  </fields>

  <views>
    <view id="Grid">
      <field name="ma_dc"/>
      <field name="ten_dc%l"/>
      <field name="ngay_hl_tu"/>
      <field name="ngay_hl_den"/>
      <field name="he_so"/>

      <field name="ma_bp_dc"/>
      <field name="tk_pb"/>
      <field name="tk_cp"/>
      <field name="ma_kh"/>
      <field name="ten_kh%l"/>
      <field name="ma_vv"/>
      <field name="ma_sp"/>
      <field name="ma_bp"/>
      <field name="so_lsx"/>
      <field name="ma_hd"/>
    </view>
  </views>

  <commands>
    <command event="Loading">
      <text>
        &CreateTicket;
        <![CDATA[
declare @message nvarchar(4000)
select @message = ''
if @@admin <> 1 begin
  if not exists(select 1 from sysunitrights where user_id = @@userID and ma_dvcs = @@unit and r_new = 1) begin
    select @message = @message + 'this._denyNew = true; this._deny$Unit = true;'
  end
end
select @message = @message + 'this._authorize = ' + rtrim(@@sysDatabaseName.dbo.FastBusiness$System$GetAuthorize(@@admin, @@userID, ']]>&TransferID;<![CDATA[', 'New')) + ';this._key = ''' + @ticket + ''';load$Grid$]]>&TransferID;<![CDATA[(this);'
select @message as message
return
]]>
      </text>
    </command>

    <command event="Closing">
      <text>
        <![CDATA[
select 'dispose$Grid$]]>&TransferID;<![CDATA[(this);' as message
return
]]>
      </text>
    </command>
  </commands>

  <script>
    <text>
      <![CDATA[
function load$Grid$]]>&TransferID;<![CDATA[(g) {
  g.add_onResponseComplete(on$Grid$]]>&TransferID;<![CDATA[$ResponseComplete);
  g.add_commandEvent(on$Grid$]]>&TransferID;<![CDATA[$ExecuteCommand);
}
function dispose$Grid$]]>&TransferID;<![CDATA[(g) {
  try {g.remove_commandEvent(on$Grid$]]>&TransferID;<![CDATA[$ExecuteCommand);} catch (ex) {}
  try {g.remove_onResponseComplete(on$Grid$]]>&TransferID;<![CDATA[$ResponseComplete);} catch (ex) {}
}
function on$Grid$]]>&TransferID;<![CDATA[$ExecuteCommand(sender, e) {
  var action = e.type.Action, g = sender;
  switch (action) {
    case 'ImportData':
      show$Form(g, ']]>&TransferID;<![CDATA[Import');
      break;
    case 'Download':
      request$Download(g, action);
      break;
    default:
      break;
  }
}
function on$Grid$]]>&TransferID;<![CDATA[$ResponseComplete(sender, e) {
  var g = e.object, context = e.type.Context, result = e.type.Result, o = e.type.Object;
  switch (context) {
    case 'Download':
      g._key = result[0].Value;
      break;
    default:
      break;
  }
}
function show$Form(g, c) {(g._authorize == 1) && (!g._denyNew) ? g.showForm(c) : $message.show($df.getResources(g._language, "Message.NotAccess"));}
]]>
      &DowloadScript;
    </text>
  </script>

  <response>
    <action id="Download">
      <text>
        &CreateTicket;<![CDATA[
select @ticket as value
return
]]>
      </text>
    </action>
  </response>

  <css>
    <text>
      &StandardCssImport;
    </text>
  </css>

  <toolbar>
    <button command="New">
      <title v="Toolbar.New" e="Toolbar.New"></title>
    </button>
    <button command="Edit">
      <title v="Toolbar.Edit" e="Toolbar.Edit"></title>
    </button>
    <button command="Delete">
      <title v="Toolbar.Delete" e="Toolbar.Delete"></title>
    </button>
    <button command="Search">
      <title v="Toolbar.Search" e="Toolbar.Search"></title>
    </button>
    <button command="View">
      <title v="Toolbar.View" e="Toolbar.View"></title>
    </button>
    <button command="Export">
      <title v="Toolbar.Export" e="Toolbar.Export"/>
    </button>
    <button command="-">
      <title v="-" e="-"/>
    </button>

    <button command="ImportData">
      <title v="Lấy dữ liệu từ tệp..." e="Import Data from File..."></title>
    </button>
    <button command="Download">
      <title v="Tải tệp mẫu..." e="Download Template File..."/>
    </button>

    <button command="Separate">
      <title v="-" e="-"/>
    </button>
    <button command="Freeze">
      <title v="Toolbar.Freeze" e="Toolbar.Freeze"></title>
    </button>
  </toolbar>
</grid>