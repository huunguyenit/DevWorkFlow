<UserControl x:Class="UI.Views.Shell.IdeRibbon"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:md="http://materialdesigninxaml.net/winfx/xaml/themes"
             xmlns:cmd="clr-namespace:UI.Commands">
    <Border Background="{StaticResource IdeRibbonBgBrush}"
            BorderBrush="{StaticResource IdeBorderBrush}"
            BorderThickness="0,0,0,1"
            Padding="6,4">
        <StackPanel Orientation="Horizontal">
            <!-- File -->
            <Button Style="{StaticResource IdeRibbonButtonStyle}" Command="{x:Static cmd:IdeCommands.New}" ToolTip="New">
                <StackPanel>
                    <md:PackIcon Kind="FilePlusOutline" Width="18" Height="18" HorizontalAlignment="Center"/>
                    <TextBlock Text="New" HorizontalAlignment="Center" Margin="0,2,0,0"/>
                </StackPanel>
            </Button>
            <Button Style="{StaticResource IdeRibbonButtonStyle}" Command="{x:Static cmd:IdeCommands.Open}" ToolTip="Open">
                <StackPanel>
                    <md:PackIcon Kind="FolderOpenOutline" Width="18" Height="18" HorizontalAlignment="Center"/>
                    <TextBlock Text="Open" HorizontalAlignment="Center" Margin="0,2,0,0"/>
                </StackPanel>
            </Button>
            <Button Style="{StaticResource IdeRibbonButtonStyle}" Command="{x:Static cmd:IdeCommands.Save}" ToolTip="Save (Ctrl+S)">
                <StackPanel>
                    <md:PackIcon Kind="ContentSaveOutline" Width="18" Height="18" HorizontalAlignment="Center"/>
                    <TextBlock Text="Save" HorizontalAlignment="Center" Margin="0,2,0,0"/>
                </StackPanel>
            </Button>

            <Rectangle Width="1" Fill="{StaticResource IdeBorderBrush}" Margin="6,2"/>

            <!-- Edit -->
            <Button Style="{StaticResource IdeRibbonButtonStyle}" Command="{x:Static cmd:IdeCommands.Undo}" ToolTip="Undo">
                <StackPanel>
                    <md:PackIcon Kind="Undo" Width="18" Height="18" HorizontalAlignment="Center"/>
                    <TextBlock Text="Undo" HorizontalAlignment="Center" Margin="0,2,0,0"/>
                </StackPanel>
            </Button>
            <Button Style="{StaticResource IdeRibbonButtonStyle}" Command="{x:Static cmd:IdeCommands.Redo}" ToolTip="Redo">
                <StackPanel>
                    <md:PackIcon Kind="Redo" Width="18" Height="18" HorizontalAlignment="Center"/>
                    <TextBlock Text="Redo" HorizontalAlignment="Center" Margin="0,2,0,0"/>
                </StackPanel>
            </Button>

            <Rectangle Width="1" Fill="{StaticResource IdeBorderBrush}" Margin="6,2"/>

            <Button Style="{StaticResource IdeRibbonButtonStyle}" Command="{x:Static cmd:IdeCommands.Cut}" ToolTip="Cut">
                <StackPanel>
                    <md:PackIcon Kind="ContentCut" Width="18" Height="18" HorizontalAlignment="Center"/>
                    <TextBlock Text="Cut" HorizontalAlignment="Center" Margin="0,2,0,0"/>
                </StackPanel>
            </Button>
            <Button Style="{StaticResource IdeRibbonButtonStyle}" Command="{x:Static cmd:IdeCommands.Copy}" ToolTip="Copy">
                <StackPanel>
                    <md:PackIcon Kind="ContentCopy" Width="18" Height="18" HorizontalAlignment="Center"/>
                    <TextBlock Text="Copy" HorizontalAlignment="Center" Margin="0,2,0,0"/>
                </StackPanel>
            </Button>
            <Button Style="{StaticResource IdeRibbonButtonStyle}" Command="{x:Static cmd:IdeCommands.Paste}" ToolTip="Paste">
                <StackPanel>
                    <md:PackIcon Kind="ContentPaste" Width="18" Height="18" HorizontalAlignment="Center"/>
                    <TextBlock Text="Paste" HorizontalAlignment="Center" Margin="0,2,0,0"/>
                </StackPanel>
            </Button>

            <Rectangle Width="1" Fill="{StaticResource IdeBorderBrush}" Margin="6,2"/>

            <Button Style="{StaticResource IdeRibbonButtonStyle}" Command="{x:Static cmd:IdeCommands.Add}" ToolTip="Add">
                <StackPanel>
                    <md:PackIcon Kind="Plus" Width="18" Height="18" HorizontalAlignment="Center"/>
                    <TextBlock Text="Add" HorizontalAlignment="Center" Margin="0,2,0,0"/>
                </StackPanel>
            </Button>
            <Button Style="{StaticResource IdeRibbonButtonStyle}" Command="{x:Static cmd:IdeCommands.Delete}" ToolTip="Delete">
                <StackPanel>
                    <md:PackIcon Kind="DeleteOutline" Width="18" Height="18" HorizontalAlignment="Center"/>
                    <TextBlock Text="Delete" HorizontalAlignment="Center" Margin="0,2,0,0"/>
                </StackPanel>
            </Button>
            <Button Style="{StaticResource IdeRibbonButtonStyle}" Command="{x:Static cmd:IdeCommands.ValidateXml}" ToolTip="Validate XML">
                <StackPanel>
                    <md:PackIcon Kind="CheckDecagramOutline" Width="18" Height="18" HorizontalAlignment="Center"/>
                    <TextBlock Text="Validate" HorizontalAlignment="Center" Margin="0,2,0,0"/>
                </StackPanel>
            </Button>

            <Rectangle Width="1" Fill="{StaticResource IdeBorderBrush}" Margin="6,2"/>

            <Button Style="{StaticResource IdeRibbonButtonStyle}" Command="{x:Static cmd:IdeCommands.Preview}" ToolTip="Preview">
                <StackPanel>
                    <md:PackIcon Kind="EyeOutline" Width="18" Height="18" HorizontalAlignment="Center"/>
                    <TextBlock Text="Preview" HorizontalAlignment="Center" Margin="0,2,0,0"/>
                </StackPanel>
            </Button>
            <Button Style="{StaticResource IdeRibbonButtonStyle}" Command="{x:Static cmd:IdeCommands.Entity}" ToolTip="Entity">
                <StackPanel>
                    <md:PackIcon Kind="FileCodeOutline" Width="18" Height="18" HorizontalAlignment="Center"/>
                    <TextBlock Text="Entity" HorizontalAlignment="Center" Margin="0,2,0,0"/>
                </StackPanel>
            </Button>
            <Button Style="{StaticResource IdeRibbonButtonStyle}" Command="{x:Static cmd:IdeCommands.Parse}" ToolTip="Parse">
                <StackPanel>
                    <md:PackIcon Kind="CodeTags" Width="18" Height="18" HorizontalAlignment="Center"/>
                    <TextBlock Text="Parse" HorizontalAlignment="Center" Margin="0,2,0,0"/>
                </StackPanel>
            </Button>
            <Button Style="{StaticResource IdeRibbonButtonStyle}" Command="{x:Static cmd:IdeCommands.ClearText}"
                    ToolTip="Source Mode / Insight Mode">
                <StackPanel>
                    <md:PackIcon Kind="LightbulbOnOutline" Width="18" Height="18" HorizontalAlignment="Center"/>
                    <TextBlock Text="Insight" HorizontalAlignment="Center" Margin="0,2,0,0"/>
                </StackPanel>
            </Button>

            <Rectangle Width="1" Fill="{StaticResource IdeBorderBrush}" Margin="6,2"/>

            <Button Style="{StaticResource IdeRibbonButtonStyle}" Command="{x:Static cmd:IdeCommands.ExecuteSql}"
                    ToolTip="Execute SQL (F5) — bôi đen để chạy vùng; Target = combobox Sys/App trên SQL Studio">
                <StackPanel>
                    <md:PackIcon Kind="Play" Width="18" Height="18" HorizontalAlignment="Center"/>
                    <TextBlock Text="Execute" HorizontalAlignment="Center" Margin="0,2,0,0"/>
                </StackPanel>
            </Button>
            <Button Style="{StaticResource IdeRibbonButtonStyle}" Command="{x:Static cmd:IdeCommands.OpenSqlFromForm}"
                    ToolTip="Mở SQL Studio từ command/query trong form XML hiện tại">
                <StackPanel>
                    <md:PackIcon Kind="Database" Width="18" Height="18" HorizontalAlignment="Center"/>
                    <TextBlock Text="SQL" HorizontalAlignment="Center" Margin="0,2,0,0"/>
                </StackPanel>
            </Button>
            <Button Style="{StaticResource IdeRibbonButtonStyle}" Command="{x:Static cmd:IdeCommands.OpenSqlFile}"
                    ToolTip="Open .sql file">
                <StackPanel>
                    <md:PackIcon Kind="FileDocumentOutline" Width="18" Height="18" HorizontalAlignment="Center"/>
                    <TextBlock Text="Open SQL" HorizontalAlignment="Center" Margin="0,2,0,0"/>
                </StackPanel>
            </Button>

            <Rectangle Width="1" Fill="{StaticResource IdeBorderBrush}" Margin="6,2"/>

            <Button Style="{StaticResource IdeRibbonButtonStyle}" Command="{x:Static cmd:IdeCommands.Search}" ToolTip="Search">
                <StackPanel>
                    <md:PackIcon Kind="Magnify" Width="18" Height="18" HorizontalAlignment="Center"/>
                    <TextBlock Text="Find" HorizontalAlignment="Center" Margin="0,2,0,0"/>
                </StackPanel>
            </Button>
            <Button Style="{StaticResource IdeRibbonButtonStyle}" Command="{x:Static cmd:IdeCommands.Replace}" ToolTip="Replace">
                <StackPanel>
                    <md:PackIcon Kind="FindReplace" Width="18" Height="18" HorizontalAlignment="Center"/>
                    <TextBlock Text="Replace" HorizontalAlignment="Center" Margin="0,2,0,0"/>
                </StackPanel>
            </Button>
            <Button Style="{StaticResource IdeRibbonButtonStyle}" Command="{x:Static cmd:IdeCommands.GoToDefinition}" ToolTip="Go To Definition (F12)">
                <StackPanel>
                    <md:PackIcon Kind="ArrowRightBoldBoxOutline" Width="18" Height="18" HorizontalAlignment="Center"/>
                    <TextBlock Text="Go To Def" HorizontalAlignment="Center" Margin="0,2,0,0"/>
                </StackPanel>
            </Button>
            <Button Style="{StaticResource IdeRibbonButtonStyle}" Command="{x:Static cmd:IdeCommands.FindReferences}" ToolTip="Find References (Shift+F12)">
                <StackPanel>
                    <md:PackIcon Kind="LinkVariant" Width="18" Height="18" HorizontalAlignment="Center"/>
                    <TextBlock Text="Find Ref" HorizontalAlignment="Center" Margin="0,2,0,0"/>
                </StackPanel>
            </Button>
            <Button Style="{StaticResource IdeRibbonButtonStyle}" Command="{x:Static cmd:IdeCommands.Settings}" ToolTip="Settings">
                <StackPanel>
                    <md:PackIcon Kind="CogOutline" Width="18" Height="18" HorizontalAlignment="Center"/>
                    <TextBlock Text="Settings" HorizontalAlignment="Center" Margin="0,2,0,0"/>
                </StackPanel>
            </Button>
        </StackPanel>
    </Border>
</UserControl>
