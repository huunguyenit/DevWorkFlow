<UserControl x:Class="UI.Views.Toolbox.ToolboxPanel"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:md="http://materialdesigninxaml.net/winfx/xaml/themes"
             xmlns:tb="clr-namespace:UI.ViewModels.Toolbox">

    <UserControl.Resources>
        <BooleanToVisibilityConverter x:Key="BoolToVis"/>
    </UserControl.Resources>

    <DockPanel Background="{StaticResource SidebarBgBrush}">
        <Border DockPanel.Dock="Top" Style="{StaticResource IdeDockHeaderStyle}">
            <TextBlock Text="TOOLBOX" FontSize="11" FontWeight="SemiBold"
                       Foreground="{StaticResource FgMutedBrush}"/>
        </Border>

        <Border DockPanel.Dock="Top" Padding="6,4" Background="#F8F8F8"
                BorderBrush="{StaticResource IdeBorderBrush}" BorderThickness="0,0,0,1">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="*"/>
                </Grid.ColumnDefinitions>
                <md:PackIcon Kind="Magnify" Width="12" Height="12" Foreground="#888"
                             VerticalAlignment="Center"/>
                <TextBox Grid.Column="1" Margin="6,0,0,0"
                         Text="{Binding SearchText, UpdateSourceTrigger=PropertyChanged}"
                         BorderThickness="1" BorderBrush="#CCCEDB" Padding="4,2"
                         FontSize="11" Background="White"/>
            </Grid>
        </Border>

        <TextBlock DockPanel.Dock="Bottom" Text="{Binding Hint}"
                   FontSize="10" Foreground="{StaticResource FgMutedBrush}"
                   Margin="8,4" TextWrapping="Wrap"/>

        <ScrollViewer VerticalScrollBarVisibility="Auto">
            <ItemsControl ItemsSource="{Binding FilteredItems}">
                <ItemsControl.GroupStyle>
                    <GroupStyle>
                        <GroupStyle.HeaderTemplate>
                            <DataTemplate>
                                <Border Background="#EEEEF2" Padding="8,4" Margin="0,6,0,2">
                                    <TextBlock Text="{Binding Name}" FontSize="10" FontWeight="SemiBold"
                                               Foreground="{StaticResource FgMutedBrush}"/>
                                </Border>
                            </DataTemplate>
                        </GroupStyle.HeaderTemplate>
                    </GroupStyle>
                </ItemsControl.GroupStyle>
                <ItemsControl.ItemTemplate>
                    <DataTemplate DataType="{x:Type tb:ToolboxItemVm}">
                        <Border Padding="8,5" Margin="2,0" Cursor="Hand"
                                Background="Transparent" ToolTip="{Binding Description}"
                                Opacity="0.75">
                            <StackPanel Orientation="Horizontal">
                                <md:PackIcon Kind="{Binding IconKind}" Width="14" Height="14"
                                             Foreground="{StaticResource PrimaryBrush}"
                                             VerticalAlignment="Center" Margin="0,0,8,0"/>
                                <TextBlock Text="{Binding Name}" FontSize="12"
                                           Foreground="{StaticResource FgBrush}"
                                           VerticalAlignment="Center"/>
                            </StackPanel>
                        </Border>
                    </DataTemplate>
                </ItemsControl.ItemTemplate>
            </ItemsControl>
        </ScrollViewer>
    </DockPanel>
</UserControl>
