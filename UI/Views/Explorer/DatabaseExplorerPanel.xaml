<UserControl x:Class="UI.Views.Explorer.DatabaseExplorerPanel"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:md="http://materialdesigninxaml.net/winfx/xaml/themes"
             xmlns:tree="clr-namespace:UI.Tree">

    <DockPanel Background="{StaticResource SidebarBgBrush}">
        <Border DockPanel.Dock="Top" Style="{StaticResource IdeDockHeaderStyle}">
            <DockPanel>
                <TextBlock Text="DATABASE" Style="{StaticResource IdeDockHeaderTitleStyle}"/>
                <Button DockPanel.Dock="Right"
                        Style="{StaticResource IdeDockHeaderIconButtonStyle}"
                        Command="{Binding RefreshCommand}"
                        ToolTip="Refresh objects">
                    <md:PackIcon Kind="Refresh" Style="{StaticResource IdeDockHeaderPackIconStyle}"/>
                </Button>
            </DockPanel>
        </Border>

        <DockPanel DockPanel.Dock="Top">
            <TextBlock DockPanel.Dock="Top" Text="Target" Style="{StaticResource IdeSidebarFieldLabelStyle}"/>
            <Border Margin="8,0,8,8"
                    HorizontalAlignment="Stretch"
                    Background="Transparent">
                <ComboBox Style="{StaticResource IdeComboBoxStyle}"
                          HorizontalAlignment="Stretch"
                          ItemsSource="{Binding ConnectionTargets}"
                          SelectedItem="{Binding SelectedTarget, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                          ToolTip="Sys hoặc App DB (1 sys có thể nhiều app)">
                    <ComboBox.ItemTemplate>
                        <DataTemplate>
                            <TextBlock Text="{Binding Display}"
                                       TextTrimming="CharacterEllipsis"
                                       TextWrapping="NoWrap"
                                       VerticalAlignment="Center"/>
                        </DataTemplate>
                    </ComboBox.ItemTemplate>
                </ComboBox>
            </Border>
        </DockPanel>

        <tree:TreeControl x:Name="Tree"
                          Engine="{Binding TreeRendering}"
                          FilterText="{Binding FilterText, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                          StatusText="{Binding StatusText}"
                          ShowFilter="True"
                          NodeActivated="Tree_NodeActivated"/>
    </DockPanel>
</UserControl>
