<ResourceDictionary
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">

    <!--
      UI/Themes/Controls/Dock.xaml
      Header / tab / title dock trái-phải-dưới — đồng nhất Explorer & Outline.
    -->

    <Style x:Key="IdeDockHeaderStyle" TargetType="Border">
        <Setter Property="Background" Value="{StaticResource IdeDockHeaderBgBrush}"/>
        <Setter Property="BorderBrush" Value="{StaticResource IdeBorderBrush}"/>
        <Setter Property="BorderThickness" Value="0,0,0,1"/>
        <Setter Property="Padding" Value="8,3"/>
        <Setter Property="MinHeight" Value="32"/>
        <Setter Property="SnapsToDevicePixels" Value="True"/>
        <Setter Property="UseLayoutRounding" Value="True"/>
    </Style>

    <!-- Tiêu đề panel (EXPLORER / MENU / DATABASE / Outline header) -->
    <Style x:Key="IdeDockHeaderTitleStyle" TargetType="TextBlock">
        <Setter Property="FontSize" Value="12"/>
        <Setter Property="FontWeight" Value="SemiBold"/>
        <Setter Property="Foreground" Value="{StaticResource FgMutedBrush}"/>
        <Setter Property="VerticalAlignment" Value="Center"/>
        <Setter Property="TextTrimming" Value="CharacterEllipsis"/>
        <Setter Property="TextOptions.TextFormattingMode" Value="Display"/>
        <Setter Property="TextOptions.TextRenderingMode" Value="ClearType"/>
    </Style>

    <!-- Dòng phụ dưới header (tên Program) -->
    <Style x:Key="IdeDockSubTitleStyle" TargetType="TextBlock">
        <Setter Property="FontSize" Value="13"/>
        <Setter Property="FontWeight" Value="SemiBold"/>
        <Setter Property="Foreground" Value="{StaticResource FgBrightBrush}"/>
        <Setter Property="Margin" Value="10,8,10,2"/>
        <Setter Property="TextTrimming" Value="CharacterEllipsis"/>
        <Setter Property="TextOptions.TextFormattingMode" Value="Display"/>
    </Style>

    <!-- Dock / explorer tab — active = border bao nút (không gạch dưới) -->
    <Style x:Key="IdeDockTabButtonStyle" TargetType="Button">
        <Setter Property="Background" Value="Transparent"/>
        <Setter Property="Foreground" Value="{StaticResource FgMutedBrush}"/>
        <Setter Property="BorderBrush" Value="Transparent"/>
        <Setter Property="BorderThickness" Value="1"/>
        <Setter Property="Padding" Value="10,6"/>
        <Setter Property="Margin" Value="3,3"/>
        <Setter Property="FontSize" Value="12"/>
        <Setter Property="FontWeight" Value="Normal"/>
        <Setter Property="Cursor" Value="Hand"/>
        <Setter Property="SnapsToDevicePixels" Value="True"/>
        <Setter Property="UseLayoutRounding" Value="True"/>
        <Setter Property="TextOptions.TextFormattingMode" Value="Display"/>
        <Setter Property="TextOptions.TextRenderingMode" Value="ClearType"/>
        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="Button">
                    <Border x:Name="bd"
                            Background="{TemplateBinding Background}"
                            BorderBrush="{TemplateBinding BorderBrush}"
                            BorderThickness="{TemplateBinding BorderThickness}"
                            CornerRadius="4"
                            Padding="{TemplateBinding Padding}"
                            SnapsToDevicePixels="True">
                        <Grid>
                            <Border x:Name="hoverOverlay"
                                    Background="#0A000000"
                                    CornerRadius="3"
                                    Opacity="0"/>
                            <ContentPresenter HorizontalAlignment="Center"
                                              VerticalAlignment="Center"
                                              RecognizesAccessKey="True"/>
                        </Grid>
                    </Border>
                    <ControlTemplate.Triggers>
                        <Trigger Property="IsMouseOver" Value="True">
                            <Setter TargetName="hoverOverlay" Property="Opacity" Value="1"/>
                            <Setter Property="Foreground" Value="{StaticResource FgBrush}"/>
                        </Trigger>
                        <Trigger Property="IsPressed" Value="True">
                            <Setter TargetName="hoverOverlay" Property="Background" Value="#140078D4"/>
                            <Setter TargetName="hoverOverlay" Property="Opacity" Value="1"/>
                        </Trigger>
                    </ControlTemplate.Triggers>
                </ControlTemplate>
            </Setter.Value>
        </Setter>
    </Style>

    <Style x:Key="IdeDockTabSeparatorStyle" TargetType="TextBlock">
        <Setter Property="Text" Value="|"/>
        <Setter Property="Foreground" Value="#B0B8C4"/>
        <Setter Property="FontSize" Value="12"/>
        <Setter Property="VerticalAlignment" Value="Center"/>
        <Setter Property="Margin" Value="2,0"/>
        <Setter Property="Opacity" Value="0.9"/>
        <Setter Property="IsHitTestVisible" Value="False"/>
    </Style>

    <!-- Auto-hide tab (unpinned panel) — cạnh trái/phải, chữ dọc -->
    <Style x:Key="IdeAutoHideTabSideStyle" TargetType="Button">
        <Setter Property="Background" Value="{StaticResource IdeDockHeaderBgBrush}"/>
        <Setter Property="Foreground" Value="{StaticResource FgMutedBrush}"/>
        <Setter Property="BorderBrush" Value="{StaticResource IdeBorderBrush}"/>
        <Setter Property="BorderThickness" Value="1"/>
        <Setter Property="Padding" Value="4,8"/>
        <Setter Property="Margin" Value="0,0,0,2"/>
        <Setter Property="MinWidth" Value="24"/>
        <Setter Property="MinHeight" Value="72"/>
        <Setter Property="Cursor" Value="Hand"/>
        <Setter Property="HorizontalContentAlignment" Value="Center"/>
        <Setter Property="VerticalContentAlignment" Value="Center"/>
        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="Button">
                    <Border x:Name="bd"
                            Background="{TemplateBinding Background}"
                            BorderBrush="{TemplateBinding BorderBrush}"
                            BorderThickness="{TemplateBinding BorderThickness}"
                            Padding="{TemplateBinding Padding}"
                            SnapsToDevicePixels="True">
                        <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                    </Border>
                    <ControlTemplate.Triggers>
                        <Trigger Property="IsMouseOver" Value="True">
                            <Setter TargetName="bd" Property="Background" Value="{StaticResource IdeHoverBrush}"/>
                            <Setter Property="Foreground" Value="{StaticResource FgBrush}"/>
                        </Trigger>
                        <Trigger Property="IsPressed" Value="True">
                            <Setter TargetName="bd" Property="Background" Value="{StaticResource IdePressBrush}"/>
                        </Trigger>
                    </ControlTemplate.Triggers>
                </ControlTemplate>
            </Setter.Value>
        </Setter>
    </Style>

    <Style x:Key="IdeAutoHideTabSideTextStyle" TargetType="TextBlock">
        <Setter Property="FontSize" Value="11"/>
        <Setter Property="FontWeight" Value="SemiBold"/>
        <Setter Property="Foreground" Value="{Binding Foreground, RelativeSource={RelativeSource AncestorType=Button}}"/>
        <Setter Property="TextTrimming" Value="CharacterEllipsis"/>
        <Setter Property="LayoutTransform">
            <Setter.Value>
                <RotateTransform Angle="-90"/>
            </Setter.Value>
        </Setter>
    </Style>

    <!-- Auto-hide tab — cạnh dưới -->
    <Style x:Key="IdeAutoHideTabBottomStyle" TargetType="Button" BasedOn="{StaticResource IdeDockTabButtonStyle}">
        <Setter Property="Margin" Value="2,0"/>
        <Setter Property="Padding" Value="12,4"/>
        <Setter Property="Background" Value="{StaticResource IdeDockHeaderBgBrush}"/>
        <Setter Property="BorderBrush" Value="{StaticResource IdeBorderBrush}"/>
        <Setter Property="BorderThickness" Value="1"/>
    </Style>

</ResourceDictionary>
