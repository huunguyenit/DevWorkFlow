return
]]>
      </text>
    </command>

    <command event="Updated">
      <text>
        <![CDATA[
if $duv.NewValue <> $duv.OldValue begin
	delete @duv where line_nbr = 0
	update @duv set ma_dot = @ma_dot, stt_rec0lich = @stt_rec0

	delete hrrmlichctuv where ma_dot = @ma_dot and stt_rec0lich = @stt_rec0
	insert into hrrmlichctuv (ma_dot, stt_rec0lich, ma_hs, ghi_chu, line_nbr, datetime0, datetime2, user_id0, user_id2)
		select ma_dot, stt_rec0lich, ma_hs, ghi_chu, line_nbr, getDate(), getDate(), @@userID, @@userID from @duv
end
]]>
      </text>
    </command>

    <command event="Deleting">
      <text>
        <![CDATA[
/*
]]>
      </text>
    </command>

    <command event="Deleted">
      <text>
        <![CDATA[
*/
