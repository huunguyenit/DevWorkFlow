<?xml version="1.0" encoding="UTF-8"?>

<configuration>
  <appSettings>
    <add key="networkKey" value="012345" />
    <add key="serialNumber" value="C76CB80ED542246233FBCC3F3" />

    <add key="sysDatabaseName" value="fsdTest_SP226_S" />

    <add key="confirmEscape" value="0"/>
    <add key="gridAutoAppearance" value="1"/>
    <add key="gridAutoExpansion" value="1" />
    <add key="gridRedundant" value="1"/>
    <add key="limitLoginAttempts" value="3" />
    <add key="limitConcurrentUsers" value="30" />
    <add key="xmlLargeSize" value="1024000" />
    <add key="commandTimeout" value="300" />
    <add key="processTimeout" value="1800" />
    <add key="reportTimeout" value="1800" />
    <!--<add key="defaultReportFont" value="Times New Roman" />-->
    <add key="denyCompressionMethods" value="GetHandleExternal, GetCompletionList, GetGridResponse, GetDirResponse" />
    <add key="languageType" value="1" />
    <add key="importMode" value="1" />

    <add key="fileLocation" value="E:\Web\FBO\Upload" />
    <add key="fileStream" value="0" />
    <add key="notify" value="1" />

    <add key="invokeTimeout" value="480000" />
    <add key="service" value="1" />
    <add key="dueTime" value="30000" />
    <add key="intervalTime" value="30000" />
	
    <add key="denySessionStorage" value="1" />
  </appSettings>

  <connectionStrings>
    <add name="appConnectionString" connectionString="Data Source=172.168.5.14\SQL2008;Initial Catalog=%Database;Application Name=%UserID;Uid=fsdTest;Pwd=fsd;" providerName="System.Data.SqlClient" />
    <add name="sysConnectionString" connectionString="Data Source=172.168.5.14\SQL2008;Initial Catalog=fsdTest_SP226_S;Uid=fsdTest;Pwd=fsd;" providerName="System.Data.SqlClient" />
  </connectionStrings>

  <system.web.extensions>
    <scripting>
      <webServices>
        <jsonSerialization maxJsonLength="50000000" />
      </webServices>
    </scripting>
  </system.web.extensions>
  <!--
    For a description of web.config changes see http://go.microsoft.com/fwlink/?LinkId=235367.

    The following attributes can be set on the <httpRuntime> tag.
      <system.Web>
        <httpRuntime targetFramework="4.5" />
      </system.Web>
  -->

  <system.web>
    <compilation debug="false" strict="false" explicit="true" targetFramework="4.5.2">
      <assemblies>
        <add assembly="DocumentFormat.OpenXml, Version=2.0.5022.0, Culture=Neutral, PublicKeyToken=31bf3856ad364e35" />
        <add assembly="System.Windows.Forms, Version=4.0.0.0, Culture=neutral, PublicKeyToken=B77A5C561934E089" />
        <add assembly="System.Design, Version=4.0.0.0, Culture=neutral, PublicKeyToken=B03F5F7F11D50A3A" />
        <add assembly="System.Speech, Version=4.0.0.0, Culture=neutral, PublicKeyToken=31BF3856AD364E35" />
      </assemblies>
    </compilation>
    <pages validateRequest="false" controlRenderingCompatibilityVersion="3.5" clientIDMode="AutoID">
      <namespaces>
        <clear />
        <add namespace="System" />
        <add namespace="System.Collections" />
        <add namespace="System.Collections.Generic" />
        <add namespace="System.Collections.Specialized" />
        <add namespace="System.Configuration" />
        <add namespace="System.Text" />
        <add namespace="System.Text.RegularExpressions" />
        <add namespace="System.Linq" />
        <add namespace="System.Xml.Linq" />
        <add namespace="System.Web" />
        <add namespace="System.Web.Caching" />
        <add namespace="System.Web.SessionState" />
        <add namespace="System.Web.Security" />
        <add namespace="System.Web.Profile" />
        <add namespace="System.Web.UI" />
        <add namespace="System.Web.UI.WebControls" />
        <add namespace="System.Web.UI.WebControls.WebParts" />
        <add namespace="System.Web.UI.HtmlControls" />
      </namespaces>
      <controls>
        <add tagPrefix="FastBusiness" namespace="FastBusiness.MenuExtender" assembly="FastBusiness.MenuExtender" />
        <add tagPrefix="FastBusiness" namespace="FastBusiness.ReportExtender" assembly="FastBusiness.ReportExtender" />
        <add tagPrefix="FastBusiness" namespace="FastBusiness.NotifyExtender" assembly="FastBusiness.NotifyExtender" />
      </controls>
    </pages>
    <authentication mode="Windows" />
    <customErrors mode="RemoteOnly" defaultRedirect="Error.htm">
      <error statusCode="403" redirect="Error.htm" />
      <error statusCode="404" redirect="Error.htm" />
    </customErrors>
    <httpRuntime requestValidationMode="2.0" maxRequestLength="10240" executionTimeout="3600" />
    <httpHandlers>
      <add verb="*" path="*.xml" type="System.Web.HttpForbiddenHandler" validate="true" />
    </httpHandlers>
    <httpModules>
      <add name="JsonCompressionModule" type="FastBusiness.ReportExtender.JsonCompressionModule" />
    </httpModules>
    <sessionState mode="InProc" cookieless="false" timeout="60" />
  </system.web>
  <system.webServer>
    <security>
      <requestFiltering>
        <requestLimits maxAllowedContentLength="10240000" />
      </requestFiltering>
      <authorization>
        <add accessType="Allow" users="?" />
      </authorization>
    </security>

    <validation validateIntegratedModeConfiguration="false" />
    <modules runAllManagedModulesForAllRequests="true">
      <add name="JsonCompressionModule" preCondition="managedHandler" type="FastBusiness.ReportExtender.JsonCompressionModule" />
    </modules>
    <defaultDocument>
      <files>
        <clear />
        <add value="default.aspx" />
        <add value="Default.htm" />
        <add value="Default.asp" />
        <add value="index.htm" />
        <add value="index.html" />
        <add value="iisstart.htm" />
      </files>
    </defaultDocument>
    <urlCompression doStaticCompression="true" doDynamicCompression="true" />
  </system.webServer>
  <location path="Controllers">
    <system.web />
  </location>

  <runtime>
    <assemblyBinding xmlns="urn:schemas-microsoft-com:asm.v1">
      <dependentAssembly>
        <assemblyIdentity name="Microsoft.Owin" publicKeyToken="31bf3856ad364e35" culture="neutral" />
        <bindingRedirect oldVersion="0.0.0.0-4.0.1.0" newVersion="4.0.1.0" />
      </dependentAssembly>
    </assemblyBinding>
  </runtime>
</configuration>