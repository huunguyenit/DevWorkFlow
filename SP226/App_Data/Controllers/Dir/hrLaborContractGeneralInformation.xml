  <commands>
    <command event="Loading">
      <text>
        <![CDATA[
declare @message nvarchar(4000), @unitName nvarchar(1023)
select @unitName = case when @@language = 'V' then ten_dvcs else ten_dvcs2 end from dmdvcs where ma_dvcs = @@unit
select @message = 'this._unitCode=''' + @@unit + ''';this._unitName=''' + replace(replace(isnull(@unitName, ''), '\', '\\'), '''', '\''') + ''';init$LaborContractGeneralInformation(this);'
select @message as message
return
]]>
      </text>
    </command>

    <command event="Declare">
      <text>
        <![CDATA[
declare @$exists nvarchar(512), @$recordHasBeenChanged nvarchar(512)
select @$exists = case when @@language = 'v' then N'<span class="Highlight">Thông tin chung hợp đồng đang cập nhật đã được khai báo</span>, không lưu được.' else N'<span class="Highlight">This item already exists</span>, it can not be saved.' end
select @$recordHasBeenChanged = case when @@language = 'v' then N'Bản ghi hiện thời đã được sửa hoặc xóa bởi người sử dụng khác.' else N'This item has been modified or deleted by another user.' end
]]>
      </text>
    </command>

    <command event="Inserting">
      <text>
        <![CDATA[
if exists(select * from @@table where ma_dvcs = @ma_dvcs) begin
	select 'ma_dvcs' as field, @$exists as message
  return
end
select @datetime0 = getdate(), @datetime2 = getdate(), @user_id0 = @@userID, @user_id2 = @@userID
]]>
      </text>
    </command>

    <command event="Updating">
      <text>
        <![CDATA[  
if not exists(select * from @@table where ma_dvcs = $ma_dvcs.OldValue) begin
  select 'ma_dvcs' as field, @$recordHasBeenChanged as message
  return
end

if (@ma_dvcs <> $ma_dvcs.OldValue)
  begin
    if exists(select * from @@table where (not (ma_dvcs = $ma_dvcs.OldValue)) and (ma_dvcs = @ma_dvcs)) begin
      select 'ma_dvcs' as field, @$exists as message
      return
    end
  end
]]>
      </text>
    </command>

    <command event="Updated">
      <text>
        <![CDATA[
update @@table set datetime2 = getdate(), user_id2 = @@userID where ma_dvcs = @ma_dvcs
]]>
      </text>
    </command>

  </commands>

  <script>
    <text>
      <![CDATA[
function init$LaborContractGeneralInformation(f) {
  if (f._action == 'New') {
    var o = f.getItem('ma_dvcs');
    o.value = f._unitCode;
    f.getItem('ten_dvcs%l').value = f._unitName;
  }  
}
]]>
    </text>
  </script>

