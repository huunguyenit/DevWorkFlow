<UserControl x:Class="UI.Views.Shell.DocumentTabBar"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:shell="clr-namespace:UI.ViewModels.Shell"
             xmlns:md="http://materialdesigninxaml.net/winfx/xaml/themes">
    <Border Background="{StaticResource IdeTabInactiveBgBrush}"
            BorderBrush="{StaticResource IdeBorderBrush}"
            BorderThickness="0,0,0,1"
            MinHeight="28">
        <ItemsControl ItemsSource="{Binding Documents}">
            <ItemsControl.ItemsPanel>
                <ItemsPanelTemplate>
                    <StackPanel Orientation="Horizontal"/>
                </ItemsPanelTemplate>
            </ItemsControl.ItemsPanel>
            <ItemsControl.ItemTemplate>
                <DataTemplate DataType="{x:Type shell:DocumentItemVm}">
                    <RadioButton Style="{StaticResource IdeDocumentTabStyle}"
                                 GroupName="IdeDocuments"
                                 IsChecked="{Binding IsActive, Mode=OneWay}"
                                 Command="{Binding DataContext.ActivateDocumentCommand, RelativeSource={RelativeSource AncestorType=UserControl}}"
                                 CommandParameter="{Binding}"
                                 ToolTip="{Binding FilePath}">
                        <StackPanel Orientation="Horizontal">
                            <md:PackIcon Kind="FileCodeOutline" Width="12" Height="12"
                                         VerticalAlignment="Center" Margin="0,0,6,0"
                                         Foreground="{StaticResource PrimaryBrush}"/>
                            <TextBlock Text="{Binding DisplayTitle}" VerticalAlignment="Center"/>
                            <Button Margin="8,0,0,0" Padding="2,0" Width="16" Height="16"
                                    Cursor="Hand" ToolTip="Close"
                                    Background="Transparent" BorderThickness="0"
                                    Foreground="{StaticResource FgMutedBrush}"
                                    FontSize="11" Content="✕"
                                    Command="{Binding DataContext.CloseDocumentCommand, RelativeSource={RelativeSource AncestorType=UserControl}}"
                                    CommandParameter="{Binding}"
                                    PreviewMouseLeftButtonDown="CloseButton_PreviewMouseLeftButtonDown"/>
                        </StackPanel>
                    </RadioButton>
                </DataTemplate>
            </ItemsControl.ItemTemplate>
        </ItemsControl>
    </Border>
</UserControl>
