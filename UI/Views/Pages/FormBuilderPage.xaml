<UserControl x:Class="UI.Views.Pages.FormBuilderPage"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:md="http://materialdesigninxaml.net/winfx/xaml/themes"
             xmlns:ctrl="clr-namespace:UI.Views.Controls"
             xmlns:design="clr-namespace:UI.Views.Design"
             xmlns:lang="clr-namespace:DevWorkFlow.Domain.Language;assembly=DevWorkFlow.Domain">

    <!--
        Source | Insight | Design. Design (ErpEditorMode.Designer) render HTML sinh từ XML→Semantic→Layout
        (DesignHtmlGenerator) trong WebView2 kèm 2 thước px — KHÔNG phụ thuộc skin capture. Data model
        DesignSurfaceVm/DesignCellVm vẫn giữ để phục vụ Property Grid + navigation (chọn field theo symbol)
        — xem docs/04-DESIGNER_PLATFORM.md.
    -->
    <UserControl.Resources>
        <BooleanToVisibilityConverter x:Key="BoolToVis"/>

        <Style x:Key="EditorModeTabStyle" TargetType="Button" BasedOn="{StaticResource IdeSegmentButtonStyle}">
            <Setter Property="MinWidth" Value="96"/>
        </Style>

        <Style x:Key="EditorModeTabActiveStyle" TargetType="Button" BasedOn="{StaticResource EditorModeTabStyle}">
            <Setter Property="Background" Value="{StaticResource IdeAccentSoftBrush}"/>
            <Setter Property="Foreground" Value="#1565C0"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
        </Style>
    </UserControl.Resources>

    <Grid Background="{StaticResource WorkspaceBgBrush}">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*" MinHeight="180"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <!-- Toolbar: trái = tiêu đề/path (co giãn + ellipsis); phải = Source|Insight|Design.
             Lưu qua IdeCommands.Save (Ctrl+S) ở MainWindow — không nút Lưu/Xoá trên toolbar. -->
        <Border Grid.Row="0"
                Background="{StaticResource CodePaneHeaderBrush}"
                BorderBrush="{StaticResource IdeBorderBrush}"
                BorderThickness="0,0,0,1"
                Padding="12,6">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*" MinWidth="80"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>

                <Grid Grid.Column="0" VerticalAlignment="Center">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="Auto"/>
                        <ColumnDefinition Width="Auto"/>
                        <ColumnDefinition Width="*" MinWidth="40"/>
                    </Grid.ColumnDefinitions>
                    <md:PackIcon Grid.Column="0" Kind="FileCodeOutline" Width="16" Height="16"
                                 Foreground="{StaticResource PrimaryBrush}"
                                 VerticalAlignment="Center"/>
                    <TextBlock Grid.Column="1"
                               Text="{Binding LoadedTitle, FallbackValue='Document'}"
                               FontSize="13" FontWeight="SemiBold"
                               Foreground="{StaticResource FgBrightBrush}"
                               VerticalAlignment="Center" Margin="8,0,8,0"
                               TextTrimming="CharacterEllipsis" MaxWidth="200"/>
                    <TextBlock Grid.Column="2"
                               Text="{Binding LoadedFilePath}"
                               FontSize="11" Foreground="{StaticResource FgMutedBrush}"
                               VerticalAlignment="Center" TextTrimming="CharacterEllipsis"
                               Visibility="{Binding LoadedFilePath, Converter={StaticResource NullOrEmptyToVisibilityConverter}}"/>
                </Grid>

                <Border Grid.Column="1" Background="White"
                        BorderBrush="{StaticResource IdeBorderBrush}"
                        BorderThickness="1" CornerRadius="4" Padding="2" Margin="12,0,0,0"
                        VerticalAlignment="Center">
                    <StackPanel Orientation="Horizontal">
                        <Button Command="{Binding SetEditorModeCommand}"
                                CommandParameter="{x:Static lang:ErpEditorMode.Source}"
                                ToolTip="Source — XML raw">
                            <Button.Style>
                                <Style TargetType="Button" BasedOn="{StaticResource EditorModeTabStyle}">
                                    <Style.Triggers>
                                        <DataTrigger Binding="{Binding IsSourceMode}" Value="True">
                                            <Setter Property="Background" Value="#ECEFF1"/>
                                            <Setter Property="Foreground" Value="#37474F"/>
                                            <Setter Property="FontWeight" Value="SemiBold"/>
                                        </DataTrigger>
                                    </Style.Triggers>
                                </Style>
                            </Button.Style>
                            <StackPanel Orientation="Horizontal">
                                <md:PackIcon Kind="CodeTags" Width="13" Height="13" VerticalAlignment="Center"/>
                                <TextBlock Text="Source" Margin="5,0,0,0"/>
                            </StackPanel>
                        </Button>
                        <Button Command="{Binding SetEditorModeCommand}"
                                CommandParameter="{x:Static lang:ErpEditorMode.Insight}"
                                ToolTip="Insight — Semantic + Entity">
                            <Button.Style>
                                <Style TargetType="Button" BasedOn="{StaticResource EditorModeTabStyle}">
                                    <Style.Triggers>
                                        <DataTrigger Binding="{Binding IsInsightMode}" Value="True">
                                            <Setter Property="Background" Value="{StaticResource IdeAccentSoftBrush}"/>
                                            <Setter Property="Foreground" Value="#1565C0"/>
                                            <Setter Property="FontWeight" Value="SemiBold"/>
                                        </DataTrigger>
                                    </Style.Triggers>
                                </Style>
                            </Button.Style>
                            <StackPanel Orientation="Horizontal">
                                <md:PackIcon Kind="LightbulbOnOutline" Width="13" Height="13" VerticalAlignment="Center"/>
                                <TextBlock Text="Insight" Margin="5,0,0,0"/>
                            </StackPanel>
                        </Button>
                        <Button Command="{Binding SetEditorModeCommand}"
                                CommandParameter="{x:Static lang:ErpEditorMode.Designer}"
                                ToolTip="Design — XML → HTML WebView"
                                Visibility="{Binding ShowDesignerTab, Converter={StaticResource BoolToVis}}">
                            <Button.Style>
                                <Style TargetType="Button" BasedOn="{StaticResource EditorModeTabStyle}">
                                    <Style.Triggers>
                                        <DataTrigger Binding="{Binding IsDesignerMode}" Value="True">
                                            <Setter Property="Background" Value="{StaticResource IdeAccentSoftBrush}"/>
                                            <Setter Property="Foreground" Value="#1565C0"/>
                                            <Setter Property="FontWeight" Value="SemiBold"/>
                                        </DataTrigger>
                                    </Style.Triggers>
                                </Style>
                            </Button.Style>
                            <StackPanel Orientation="Horizontal">
                                <md:PackIcon Kind="MonitorScreenshot" Width="13" Height="13" VerticalAlignment="Center"/>
                                <TextBlock Text="Design" Margin="5,0,0,0"/>
                            </StackPanel>
                        </Button>
                    </StackPanel>
                </Border>
            </Grid>
        </Border>

        <!-- Document center: Source / Insight / Design -->
        <Grid Grid.Row="1">
            <ctrl:InsightEditorSurface
                Visibility="{Binding ShowEditorSurface, Converter={StaticResource BoolToVis}}"/>
            <design:DesignWebViewHost
                Visibility="{Binding ShowDesignerModeSurface, Converter={StaticResource BoolToVis}}"/>
        </Grid>

        <Border Grid.Row="2" Background="{StaticResource CodePaneHeaderBrush}"
                BorderBrush="{StaticResource IdeBorderBrush}" BorderThickness="0,1,0,0"
                Padding="12,4">
            <TextBlock Text="{Binding StatusMessage}" FontSize="11"
                       Foreground="{StaticResource FgMutedBrush}" TextTrimming="CharacterEllipsis"/>
        </Border>

    </Grid>
</UserControl>
