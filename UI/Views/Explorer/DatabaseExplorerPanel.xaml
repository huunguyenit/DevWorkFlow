<UserControl x:Class="UI.Views.Explorer.DatabaseExplorerPanel"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:md="http://materialdesigninxaml.net/winfx/xaml/themes"
             xmlns:ex="clr-namespace:UI.Views.Explorer">

    <DockPanel Background="{StaticResource SidebarBgBrush}">
        <Border DockPanel.Dock="Top" Style="{StaticResource IdeDockHeaderStyle}">
            <DockPanel>
                <TextBlock Text="DATABASE" FontSize="11" FontWeight="SemiBold"
                           Foreground="{StaticResource FgMutedBrush}"
                           VerticalAlignment="Center"/>
                <Button DockPanel.Dock="Right" Style="{StaticResource IconButtonStyle}"
                        Width="24" Height="24" Command="{Binding RefreshCommand}"
                        ToolTip="Refresh objects" HorizontalAlignment="Right">
                    <md:PackIcon Kind="Refresh" Width="14" Height="14"/>
                </Button>
            </DockPanel>
        </Border>

        <StackPanel DockPanel.Dock="Top" Margin="8,6,8,4">
            <TextBlock Text="Target" FontSize="10" Foreground="{StaticResource FgMutedBrush}" Margin="0,0,0,2"/>
            <ComboBox ItemsSource="{Binding ConnectionTargets}"
                      SelectedItem="{Binding SelectedTarget}"
                      DisplayMemberPath="Display"
                      FontSize="11" Height="26"/>
        </StackPanel>

        <ex:ExplorerTreePanel NodeActivated="ExplorerTreePanel_NodeActivated"/>
    </DockPanel>
</UserControl>
