      </text>
    </command>
  </commands>
  <script>
    <text>
      <![CDATA[
function active$PeriodicTransaction(f) {
  f._controlFocus = f.getItem('so_ct');
  f.getItem('so_ct').focus();
  f.live(f.getItem('so_ct'));
}
function set$VoucherNumberArray(f, old) {
  var g = f.grid, r = g._activeRow, j = Array.indexOf(g._$r, r), v = g._getItemValue(r, g._$n);
  if (g._getItemValue(r, g._$t)) {
    if (j != -1) {
      Array.removeAt(g._$c, j);
      Array.removeAt(g._$r, j);
    }
    Array.add(g._$c, v]);
    Array.add(g._$r, r]);
  }
}
]]>
    </text>
  </script>
</dir>