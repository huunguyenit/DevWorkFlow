  <commands>
    <command event="Loading">
      <text>
        <![CDATA[
declare @message nvarchar(4000)
select @message = 'active$hrRMTestInterviewScheduleApplicant(this);'
]]>&CommandWhenBeforeEdit;<![CDATA[
select @message as message
return
]]>
      </text>
    </command>

    <command event="Closing">
      <text>
        <![CDATA[
select 'close$hrRMTestInterviewScheduleApplicant(this);' as message
return
]]>
      </text>
    </command>

    <command event="Scattering">
      <text>
        <![CDATA[
declare @message nvarchar(4000)
]]>&CommandWhenBeforeEdit;<![CDATA[
