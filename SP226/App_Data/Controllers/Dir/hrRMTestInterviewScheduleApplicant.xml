  </commands>

  <script>
    <text>
      <![CDATA[			
function active$hrRMTestInterviewScheduleApplicant(f) {
	f.add_commandEvent(on$hrRMTestInterviewScheduleApplicant$ExecuteCommand);
	f.setReadOnlyFields('ma_dot, ma_vong, ma_vtr, ngay_pv');
}
function close$hrRMTestInterviewScheduleApplicant(f) {try {f.remove_commandEvent(on$hrRMTestInterviewScheduleApplicant$ExecuteCommand);} catch (ex) {}}
function on$hrRMTestInterviewScheduleApplicant$ExecuteCommand(sender, e) {
  var action = e.type.Action, f = sender, g = f.getItem('duv')._controlBehavior;
  switch (action) {
    case 'Gather':
      var i = 1, l1 = g._getColumnOrder('tag'), l2 = g._getColumnOrder('line_nbr');
      for (var r = 1; r <= g._rowCount; r++) {
        if (g._getItemValue(r, l1)) {
          g._setItemValue(r, l2, i);
          i++;
        } else g._setItemValue(r, l2, 0);
			}
      break;
    default:
      break;
  }
}
]]>
    </text>
  </script>
