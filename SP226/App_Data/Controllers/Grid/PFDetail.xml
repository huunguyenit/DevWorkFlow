      <field name="ma_vi_tri"/>
      <field name="ten_vi_tri%l"/>
      <field name="ma_lo"/>
      <field name="ten_lo%l"/>
      <field name="so_luong"/>

      <field name="cp_vc_nt"/>
      <field name="cp_bh_nt"/>
      <field name="cp_khac_nt"/>
      <field name="cp_nt"/>

      <field name="tk_vt"/>
      <field name="ten_tk_vt%l"/>
      <field name="tien0"/>
      <field name="tien3"/>

      <field name="cp_vc"/>
      <field name="cp_bh"/>
      <field name="cp_khac"/>
      <field name="cp"/>

      <field name="hd_so"/>
      <field name="hd_ln"/>

      &XMLUserDefinedViews;

      <field name="stt_rec_hd"/>
      <field name="stt_rec0hd"/>
      <field name="stt_rec"/>
      <field name="stt_rec0"/>
      <field name="line_nbr"/>

      <field name="volume"/>
      <field name="weight"/>
    </view>
  </views>

  <commands>
    <command event="Showing">
      <text>
        <![CDATA[
declare @message nvarchar(4000)
select @message = ''
]]>
        &CommandControlLocationLotShowing;
        <![CDATA[
select @message as message
return
]]>
      </text>
    </command>

    <command event="Loading">
      <text>
        <![CDATA[select 'this._voucherCode='@@id';load$GridVoucherDetail$(this);' as message
return]]>
      </text>
    </command>

    <command event="Closing">
      <text>
        <![CDATA[select 'dispose$GridVoucherDetail$(this);' as message
return]]>
      </text>
    </command>
  </commands>

  <script>
    <text>
      <![CDATA[
/* <flatten type="Javascript"> */
function load$GridVoucherDetail$(g) {
  g.add_commandEvent(on$GridVoucherDetail$ExecuteCommand);
  g.$a = {
    cp_nt: '[cp_nt]:=[cp_vc_nt]+[cp_bh_nt]+[cp_khac_nt]',
    cp: '[cp]:=[cp_vc]+[cp_bh]+[cp_khac]'
  };
  udf$Detail$(g);
}
function dispose$GridVoucherDetail$(g) {
  g.$a = null;
  try {g.remove_commandEvent(on$GridVoucherDetail$ExecuteCommand);} catch (ex) {}
}
function on$GridVoucherDetail$ExecuteCommand(sender, e) {
  var action = e.type.Action, g = sender, f = g.get_element().parentForm;
  switch (action) {
    case 'Retrieve':
      if (f._action != 'View') g.showForm('PFReceiptFilter');
      break;
    default:
      break;
  }
}
/* </flatten> */
]]>
      &ScriptInsertRetrieveItems;
    </text>
  </script>

  <queries>
    <query event="Loading">
      <text>
        <![CDATA[
select @@fieldExternal from @@prime$partition$current a left join dmvt b on a.ma_vt = b.ma_vt where @@whereClause order by @@orderByClause
]]>
      </text>
    </query>

    <query event="Finding">
      <text>
        <![CDATA[
declare @s nvarchar(4000)
select a.*, b.volume, b.weight into #r from @@prime$partition$current a left join dmvt b on a.ma_vt = b.ma_vt where 1 = 0
select @s = 'insert into #r (ma_vt, dvt, he_so, ma_kho, ma_vi_tri, ma_lo, so_luong, tien0, tien3, cp, tk_vt, stt_rec_hd, stt_rec0hd, hd_so, hd_ln, stt_rec, stt_rec0, line_nbr, volume, weight, '
select @s = @s + char(13) + 'ma_vv, ma_sp, ma_bp, ma_hd, ma_ku, so_lsx, ma_phi, ma_ct, so_ct, ngay_ct)'
select @s = @s + char(13) + 'select rtrim(a.ma_vt), rtrim(a.dvt), he_so, rtrim(a.ma_kho), rtrim(a.ma_vi_tri), rtrim(a.ma_lo), a.so_luong, a.tien0, a.tien, 0, rtrim(a.tk_vt), a.stt_rec, a.stt_rec0, a.so_ct, a.line_nbr, ''' + replace(@stt_rec, '''', '') + ''', a.stt_rec0, a.line_nbr, b.volume, b.weight, '
select @s = @s + char(13) + 'rtrim(a.ma_vv), rtrim(a.ma_sp), rtrim(ma_bp), rtrim(a.ma_hd), rtrim(a.ma_ku), rtrim(a.so_lsx), rtrim(a.ma_phi), a.ma_ct, a.so_ct, a.ngay_ct'
select @s = @s + char(13) + ' from ' + case when @vcCode = 'PNG' then 'd78$' when @vcCode = 'PNB' then 'd72$' else 'd71$' end + case when patindex('%[^0-9]%', @e) > 0 then '000000' else left(@e, 6) end + ' a left join dmvt b on a.ma_vt = b.ma_vt where a.stt_rec = ''' + replace(@vcID, '''', '') + ''''
exec sp_executesql @s
select @@fieldExternal from #r a left join dmvt b on a.ma_vt = b.ma_vt order by line_nbr
drop table #r
]]>
      </text>
    </query>
  </queries>

