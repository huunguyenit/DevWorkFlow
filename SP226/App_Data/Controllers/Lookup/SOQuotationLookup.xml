<?xml version="1.0" encoding="utf-8"?>

<!DOCTYPE lookup [
  <!ENTITY FilterInitialize SYSTEM "..\Include\FilterInitialize.xml">
  <!ENTITY % Control.Filter SYSTEM "..\Include\Filter.ent">
  %Control.Filter;
  <!ENTITY Controller "'SQTran'">

  <!ENTITY % CheckRelative SYSTEM "..\Include\CheckRelative.ent">
  %CheckRelative;
  <!ENTITY CheckRelativeParameter "'SOQuotationLookup', 'Lookup', 'SOTran'">
  <!ENTITY CheckRelativeQuery "set @$primeFilter = '1 = 0'">
]>

<lookup table="m61$000000" code="so_ct" name="stt_rec" order="ngay_ct, so_ct, stt_rec" xmlns="urn:schemas-fast-com:data-lookup">
  <header v="Chọn giấy báo giá" e="Select Quotation"></header>
  <fields>
    <field name="so_ct" align="right" allowFilter="true">
      <header v="Số báo giá" e="Quotation No."></header>
      <query>&InsertCommandFilter;</query>
    </field>
    <field name="stt_rec">
      <header v="" e=""></header>
    </field>
    <field name="ngay_ct" type="DateTime" dataFormatString="dd/MM/yyyy" allowFilter="true">
      <header v="Ngày báo giá" e="Quotation Date"></header>
      <query>&InsertCommandFilter;</query>
    </field>
    <field name="t_tien_nt2" type="Decimal" dataFormatString="### ### ### ### ### ###.00" allowFilter="true">
      <header v="Tiền hàng" e="Amount"></header>
      <query>&InsertCommandFilter;</query>
    </field>
    <field name="ma_nt" allowFilter="true">
      <header v="Mã nt" e="Currency Code"></header>
      <query>&InsertCommandFilter;</query>
    </field>
    <field name="status" allowFilter="true">
      <header v="Trạng thái" e="Status"></header>
      <query>&InsertCommandFilter;</query>
    </field>
    <field name="u0%l" aliasName="statusname%l" allowFilter="true">
      <header v="Tên trạng thái" e="Status Name"></header>
      <query>&InsertCommandFilter;</query>
    </field>
  </fields>

  <queries>
    <query event="Declare">
      <text>&DeclareCommandFilter;</text>
    </query>

    <query event="Finding">
      <text>
        <![CDATA[
declare @unit varchar(128), @custID varchar(64)
select @custID = '%#10$' + @ma_kh + '#%', @unit = case when @ma_dvcs = '' then @@unit else @ma_dvcs end
]]>&FilterInitialize;&CheckRelativeProcess;<![CDATA[
exec FastBusiness$App$Voucher$Finding 'SQ1', 'c61$000000', 'm61$', 'i61$', 'ngay_ct', 'convert(char(6), {0}, 112)', 'dateadd(month, 1, {0})', '000000',
@@refresh, @@pageIndex, @@pageCount, @@lastPage, @@lastCount, @@firstItem, @@lastItem, @custID, '', 'stt_rec',
  'so_ct,stt_rec,ngay_ct,t_tien_nt2,ma_nt,status',
  'so_ct,stt_rec,ngay_ct,t_tien_nt2,ma_nt,a.status,b.statusname%l u0%l',
  'a left join dmttct b on a.status = b.status where b.ma_ct = ''SQ1''',
  'ngay_ct, so_ct', 1, @@userID, 1,
  @ngay_ct1, @ngay_ct2, '', '', '1', '0', @unit, 0, 1, default, default, default, default, default, @$primeJoin, @$primeFilter]]>
      </text>
    </query>
  </queries>
</lookup>