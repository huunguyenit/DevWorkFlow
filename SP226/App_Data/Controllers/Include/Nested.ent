<!ENTITY % Conditional.TS2Tran.Nested SYSTEM "..\Include\TS2Tran.Nested">

<!ENTITY Nested.Message.Exists.v "đã có">
<!ENTITY Nested.Message.Exists.e "already exists">

<!ENTITY Nested.Message.Invalid.v "đã có hoặc lồng nhau">
<!ENTITY Nested.Message.Invalid.e "invalid or already exists">

<![%Conditional.Item.Nested;[
  <!ENTITY Item.Nested.Key.a "ma_vt = @ma_vt">
  <!ENTITY Item.Nested.Key.b "if 1 = 0 begin">

  <!ENTITY Item.Nested.Message.v "&Nested.Message.Exists.v;">
  <!ENTITY Item.Nested.Message.e "&Nested.Message.Exists.e;">
]]>

<![%Conditional.Customer.Nested;[
  <!ENTITY Customer.Nested.Key.a "ma_kh = @ma_kh">
  <!ENTITY Customer.Nested.Key.b "if 1 = 0 begin">

  <!ENTITY Customer.Nested.Message.v "&Nested.Message.Exists.v;">
  <!ENTITY Customer.Nested.Message.e "&Nested.Message.Exists.e;">
  <!ENTITY Customer.Nested.Report ",1">
]]>
<![%Conditional.Job.Nested;[
  <!ENTITY Job.Nested.Key.a "ma_vv = @ma_vv">
  <!ENTITY Job.Nested.Key.b "if 1 = 0 begin">

  <!ENTITY Job.Nested.Message.v "&Nested.Message.Exists.v;">
  <!ENTITY Job.Nested.Message.e "&Nested.Message.Exists.e;">
]]>
<![%Conditional.Contract.Nested;[
  <!ENTITY Contract.Nested.Key.a "ma_hd = @ma_hd">
  <!ENTITY Contract.Nested.Key.b "if 1 = 0 begin">

  <!ENTITY Contract.Nested.Message.v "&Nested.Message.Exists.v;">
  <!ENTITY Contract.Nested.Message.e "&Nested.Message.Exists.e;">
]]>
<![%Conditional.LoanContract.Nested;[
  <!ENTITY LoanContract.Nested.Key.a "ma_ku = @ma_ku">
  <!ENTITY LoanContract.Nested.Key.b "if 1 = 0 begin">

  <!ENTITY LoanContract.Nested.Message.v "&Nested.Message.Exists.v;">
  <!ENTITY LoanContract.Nested.Message.e "&Nested.Message.Exists.e;">
]]>
<![%Conditional.Expense.Nested;[
  <!ENTITY Expense.Nested.Key.a "ma_phi = @ma_phi">
  <!ENTITY Expense.Nested.Key.b "if 1 = 0 begin">

  <!ENTITY Expense.Nested.Message.v "&Nested.Message.Exists.v;">
  <!ENTITY Expense.Nested.Message.e "&Nested.Message.Exists.e;">
]]>
<![%Conditional.ManagementObject1.Nested;[
  <!ENTITY ManagementObject1.Nested.Key.a "ma_dtqt = @ma_dtqt">
  <!ENTITY ManagementObject1.Nested.Key.b "if 1 = 0 begin">

  <!ENTITY ManagementObject1.Nested.Message.v "&Nested.Message.Exists.v;">
  <!ENTITY ManagementObject1.Nested.Message.e "&Nested.Message.Exists.e;">
]]>
<![%Conditional.ManagementObject2.Nested;[
  <!ENTITY ManagementObject2.Nested.Key.a "ma_dtqt = @ma_dtqt">
  <!ENTITY ManagementObject2.Nested.Key.b "if 1 = 0 begin">

  <!ENTITY ManagementObject2.Nested.Message.v "&Nested.Message.Exists.v;">
  <!ENTITY ManagementObject2.Nested.Message.e "&Nested.Message.Exists.e;">
]]>
<![%Conditional.ManagementObject3.Nested;[
  <!ENTITY ManagementObject3.Nested.Key.a "ma_dtqt = @ma_dtqt">
  <!ENTITY ManagementObject3.Nested.Key.b "if 1 = 0 begin">

  <!ENTITY ManagementObject3.Nested.Message.v "&Nested.Message.Exists.v;">
  <!ENTITY ManagementObject3.Nested.Message.e "&Nested.Message.Exists.e;">
]]>
<![%Conditional.FATran.Nested;[
  <!ENTITY FATran.Nested.Key.a "so_the_ts = @so_the_ts">
  <!ENTITY FATran.Nested.Key.b "if 1 = 0 begin">

  <!ENTITY FATran.Nested.Message.v "&Nested.Message.Exists.v;">
  <!ENTITY FATran.Nested.Message.e "&Nested.Message.Exists.e;">
