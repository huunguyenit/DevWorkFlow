<UserControl x:Class="UI.Views.Shell.IdeRibbon"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:md="http://materialdesigninxaml.net/winfx/xaml/themes"
             xmlns:cmd="clr-namespace:UI.Commands">
    <UserControl.Resources>
        <!-- Icon well: nền tách biệt ribbon trắng + viền nhẹ -->
        <Style x:Key="RibbonIconWell" TargetType="Border">
            <Setter Property="Width" Value="32"/>
            <Setter Property="Height" Value="32"/>
            <Setter Property="CornerRadius" Value="6"/>
            <Setter Property="HorizontalAlignment" Value="Center"/>
            <Setter Property="Background" Value="#E8EEF5"/>
            <Setter Property="BorderBrush" Value="#C5D0DC"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="SnapsToDevicePixels" Value="True"/>
            <Setter Property="UseLayoutRounding" Value="True"/>
        </Style>
        <Style x:Key="RibbonIconWellPrimary" TargetType="Border" BasedOn="{StaticResource RibbonIconWell}">
            <Setter Property="Background" Value="#CDE5FA"/>
            <Setter Property="BorderBrush" Value="#90CAF9"/>
        </Style>
        <Style x:Key="RibbonIconWellSuccess" TargetType="Border" BasedOn="{StaticResource RibbonIconWell}">
            <Setter Property="Background" Value="#DCEFDE"/>
            <Setter Property="BorderBrush" Value="#A5D6A7"/>
        </Style>
        <Style x:Key="RibbonIconWellAmber" TargetType="Border" BasedOn="{StaticResource RibbonIconWell}">
            <Setter Property="Background" Value="#FFF3C4"/>
            <Setter Property="BorderBrush" Value="#FFE082"/>
        </Style>
        <Style x:Key="RibbonLabel" TargetType="TextBlock">
            <Setter Property="FontSize" Value="12"/>
            <Setter Property="FontWeight" Value="Medium"/>
            <Setter Property="Foreground" Value="{StaticResource FgBrush}"/>
            <Setter Property="HorizontalAlignment" Value="Center"/>
            <Setter Property="Margin" Value="0,4,0,0"/>
            <Setter Property="TextOptions.TextFormattingMode" Value="Display"/>
            <Setter Property="TextOptions.TextRenderingMode" Value="ClearType"/>
            <Setter Property="SnapsToDevicePixels" Value="True"/>
        </Style>
    </UserControl.Resources>

    <Border Background="{StaticResource IdeRibbonBgBrush}"
            BorderBrush="{StaticResource IdeBorderBrush}"
            BorderThickness="0,0,0,1"
            Padding="10,5,10,3"
            SnapsToDevicePixels="True"
            UseLayoutRounding="True"
            TextOptions.TextFormattingMode="Display"
            TextOptions.TextRenderingMode="ClearType">
        <StackPanel Orientation="Horizontal">

            <!-- File -->
            <StackPanel Margin="0,0,2,0">
                <StackPanel Orientation="Horizontal">
                    <Button Style="{StaticResource IdeRibbonButtonStyle}"
                            Command="{x:Static cmd:IdeCommands.New}" ToolTip="New (Ctrl+N)">
                        <StackPanel>
                            <Border Style="{StaticResource RibbonIconWell}">
                                <md:PackIcon Kind="FilePlusOutline" Width="18" Height="18"
                                             HorizontalAlignment="Center" VerticalAlignment="Center"
                                             Foreground="{StaticResource PrimaryBrush}"/>
                            </Border>
                            <TextBlock Text="New" Style="{StaticResource RibbonLabel}"/>
                        </StackPanel>
                    </Button>
                    <Button Style="{StaticResource IdeRibbonButtonStyle}"
                            Command="{x:Static cmd:IdeCommands.Open}" ToolTip="Open (Ctrl+O)">
                        <StackPanel>
                            <Border Style="{StaticResource RibbonIconWell}">
                                <md:PackIcon Kind="FolderOpenOutline" Width="18" Height="18"
                                             HorizontalAlignment="Center" VerticalAlignment="Center"
                                             Foreground="#1565C0"/>
                            </Border>
                            <TextBlock Text="Open" Style="{StaticResource RibbonLabel}"/>
                        </StackPanel>
                    </Button>
                    <Button Style="{StaticResource IdeRibbonPrimaryButtonStyle}"
                            Command="{x:Static cmd:IdeCommands.Save}" ToolTip="Save (Ctrl+S)">
                        <StackPanel>
                            <Border Style="{StaticResource RibbonIconWellPrimary}">
                                <md:PackIcon Kind="ContentSave" Width="18" Height="18"
                                             HorizontalAlignment="Center" VerticalAlignment="Center"
                                             Foreground="{StaticResource PrimaryDarkBrush}"/>
                            </Border>
                            <TextBlock Text="Save" Style="{StaticResource RibbonLabel}"
                                       FontWeight="SemiBold"
                                       Foreground="{StaticResource PrimaryDarkBrush}"/>
                        </StackPanel>
                    </Button>
                </StackPanel>
                <TextBlock Text="File" Style="{StaticResource IdeRibbonGroupLabelStyle}"/>
            </StackPanel>

            <Rectangle Style="{StaticResource IdeRibbonSeparatorStyle}"/>

            <!-- Edit -->
            <StackPanel Margin="0,0,2,0">
                <StackPanel Orientation="Horizontal">
                    <Button Style="{StaticResource IdeRibbonButtonStyle}"
                            Command="{x:Static cmd:IdeCommands.Undo}" ToolTip="Undo (Ctrl+Z)">
                        <StackPanel>
                            <Border Style="{StaticResource RibbonIconWell}">
                                <md:PackIcon Kind="Undo" Width="18" Height="18"
                                             HorizontalAlignment="Center" VerticalAlignment="Center"
                                             Foreground="#5E6A75"/>
                            </Border>
                            <TextBlock Text="Undo" Style="{StaticResource RibbonLabel}"/>
                        </StackPanel>
                    </Button>
                    <Button Style="{StaticResource IdeRibbonButtonStyle}"
                            Command="{x:Static cmd:IdeCommands.Redo}" ToolTip="Redo (Ctrl+Y)">
                        <StackPanel>
                            <Border Style="{StaticResource RibbonIconWell}">
                                <md:PackIcon Kind="Redo" Width="18" Height="18"
                                             HorizontalAlignment="Center" VerticalAlignment="Center"
                                             Foreground="#5E6A75"/>
                            </Border>
                            <TextBlock Text="Redo" Style="{StaticResource RibbonLabel}"/>
                        </StackPanel>
                    </Button>
                </StackPanel>
                <TextBlock Text="Edit" Style="{StaticResource IdeRibbonGroupLabelStyle}"/>
            </StackPanel>

            <Rectangle Style="{StaticResource IdeRibbonSeparatorStyle}"/>

            <!-- Language -->
            <StackPanel Margin="0,0,2,0">
                <StackPanel Orientation="Horizontal">
                    <Button Style="{StaticResource IdeRibbonButtonStyle}"
                            Command="{x:Static cmd:IdeCommands.ValidateXml}" ToolTip="Validate XML">
                        <StackPanel>
                            <Border Style="{StaticResource RibbonIconWell}">
                                <md:PackIcon Kind="CheckDecagramOutline" Width="18" Height="18"
                                             HorizontalAlignment="Center" VerticalAlignment="Center"
                                             Foreground="#2E7D32"/>
                            </Border>
                            <TextBlock Text="Validate" Style="{StaticResource RibbonLabel}"/>
                        </StackPanel>
                    </Button>
                    <Button Style="{StaticResource IdeRibbonButtonStyle}"
                            Command="{x:Static cmd:IdeCommands.ClearText}"
                            ToolTip="Toggle Source / Insight Mode">
                        <StackPanel>
                            <Border Style="{StaticResource RibbonIconWellAmber}">
                                <md:PackIcon Kind="LightbulbOnOutline" Width="18" Height="18"
                                             HorizontalAlignment="Center" VerticalAlignment="Center"
                                             Foreground="#F9A825"/>
                            </Border>
                            <TextBlock Text="Insight" Style="{StaticResource RibbonLabel}"/>
                        </StackPanel>
                    </Button>
                </StackPanel>
                <TextBlock Text="Language" Style="{StaticResource IdeRibbonGroupLabelStyle}"/>
            </StackPanel>

            <Rectangle Style="{StaticResource IdeRibbonSeparatorStyle}"/>

            <!-- SQL -->
            <StackPanel Margin="0,0,2,0">
                <StackPanel Orientation="Horizontal">
                    <Button Style="{StaticResource IdeRibbonSuccessButtonStyle}"
                            Command="{x:Static cmd:IdeCommands.ExecuteSql}"
                            ToolTip="Execute SQL (F5)">
                        <StackPanel>
                            <Border Style="{StaticResource RibbonIconWellSuccess}">
                                <md:PackIcon Kind="Play" Width="18" Height="18"
                                             HorizontalAlignment="Center" VerticalAlignment="Center"
                                             Foreground="{StaticResource SuccessBrush}"/>
                            </Border>
                            <TextBlock Text="Run" Style="{StaticResource RibbonLabel}"
                                       FontWeight="SemiBold"
                                       Foreground="#2E7D32"/>
                        </StackPanel>
                    </Button>
                    <Button Style="{StaticResource IdeRibbonButtonStyle}"
                            Command="{x:Static cmd:IdeCommands.OpenSqlFromForm}"
                            ToolTip="Open SQL Studio from form commands">
                        <StackPanel>
                            <Border Style="{StaticResource RibbonIconWell}">
                                <md:PackIcon Kind="Database" Width="18" Height="18"
                                             HorizontalAlignment="Center" VerticalAlignment="Center"
                                             Foreground="#0277BD"/>
                            </Border>
                            <TextBlock Text="SQL" Style="{StaticResource RibbonLabel}"/>
                        </StackPanel>
                    </Button>
                </StackPanel>
                <TextBlock Text="SQL" Style="{StaticResource IdeRibbonGroupLabelStyle}"/>
            </StackPanel>

            <Rectangle Style="{StaticResource IdeRibbonSeparatorStyle}"/>

            <!-- Web Skin (nền Designer Platform) -->
            <StackPanel Margin="0,0,2,0">
                <StackPanel Orientation="Horizontal">
                    <Button Style="{StaticResource IdeRibbonButtonStyle}"
                            Command="{x:Static cmd:IdeCommands.CaptureSkin}"
                            CommandTarget="{Binding RelativeSource={RelativeSource AncestorType=Window}}"
                            ToolTip="Lấy / cập nhật Web Skin (login ERP → lưu shell local)">
                        <StackPanel>
                            <Border Style="{StaticResource RibbonIconWellPrimary}">
                                <md:PackIcon Kind="Web" Width="18" Height="18"
                                             HorizontalAlignment="Center" VerticalAlignment="Center"
                                             Foreground="{StaticResource PrimaryDarkBrush}"/>
                            </Border>
                            <TextBlock Text="Skin" Style="{StaticResource RibbonLabel}"/>
                        </StackPanel>
                    </Button>
                    <Button Style="{StaticResource IdeRibbonButtonStyle}"
                            Command="{x:Static cmd:IdeCommands.RefreshSkinAssets}"
                            CommandTarget="{Binding RelativeSource={RelativeSource AncestorType=Window}}"
                            ToolTip="Refresh CSS/JS/image từ Program (không login lại)">
                        <StackPanel>
                            <Border Style="{StaticResource RibbonIconWell}">
                                <md:PackIcon Kind="FolderSync" Width="18" Height="18"
                                             HorizontalAlignment="Center" VerticalAlignment="Center"
                                             Foreground="#455A64"/>
                            </Border>
                            <TextBlock Text="Assets" Style="{StaticResource RibbonLabel}"/>
                        </StackPanel>
                    </Button>
                    <Button Style="{StaticResource IdeRibbonButtonStyle}"
                            Command="{x:Static cmd:IdeCommands.ViewSkin}"
                            CommandTarget="{Binding RelativeSource={RelativeSource AncestorType=Window}}"
                            ToolTip="Xem skin trống (shell đã chuẩn hóa)">
                        <StackPanel>
                            <Border Style="{StaticResource RibbonIconWell}">
                                <md:PackIcon Kind="MonitorScreenshot" Width="18" Height="18"
                                             HorizontalAlignment="Center" VerticalAlignment="Center"
                                             Foreground="#0277BD"/>
                            </Border>
                            <TextBlock Text="Preview" Style="{StaticResource RibbonLabel}"/>
                        </StackPanel>
                    </Button>
                </StackPanel>
                <TextBlock Text="Web Skin" Style="{StaticResource IdeRibbonGroupLabelStyle}"/>
            </StackPanel>

            <Rectangle Style="{StaticResource IdeRibbonSeparatorStyle}"/>

            <!-- Navigate -->
            <StackPanel>
                <StackPanel Orientation="Horizontal">
                    <Button Style="{StaticResource IdeRibbonButtonStyle}"
                            Command="{x:Static cmd:IdeCommands.Search}" ToolTip="Find (Ctrl+F)">
                        <StackPanel>
                            <Border Style="{StaticResource RibbonIconWell}">
                                <md:PackIcon Kind="Magnify" Width="18" Height="18"
                                             HorizontalAlignment="Center" VerticalAlignment="Center"
                                             Foreground="#455A64"/>
                            </Border>
                            <TextBlock Text="Find" Style="{StaticResource RibbonLabel}"/>
                        </StackPanel>
                    </Button>
                    <Button Style="{StaticResource IdeRibbonButtonStyle}"
                            Command="{x:Static cmd:IdeCommands.Replace}" ToolTip="Replace (Ctrl+H)">
                        <StackPanel>
                            <Border Style="{StaticResource RibbonIconWell}">
                                <md:PackIcon Kind="FindReplace" Width="18" Height="18"
                                             HorizontalAlignment="Center" VerticalAlignment="Center"
                                             Foreground="#455A64"/>
                            </Border>
                            <TextBlock Text="Replace" Style="{StaticResource RibbonLabel}"/>
                        </StackPanel>
                    </Button>
                    <Button Style="{StaticResource IdeRibbonButtonStyle}"
                            Command="{x:Static cmd:IdeCommands.GoToDefinition}" ToolTip="Go To Definition (F12)">
                        <StackPanel>
                            <Border Style="{StaticResource RibbonIconWell}">
                                <md:PackIcon Kind="ArrowRightBoldBoxOutline" Width="18" Height="18"
                                             HorizontalAlignment="Center" VerticalAlignment="Center"
                                             Foreground="{StaticResource PrimaryBrush}"/>
                            </Border>
                            <TextBlock Text="Go To" Style="{StaticResource RibbonLabel}"/>
                        </StackPanel>
                    </Button>
                </StackPanel>
                <TextBlock Text="Navigate" Style="{StaticResource IdeRibbonGroupLabelStyle}"/>
            </StackPanel>
        </StackPanel>
    </Border>
</UserControl>
