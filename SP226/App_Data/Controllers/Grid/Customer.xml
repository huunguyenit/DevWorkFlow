}
function dispose$Grid(g) {
  try {g.remove_commandEvent(on$GridCustomer$ExecuteCommand);} catch (ex) {}
  try {g.remove_onResponseComplete(on$GridCustomer$ResponseComplete);} catch (ex) {}  
}
function on$GridCustomer$ExecuteCommand(sender, e) {
  var action = e.type.Action, g = sender;
  switch (action) {
    case 'ImportData':
      show$Form(g, 'CustomerImport');
      break;
    case 'Download':
      request$Download(g, action);
      break;
    default:
      break;
  }
}
function on$GridCustomer$ResponseComplete(sender, e) {
  var g = e.object, context = e.type.Context, result = e.type.Result, o = e.type.Object;
  switch (context) {
    case 'Download':
