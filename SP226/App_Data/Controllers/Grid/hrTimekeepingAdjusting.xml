	  select @rKey, getdate(), @so_lan, loai_dl, stt_rec, ngay, gio_vao, hs_vao, gio_ra, hs_ra, gio_vao0, hs_vao0, gio_ra0, hs_ra0, xoa_yn, ghi_chu, gio_vao_old, hs_vao_old, gio_ra_old, hs_ra_old from #t
  select ''
  return
end

insert into #t (stt_rec, ngay, ky, gio_vao0, hs_vao0, gio_ra0, hs_ra0, gio_vao, hs_vao, gio_ra, hs_ra, xoa_yn, ghi_chu, loai_dl, gio_vao_old, hs_vao_old, gio_ra_old, hs_ra_old)
  select stt_rec, convert(char(8), ngay, 112), convert(char(6), ngay, 112), gio_vao0, hs_vao0, gio_ra0, hs_ra0, gio_vao, hs_vao, gio_ra, hs_ra, xoa_yn, ghi_chu, loai_dl, gio_vao_old, hs_vao_old, gio_ra_old, hs_ra_old
    from hrdcdulieu$999999 where rkey = @rKey
delete hrdcdulieu$999999 where rkey = @rKey
update #t set thoi_gian_vao = cast(convert(varchar(8), ngay, 112) + ' ' + gio_vao as datetime) + case when hs_vao = 1 then 1 else 0 end where gio_vao <> ''
update #t set thoi_gian_ra = cast(convert(varchar(8), ngay, 112) + ' ' + gio_ra as datetime) + case when hs_ra = 1 then 1 else 0 end where gio_ra <> ''

select top 1 @check = 1, @s1 = gio_vao, @s2 = stt_rec, @s3 = convert(char(10), ngay, 103) from #t a where loai_dl = 1 and exists(select 1 from #t b where loai_dl = 1 and b.stt <> a.stt and b.stt_rec = a.stt_rec and b.ngay = a.ngay and b.gio_vao = a.gio_vao)
if @check = 1 begin
  select replace(replace(replace(@$exists, '%s1', @s1), '%s2', rtrim(ma_nv)), '%s3', @s3) from hrnv with(nolock) where stt_rec = @s2
  return
end
select top 1 @check = 1, @s1 = gio_ra, @s2 = stt_rec, @s3 = convert(char(10), ngay, 103) from #t a where loai_dl = 1 and exists(select 1 from #t b where loai_dl = 1 and b.stt <> a.stt and b.stt_rec = a.stt_rec and b.ngay = a.ngay and b.gio_ra = a.gio_ra)
if @check = 1 begin
  select replace(replace(replace(@$exists, '%s1', @s1), '%s2', rtrim(ma_nv)), '%s3', @s3) from hrnv with(nolock) where stt_rec = @s2
  return
end

select top 1 @check = 1, @s1 = a.gio_vao + '/' + a.gio_ra, @s2 = a.stt_rec, @s3 = convert(char(10), a.ngay, 103)
  from #t a, #t b where a.stt_rec = b.stt_rec and a.ngay = b.ngay and (
  (a.thoi_gian_vao <> b.thoi_gian_vao and a.thoi_gian_vao = b.thoi_gian_ra) or (a.thoi_gian_ra <> b.thoi_gian_ra and a.thoi_gian_ra = b.thoi_gian_vao))
if @check = 1 begin
  select replace(replace(replace(@$exists, '%s1', @s1), '%s2', rtrim(ma_nv)), '%s3', @s3) from hrnv with(nolock) where stt_rec = @s2
  return
end

select distinct ky into #ky from #t
select @ky = min(ky) from #ky
select top 0 @check as c, @s1 as s1, @s2 as s2, @s3 as s3 into #check
while @ky is not null begin
  set @q = 'select top 1 1, a.gio_vao + ''/'' + a.gio_ra, a.stt_rec, convert(char(10), a.ngay, 103) from #t a join hrdcdulieu$' + @ky + ' b with(nolock) on a.stt_rec = b.stt_rec and a.ngay = b.ngay'
  set @q = @q + ' where a.loai_dl = b.loai_dl and not (b.gio_vao = a.gio_vao_old and b.hs_vao = a.hs_vao_old and b.gio_ra = a.gio_ra_old and b.hs_ra = a.hs_ra_old)'
  set @q = @q + ' and ((a.gio_vao = b.gio_vao and a.hs_vao = b.hs_vao) or (a.gio_ra = b.gio_vao and a.hs_ra = b.hs_vao) or (a.gio_vao = b.gio_ra and a.hs_vao = b.hs_ra) or (a.gio_ra = b.gio_ra and a.hs_ra = b.hs_ra))'
  insert into #check exec sp_executesql @q

  select top 1 @check = c, @s1 = s1, @s2 = s2, @s3 = s3 from #check
  if @check = 1 begin
	select replace(replace(replace(@$exists, '%s1', @s1), '%s2', rtrim(ma_nv)), '%s3', @s3) from hrnv with(nolock) where stt_rec = @s2
    return
  end
  --
  select @ky = min(ky) from #ky where ky > @ky
end

set @q = 'update hrdcdulieu$%ky set gio_vao = b.gio_vao, hs_vao = b.hs_vao, gio_ra = b.gio_ra, hs_ra = b.hs_ra,'
set @q = @q + ' thoi_gian_vao = b.thoi_gian_vao, thoi_gian_ra = b.thoi_gian_ra,'
set @q = @q + ' gio0_vao = cast(left(b.gio_vao, 2) as int) * 60 + cast(right(b.gio_vao, 2) as int) + case when b.hs_vao = 1 then 1440 else 0 end,'
set @q = @q + ' gio0_ra = cast(left(b.gio_ra, 2) as int) * 60 + cast(right(b.gio_ra, 2) as int) + case when b.hs_ra = 1 then 1440 else 0 end,'
set @q = @q + ' ghi_chu = b.ghi_chu, xoa_yn = b.xoa_yn, datetime2 = getdate(), user_id2 = @@userID'
set @q = @q + ' from hrdcdulieu$%ky a join #t b on a.stt_rec = b.stt_rec and a.ngay = b.ngay and a.loai_dl = b.loai_dl and a.gio_vao = b.gio_vao_old and a.hs_vao = b.hs_vao_old and a.gio_ra = b.gio_ra_old and a.hs_ra = b.hs_ra_old'
set @q = @q + ' where not exists (select 1 from hrdcdulieu$%ky c with(nolock) where b.stt_rec = c.stt_rec and b.ngay = c.ngay and b.loai_dl = c.loai_dl'
set @q = @q + ' and ((a.gio_vao <> b.gio_vao_old or a.hs_vao <> b.hs_vao_old))'
set @q = @q + ' and ((b.gio_vao = c.gio_vao and b.hs_vao = c.hs_vao) or (b.gio_ra = c.gio_vao and b.hs_ra = c.hs_vao)'
set @q = @q + ' or (b.gio_vao = c.gio_ra and b.hs_vao = c.hs_ra) or (b.gio_ra = c.gio_ra and b.hs_ra = c.hs_ra)))'
set @q = @q + char(13)
set @q = @q + 'insert into hrdcdulieu$%ky (stt_rec, ngay, gio_vao, hs_vao, gio_vao0, hs_vao0, gio0_vao, thoi_gian_vao, thoi_gian_vao0, gio_ra,'
set @q = @q + ' hs_ra, gio_ra0, hs_ra0, gio0_ra, thoi_gian_ra, thoi_gian_ra0, xoa_yn, ghi_chu, loai_dl, datetime0, datetime2, user_id0, user_id2)'
set @q = @q + ' select a.stt_rec, a.ngay, a.gio_vao, a.hs_vao, a.gio_vao0, a.hs_vao0,'
set @q = @q + ' cast(left(a.gio_vao, 2) as int) * 60 + cast(right(a.gio_vao, 2) as int) + case when a.hs_vao = 1 then 1440 else 0 end,'
set @q = @q + ' a.thoi_gian_vao, case when a.gio_vao0 <> '''' then cast(convert(varchar(8), a.ngay, 112) + '' '' + a.gio_vao0 as datetime) + case when a.hs_vao0 = 1 then 1 else 0 end else null end,'
set @q = @q + ' a.gio_ra, a.hs_ra, a.gio_ra0, a.hs_ra0,'
set @q = @q + ' cast(left(a.gio_ra, 2) as int) * 60 + cast(right(a.gio_ra, 2) as int) + case when a.hs_ra = 1 then 1440 else 0 end,'
set @q = @q + ' a.thoi_gian_ra, case when a.gio_ra0 <> '''' then cast(convert(varchar(8), a.ngay, 112) + '' '' + a.gio_ra0 as datetime) + case when a.hs_ra0 = 1 then 1 else 0 end else null end,'
set @q = @q + ' a.xoa_yn, a.ghi_chu, a.loai_dl, getdate(), getdate(), @@userID, @@userID'
set @q = @q + ' from #t a where not exists (select 1 from hrdcdulieu$%ky b with(nolock) where a.stt_rec = b.stt_rec and a.ngay = b.ngay and a.gio_vao_old = b.gio_vao and a.hs_vao_old = b.hs_vao and a.gio_ra_old = b.gio_ra and a.hs_ra_old = b.hs_ra)'
set @q = @q + ' and not exists(select 1 from hrdcdulieu$%ky c with(nolock) where a.stt_rec = c.stt_rec and a.ngay = c.ngay and a.gio_vao = c.gio_vao and a.hs_vao = c.hs_vao and a.gio_ra = c.gio_ra and a.hs_ra = c.hs_ra and a.loai_dl = c.loai_dl)'
set @q = @q + ' and a.ky = ''%ky'''

set @q3 = 'delete hrdcdulieu$%ky from hrdcdulieu$%ky a where exists (select 1 from #t b where a.stt_rec = b.stt_rec and a.ngay = b.ngay and a.loai_dl = 1'
set @q3 = @q3 + ' and a.gio_vao = b.gio_vao_old and a.hs_vao = b.hs_vao_old and a.gio_ra = b.gio_ra_old and a.hs_ra = b.hs_ra_old and b.xoa_yn = 1)'
set @q3 = @q3 + char(13) + 'delete #t where ky = ''%ky'' and loai_dl = 1 and xoa_yn = 1'

select @ky = min(ky) from #ky
while @ky is not null begin
  select @q2 = replace(@q, '%ky', @ky), @q4 = replace(@q3, '%ky', @ky)
  exec sp_executesql @q4
  exec sp_executesql @q2
  select @ky = min(ky) from #ky where ky > @ky
end

select 'Done'
return
