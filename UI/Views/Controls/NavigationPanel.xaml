<UserControl x:Class="UI.Views.Controls.NavigationPanel"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:md="http://materialdesigninxaml.net/winfx/xaml/themes"
             xmlns:vm="clr-namespace:UI.ViewModels">

    <UserControl.Resources>
        <BooleanToVisibilityConverter x:Key="BoolToVis"/>

        <HierarchicalDataTemplate DataType="{x:Type vm:MenuNodeViewModel}"
                                  ItemsSource="{Binding Children}">
            <Grid Margin="0,1" ToolTip="{Binding Tooltip}">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>

                <md:PackIcon Grid.Column="0"
                             Width="16" Height="16"
                             VerticalAlignment="Center"
                             Margin="0,0,6,0"
                             Kind="{Binding IconKind}"
                             Foreground="{Binding IconForeground}">
                    <md:PackIcon.Style>
                        <Style TargetType="md:PackIcon">
                            <Style.Triggers>
                                <DataTrigger Binding="{Binding IsSeparator}" Value="True">
                                    <Setter Property="Visibility" Value="Collapsed"/>
                                </DataTrigger>
                            </Style.Triggers>
                        </Style>
                    </md:PackIcon.Style>
                </md:PackIcon>

                <TextBlock Grid.Column="1"
                           Text="{Binding Title}"
                           Foreground="{StaticResource FgBrush}"
                           FontSize="12"
                           VerticalAlignment="Center"
                           TextTrimming="CharacterEllipsis"
                           TextWrapping="NoWrap"
                           HorizontalAlignment="Stretch">
                    <TextBlock.Style>
                        <Style TargetType="TextBlock">
                            <Setter Property="FontFamily" Value="Segoe UI"/>
                            <Style.Triggers>
                                <DataTrigger Binding="{Binding IsSeparator}" Value="True">
                                    <Setter Property="Foreground" Value="#A0A0A0"/>
                                    <Setter Property="FontFamily" Value="Consolas, Cascadia Code"/>
                                    <Setter Property="FontSize" Value="11"/>
                                    <Setter Property="Opacity" Value="0.85"/>
                                </DataTrigger>
                            </Style.Triggers>
                        </Style>
                    </TextBlock.Style>
                </TextBlock>

                <Border Grid.Column="2" Margin="8,0,0,0" Padding="5,1" CornerRadius="2"
                        VerticalAlignment="Center">
                    <Border.Style>
                        <Style TargetType="Border">
                            <Setter Property="Visibility" Value="Collapsed"/>
                            <Setter Property="Background" Value="#E0E0E0"/>
                            <Style.Triggers>
                                <DataTrigger Binding="{Binding IsSeparator}" Value="True">
                                    <Setter Property="Visibility" Value="Collapsed"/>
                                </DataTrigger>
                                <DataTrigger Binding="{Binding IsFileNode}" Value="True">
                                    <Setter Property="Visibility" Value="Visible"/>
                                    <Setter Property="Background" Value="{StaticResource BadgeFileBrush}"/>
                                </DataTrigger>
                                <DataTrigger Binding="{Binding HasControllerBadge}" Value="True">
                                    <Setter Property="Visibility" Value="Visible"/>
                                    <Setter Property="Background" Value="{StaticResource PrimaryBrush}"/>
                                </DataTrigger>
                            </Style.Triggers>
                        </Style>
                    </Border.Style>
                    <TextBlock Text="{Binding TypeBadge}"
                               Foreground="White"
                               FontSize="10"
                               FontWeight="SemiBold"/>
                </Border>

                <TextBlock Grid.Column="3"
                           Margin="6,0,4,0"
                           FontSize="10"
                           FontWeight="Bold"
                           Foreground="{StaticResource BadgeEncryptedBrush}"
                           VerticalAlignment="Center"
                           Text=".f">
                    <TextBlock.Style>
                        <Style TargetType="TextBlock">
                            <Setter Property="Visibility" Value="Collapsed"/>
                            <Style.Triggers>
                                <DataTrigger Binding="{Binding FileItem.IsEncrypted}" Value="True">
                                    <Setter Property="Visibility" Value="Visible"/>
                                </DataTrigger>
                            </Style.Triggers>
                        </Style>
                    </TextBlock.Style>
                </TextBlock>
            </Grid>
        </HierarchicalDataTemplate>
    </UserControl.Resources>

    <Grid Background="{StaticResource SidebarBgBrush}">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <!-- Explorer header -->
        <Border Grid.Row="0" Padding="12,10,8,8"
                BorderBrush="{StaticResource IdeBorderBrush}"
                BorderThickness="0,0,0,1">
            <TextBlock Text="EXPLORER"
                       Foreground="{StaticResource FgMutedBrush}"
                       FontSize="11" FontWeight="Bold"/>
        </Border>

        <!-- Program picker -->
        <StackPanel Grid.Row="1" Margin="8,8,8,6">
            <Button Style="{StaticResource IdePrimaryButtonStyle}"
                    Command="{Binding SelectProgramCommand}"
                    HorizontalAlignment="Stretch">
                <StackPanel Orientation="Horizontal">
                    <md:PackIcon Kind="FolderOpen" Width="16" Height="16" Foreground="White"/>
                    <TextBlock Text="Chọn Program" Margin="8,0,0,0"
                               VerticalAlignment="Center" Foreground="White"/>
                </StackPanel>
            </Button>
            <TextBlock Text="{Binding ProgramName}"
                       Foreground="{StaticResource FgMutedBrush}"
                       FontSize="12" Margin="2,8,2,4"
                       TextTrimming="CharacterEllipsis"
                       ToolTip="{Binding ProgramName}"/>
            <TextBox Text="{Binding FilterText, UpdateSourceTrigger=PropertyChanged}"
                     Style="{StaticResource IdeSearchBoxStyle}"
                     ToolTip="Lọc LIKE: bar, sysid, link, syscode, wmenu_id"/>
        </StackPanel>

        <!-- Tree -->
        <TreeView x:Name="MenuTree"
                  Grid.Row="2"
                  ItemsSource="{Binding MenuRoots}"
                  SelectedItemChanged="MenuTree_SelectedItemChanged"
                  RequestBringIntoView="MenuTree_RequestBringIntoView"
                  Style="{StaticResource IdeTreeViewStyle}"
                  Margin="0,0,0,4"
                  ScrollViewer.HorizontalScrollBarVisibility="Disabled"
                  ScrollViewer.VerticalScrollBarVisibility="Auto">
            <TreeView.ItemContainerStyle>
                <Style TargetType="TreeViewItem" BasedOn="{StaticResource IdeTreeViewItemStyle}">
                    <Setter Property="Visibility" Value="{Binding Visibility}"/>
                    <EventSetter Event="MouseDoubleClick" Handler="TreeViewItem_MouseDoubleClick"/>
                    <EventSetter Event="RequestBringIntoView" Handler="TreeViewItem_RequestBringIntoView"/>
                    <Style.Triggers>
                        <DataTrigger Binding="{Binding IsSeparator}" Value="True">
                            <Setter Property="Focusable" Value="False"/>
                            <Setter Property="IsHitTestVisible" Value="False"/>
                            <Setter Property="Padding" Value="0,2"/>
                        </DataTrigger>
                    </Style.Triggers>
                </Style>
            </TreeView.ItemContainerStyle>
        </TreeView>

        <TextBlock Grid.Row="3"
                   Text="{Binding StatusText}"
                   Foreground="{StaticResource FgMutedBrush}"
                   FontSize="11"
                   Margin="10,4,10,6"
                   TextWrapping="Wrap"/>

        <Border Grid.Row="4"
                BorderBrush="{StaticResource IdeBorderBrush}"
                BorderThickness="0,1,0,0"
                Padding="0,2">
            <StackPanel>
                <Button Style="{StaticResource SidebarButtonStyle}" Command="{Binding OpenSqlFileCommand}">
                    <StackPanel Orientation="Horizontal">
                        <md:PackIcon Kind="Database" Width="16" Height="16"/>
                        <TextBlock Text="Open SQL file…" Margin="10,0,0,0" VerticalAlignment="Center"/>
                    </StackPanel>
                </Button>
                <Button Style="{StaticResource SidebarButtonStyle}" Command="{Binding RefreshMenuCommand}">
                    <StackPanel Orientation="Horizontal">
                        <md:PackIcon Kind="Refresh" Width="16" Height="16"/>
                        <TextBlock Text="Refresh menu" Margin="10,0,0,0" VerticalAlignment="Center"/>
                    </StackPanel>
                </Button>
            </StackPanel>
        </Border>
    </Grid>
</UserControl>
