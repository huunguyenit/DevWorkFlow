<UserControl x:Class="UI.Views.Explorer.ExplorerTreePanel"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:md="http://materialdesigninxaml.net/winfx/xaml/themes"
             xmlns:ex="clr-namespace:UI.ViewModels.Explorer">

    <UserControl.Resources>
        <BooleanToVisibilityConverter x:Key="BoolToVis"/>

        <HierarchicalDataTemplate DataType="{x:Type ex:ExplorerTreeNodeVm}"
                                  ItemsSource="{Binding Children}">
            <Grid Margin="0,1" ToolTip="{Binding Tooltip}">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>

                <md:PackIcon Grid.Column="0" Width="14" Height="14"
                             Kind="{Binding IconKind}"
                             Foreground="{Binding IconForeground}"
                             VerticalAlignment="Center" Margin="0,0,6,0"/>

                <TextBlock Grid.Column="1" Text="{Binding DisplayText}"
                           FontSize="12" Foreground="{StaticResource FgBrush}"
                           TextTrimming="CharacterEllipsis" VerticalAlignment="Center"/>

                <TextBlock Grid.Column="2" Text="{Binding ModifiedText}"
                           FontSize="9" Foreground="{StaticResource FgMutedBrush}"
                           Margin="6,0,0,0" VerticalAlignment="Center"
                           Visibility="{Binding ShowModified, Converter={StaticResource BoolToVis}}"/>

                <Border Grid.Column="3" Margin="6,0,0,0" Padding="4,0" CornerRadius="2"
                        Background="{StaticResource BadgeFileBrush}"
                        Visibility="{Binding HasBadge, Converter={StaticResource BoolToVis}}"
                        VerticalAlignment="Center">
                    <TextBlock Text="{Binding Badge}" Foreground="White"
                               FontSize="9" FontWeight="SemiBold"/>
                </Border>
            </Grid>
        </HierarchicalDataTemplate>
    </UserControl.Resources>

    <DockPanel Background="{StaticResource SidebarBgBrush}">
        <Border DockPanel.Dock="Top" Margin="8,2,8,6" Padding="6,3"
                Background="White" BorderBrush="{StaticResource IdeBorderBrush}" BorderThickness="1">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="*"/>
                </Grid.ColumnDefinitions>
                <md:PackIcon Kind="Magnify" Width="12" Height="12" Foreground="#888"
                             VerticalAlignment="Center"/>
                <TextBox Grid.Column="1" Margin="6,0,0,0"
                         Text="{Binding FilterText, UpdateSourceTrigger=PropertyChanged}"
                         BorderThickness="0" Background="Transparent" FontSize="11"
                         VerticalContentAlignment="Center"/>
            </Grid>
        </Border>

        <TextBlock DockPanel.Dock="Bottom" Text="{Binding StatusText}"
                   FontSize="10" Foreground="{StaticResource FgMutedBrush}"
                   Margin="8,4,8,10" TextTrimming="CharacterEllipsis" TextWrapping="Wrap"/>

        <TreeView ItemsSource="{Binding TreeRoots}"
                  Style="{StaticResource IdeTreeViewStyle}"
                  Padding="4,0,4,16"
                  SelectedItemChanged="TreeView_SelectedItemChanged">
            <TreeView.ItemContainerStyle>
                <Style TargetType="TreeViewItem" BasedOn="{StaticResource IdeTreeViewItemStyle}">
                    <Setter Property="Visibility" Value="{Binding IsVisible, Converter={StaticResource BoolToVis}}"/>
                    <Setter Property="Padding" Value="2"/>
                    <EventSetter Event="Expanded" Handler="TreeViewItem_Expanded"/>
                    <EventSetter Event="MouseDoubleClick" Handler="TreeViewItem_MouseDoubleClick"/>
                </Style>
            </TreeView.ItemContainerStyle>
        </TreeView>
    </DockPanel>
</UserControl>
