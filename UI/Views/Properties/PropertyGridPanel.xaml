<UserControl x:Class="UI.Views.Properties.PropertyGridPanel"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:md="http://materialdesigninxaml.net/winfx/xaml/themes"
             xmlns:design="clr-namespace:UI.ViewModels.Design">

    <UserControl.Resources>
        <BooleanToVisibilityConverter x:Key="BoolToVis"/>

        <DataTemplate DataType="{x:Type design:DesignFieldPropertyVm}">
            <Border BorderBrush="#EEEEEE" BorderThickness="0,0,0,1" Padding="6,3" Background="White">
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="Auto"/>
                        <ColumnDefinition Width="110"/>
                        <ColumnDefinition Width="*"/>
                    </Grid.ColumnDefinitions>

                    <Button Grid.Column="0" Width="18" Height="18" Padding="0" Margin="0,0,4,0"
                            Background="Transparent" BorderThickness="0" Cursor="Hand"
                            Command="{Binding DataContext.ToggleFavoriteCommand, RelativeSource={RelativeSource AncestorType=UserControl}}"
                            CommandParameter="{Binding}"
                            ToolTip="Favorite">
                        <md:PackIcon Kind="StarOutline" Width="12" Height="12" Foreground="#C9A227"/>
                    </Button>

                    <TextBlock Grid.Column="1" Text="{Binding DisplayName}"
                               FontSize="11" Foreground="#555"
                               VerticalAlignment="Center" TextTrimming="CharacterEllipsis"
                               ToolTip="{Binding Name}"/>

                    <CheckBox Grid.Column="2"
                              IsChecked="{Binding BoolValue, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                              VerticalAlignment="Center">
                        <CheckBox.Style>
                            <Style TargetType="CheckBox">
                                <Setter Property="Visibility" Value="Collapsed"/>
                                <Style.Triggers>
                                    <DataTrigger Binding="{Binding IsBooleanEditor}" Value="True">
                                        <Setter Property="Visibility" Value="Visible"/>
                                    </DataTrigger>
                                    <DataTrigger Binding="{Binding IsReadOnly}" Value="True">
                                        <Setter Property="IsEnabled" Value="False"/>
                                    </DataTrigger>
                                </Style.Triggers>
                            </Style>
                        </CheckBox.Style>
                    </CheckBox>

                    <ComboBox Grid.Column="2"
                              ItemsSource="{Binding EnumOptions}"
                              Text="{Binding Value, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                              IsEditable="True" FontSize="11" Height="22"
                              VerticalAlignment="Center">
                        <ComboBox.Style>
                            <Style TargetType="ComboBox">
                                <Setter Property="Visibility" Value="Collapsed"/>
                                <Style.Triggers>
                                    <DataTrigger Binding="{Binding IsEnumEditor}" Value="True">
                                        <Setter Property="Visibility" Value="Visible"/>
                                    </DataTrigger>
                                    <DataTrigger Binding="{Binding IsReadOnly}" Value="True">
                                        <Setter Property="IsEnabled" Value="False"/>
                                    </DataTrigger>
                                </Style.Triggers>
                            </Style>
                        </ComboBox.Style>
                    </ComboBox>

                    <TextBox Grid.Column="2"
                             Text="{Binding Value, Mode=TwoWay, UpdateSourceTrigger=LostFocus}"
                             IsReadOnly="{Binding IsReadOnly}"
                             FontSize="11" Padding="4,2" Height="22"
                             VerticalContentAlignment="Center"
                             BorderBrush="#CCCCCC" BorderThickness="1">
                        <TextBox.Style>
                            <Style TargetType="TextBox">
                                <Setter Property="Visibility" Value="Collapsed"/>
                                <Style.Triggers>
                                    <DataTrigger Binding="{Binding IsTextEditor}" Value="True">
                                        <Setter Property="Visibility" Value="Visible"/>
                                    </DataTrigger>
                                </Style.Triggers>
                            </Style>
                        </TextBox.Style>
                    </TextBox>
                </Grid>
            </Border>
        </DataTemplate>
    </UserControl.Resources>

    <DockPanel Background="{StaticResource SidebarBgBrush}">
        <Border DockPanel.Dock="Top" Style="{StaticResource IdeDockHeaderStyle}">
            <DockPanel>
                <TextBlock Text="PROPERTIES" FontSize="11" FontWeight="SemiBold"
                           Foreground="{StaticResource FgMutedBrush}" VerticalAlignment="Center"/>
                <TextBlock DockPanel.Dock="Right" Text="{Binding SelectedFieldName}"
                           FontSize="11" Foreground="{StaticResource PrimaryBrush}"
                           HorizontalAlignment="Right" VerticalAlignment="Center"
                           Margin="0,0,6,0"/>
            </DockPanel>
        </Border>

        <!-- Search + category + favorites -->
        <Border DockPanel.Dock="Top" Padding="6,4" Background="#F8F8F8"
                BorderBrush="{StaticResource IdeBorderBrush}" BorderThickness="0,0,0,1">
            <StackPanel>
                <Grid Margin="0,0,0,4">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="Auto"/>
                        <ColumnDefinition Width="*"/>
                    </Grid.ColumnDefinitions>
                    <md:PackIcon Kind="Magnify" Width="12" Height="12" Foreground="#888"
                                 VerticalAlignment="Center"/>
                    <TextBox Grid.Column="1" Margin="6,0,0,0"
                             Text="{Binding SearchText, UpdateSourceTrigger=PropertyChanged}"
                             BorderThickness="1" BorderBrush="#CCCEDB" Padding="4,2"
                             FontSize="11" Background="White"/>
                </Grid>
                <DockPanel>
                    <CheckBox DockPanel.Dock="Right" Content="★"
                              IsChecked="{Binding ShowFavoritesOnly}"
                              FontSize="11" VerticalAlignment="Center"
                              ToolTip="Chỉ hiện Favorite"/>
                    <ComboBox ItemsSource="{Binding Categories}"
                              SelectedItem="{Binding SelectedCategory}"
                              FontSize="11" Height="22"/>
                </DockPanel>
            </StackPanel>
        </Border>

        <TextBlock DockPanel.Dock="Top" Text="{Binding SelectionHint}"
                   Margin="10,8" FontSize="11" Foreground="{StaticResource FgMutedBrush}"
                   TextWrapping="Wrap">
            <TextBlock.Style>
                <Style TargetType="TextBlock">
                    <Setter Property="Visibility" Value="Collapsed"/>
                    <Style.Triggers>
                        <DataTrigger Binding="{Binding HasSelectedCell}" Value="False">
                            <Setter Property="Visibility" Value="Visible"/>
                        </DataTrigger>
                    </Style.Triggers>
                </Style>
            </TextBlock.Style>
        </TextBlock>

        <ScrollViewer VerticalScrollBarVisibility="Auto"
                      Visibility="{Binding HasSelectedCell, Converter={StaticResource BoolToVis}}">
            <ItemsControl ItemsSource="{Binding FilteredProperties}">
                <ItemsControl.GroupStyle>
                    <GroupStyle>
                        <GroupStyle.HeaderTemplate>
                            <DataTemplate>
                                <Border Background="#EEEEF2" Padding="8,3" Margin="0,4,0,0">
                                    <TextBlock Text="{Binding Name}" FontSize="10" FontWeight="SemiBold"
                                               Foreground="{StaticResource FgMutedBrush}"/>
                                </Border>
                            </DataTemplate>
                        </GroupStyle.HeaderTemplate>
                    </GroupStyle>
                </ItemsControl.GroupStyle>
            </ItemsControl>
        </ScrollViewer>
    </DockPanel>
</UserControl>
