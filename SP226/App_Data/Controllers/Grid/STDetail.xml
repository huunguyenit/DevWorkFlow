select @unitCode = case when @$ma_dvcs = '' then @@unit else @$ma_dvcs end
if exists(select 1 from dmkho where ma_kho = @ma_kho and ma_dvcs = @unitCode]]>&SiteCheck;<![CDATA[) begin
  select case when exists(select 1 from dmvitri where dmvitri.ma_kho = @ma_kho) then 1 else 0 end as vi_tri_yn
  return
end
]]>
