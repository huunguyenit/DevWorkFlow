<UserControl x:Class="UI.Views.Bottom.XmlBottomPanel"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:md="http://materialdesigninxaml.net/winfx/xaml/themes"
             xmlns:ctrl="clr-namespace:UI.Views.Controls"
             xmlns:vm="clr-namespace:UI.ViewModels.Bottom">

    <DockPanel Background="{StaticResource EditorBgBrush}" LastChildFill="True">
        <Border DockPanel.Dock="Top" Background="{StaticResource CodePaneHeaderBrush}"
                BorderBrush="{StaticResource IdeBorderBrush}" BorderThickness="0,0,0,1"
                Padding="8,4">
            <DockPanel>
                <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                    <md:PackIcon Kind="CodeTags" Width="14" Height="14"
                                 Foreground="{StaticResource PrimaryBrush}" VerticalAlignment="Center"/>
                    <TextBlock Text="{Binding Header}" FontSize="11" FontWeight="SemiBold"
                               Foreground="{StaticResource FgMutedBrush}"
                               Margin="6,0,0,0" VerticalAlignment="Center"/>
                    <TextBlock Text="{Binding EditorModeText, Mode=OneWay, StringFormat='  ·  {0}'}"
                               FontSize="11" Foreground="{StaticResource PrimaryBrush}"
                               VerticalAlignment="Center"/>
                    <TextBlock Text="  ·  Ctrl+F Find · Ctrl+H Replace · F12 Go to Definition"
                               FontSize="10" Foreground="{StaticResource FgMutedBrush}"
                               VerticalAlignment="Center" Margin="8,0,0,0"/>
                </StackPanel>
                <StackPanel DockPanel.Dock="Right" Orientation="Horizontal" HorizontalAlignment="Right">
                    <Button Content="{Binding EditorModeButtonText, Mode=OneWay}" FontSize="10" Padding="8,2"
                            ToolTip="Chuyển Source Mode / Insight Mode"
                            Command="{Binding ToggleInsightCommand}"
                            Style="{StaticResource IdeRibbonButtonStyle}"/>
                </StackPanel>
            </DockPanel>
        </Border>

        <TextBlock DockPanel.Dock="Top"
                   Text="Chưa có document XML. Mở file từ Explorer."
                   Margin="12" FontSize="12" Foreground="{StaticResource FgMutedBrush}"
                   HorizontalAlignment="Center" VerticalAlignment="Top"
                   TextWrapping="Wrap">
            <TextBlock.Style>
                <Style TargetType="TextBlock">
                    <Setter Property="Visibility" Value="Collapsed"/>
                    <Style.Triggers>
                        <DataTrigger Binding="{Binding HasDocument}" Value="False">
                            <Setter Property="Visibility" Value="Visible"/>
                        </DataTrigger>
                    </Style.Triggers>
                </Style>
            </TextBlock.Style>
        </TextBlock>

        <Border DockPanel.Dock="Top" Background="#F3E5F5" Padding="8,4"
                BorderBrush="#CE93D8" BorderThickness="0,0,0,1">
            <Border.Style>
                <Style TargetType="Border">
                    <Setter Property="Visibility" Value="Collapsed"/>
                    <Style.Triggers>
                        <DataTrigger Binding="{Binding ShowInsights}" Value="True">
                            <Setter Property="Visibility" Value="Visible"/>
                        </DataTrigger>
                    </Style.Triggers>
                </Style>
            </Border.Style>
            <TextBlock FontSize="11" Foreground="#4A148C" TextWrapping="Wrap"
                       Text="Insight Mode: reference Entity read-only; resolved value sửa inline. Insight là virtual rendering và không đổi XML source."/>
        </Border>

        <!-- Editor trái + Structure TreeView phải -->
        <Grid Visibility="{Binding HasDocument, Converter={StaticResource BoolToVisibilityConverter}}">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*" MinWidth="120"/>
                <ColumnDefinition Width="4"/>
                <ColumnDefinition Width="260" MinWidth="160"/>
            </Grid.ColumnDefinitions>

            <ctrl:BindableXmlEditor x:Name="XmlEditor"
                Grid.Column="0"
                HorizontalAlignment="Stretch"
                VerticalAlignment="Stretch"
                BoundText="{Binding EditorText, UpdateSourceTrigger=PropertyChanged, Mode=TwoWay}"
                IsReadOnly="{Binding IsEditorReadOnly}"
                ShowInsights="{Binding ShowInsights}"
                Insights="{Binding Insights}"
                InsightEditCommand="{Binding FormBuilder.UpdateEntityValueCommand}"
                ScrollToLine="{Binding CaretLine, Mode=OneWay}"
                ScrollToOffset="{Binding CaretOffset, Mode=OneWay}"/>

            <GridSplitter Grid.Column="1" Width="4" HorizontalAlignment="Stretch"
                          Background="{StaticResource IdeBorderBrush}"
                          ResizeBehavior="PreviousAndNext" ResizeDirection="Columns"/>

            <!-- Structure outline -->
            <Border Grid.Column="2"
                    Background="{StaticResource SidebarBgBrush}"
                    BorderBrush="{StaticResource IdeBorderBrush}"
                    BorderThickness="1,0,0,0"
                    DataContext="{Binding StructureOutline}">
                <DockPanel>
                    <Border DockPanel.Dock="Top" Padding="8,4"
                            Background="{StaticResource CodePaneHeaderBrush}"
                            BorderBrush="{StaticResource IdeBorderBrush}"
                            BorderThickness="0,0,0,1">
                        <DockPanel>
                            <md:PackIcon Kind="FileTreeOutline" Width="14" Height="14"
                                         Foreground="{StaticResource PrimaryBrush}"
                                         VerticalAlignment="Center"/>
                            <TextBlock Text="{Binding Header}" FontSize="11" FontWeight="SemiBold"
                                       Foreground="{StaticResource FgMutedBrush}"
                                       Margin="6,0,0,0" VerticalAlignment="Center"
                                       TextTrimming="CharacterEllipsis"/>
                            <Button DockPanel.Dock="Right"
                                    Command="{Binding RefreshCommand}"
                                    ToolTip="Refresh structure"
                                    Style="{StaticResource IdeRibbonButtonStyle}"
                                    Padding="4,2" MinWidth="24">
                                <md:PackIcon Kind="Refresh" Width="12" Height="12"/>
                            </Button>
                        </DockPanel>
                    </Border>

                    <TreeView ItemsSource="{Binding Roots}"
                              SelectedItemChanged="StructureTree_SelectedItemChanged"
                              Style="{StaticResource IdeTreeViewStyle}"
                              BorderThickness="0"
                              Background="Transparent"
                              Padding="2">
                        <TreeView.ItemContainerStyle>
                            <Style TargetType="TreeViewItem" BasedOn="{StaticResource IdeTreeViewItemStyle}">
                                <Setter Property="IsExpanded" Value="{Binding IsExpanded, Mode=TwoWay}"/>
                                <EventSetter Event="MouseDoubleClick" Handler="StructureItem_MouseDoubleClick"/>
                            </Style>
                        </TreeView.ItemContainerStyle>
                        <TreeView.ItemTemplate>
                            <HierarchicalDataTemplate DataType="{x:Type vm:XmlStructureNodeVm}"
                                                      ItemsSource="{Binding Children}">
                                <StackPanel Orientation="Horizontal" Margin="0,1"
                                            ToolTip="{Binding StartLine, StringFormat=Line {0}}">
                                    <md:PackIcon Kind="{Binding IconKind}" Width="14" Height="14"
                                                 Foreground="{StaticResource FgMutedBrush}"
                                                 VerticalAlignment="Center" Margin="0,0,6,0"/>
                                    <TextBlock Text="{Binding Display}" FontSize="11"
                                               Foreground="{StaticResource FgBrush}"
                                               VerticalAlignment="Center"
                                               TextTrimming="CharacterEllipsis"/>
                                </StackPanel>
                            </HierarchicalDataTemplate>
                        </TreeView.ItemTemplate>
                    </TreeView>
                </DockPanel>
            </Border>
        </Grid>
    </DockPanel>
</UserControl>
