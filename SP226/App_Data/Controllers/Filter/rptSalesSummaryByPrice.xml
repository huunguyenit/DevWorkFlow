    &XMLWhenFilterLoading;
    &XMLWhenFilterClosing;
    &XMLWhenFilterQuerying;
    <command event="Processing">
      <text>
        <![CDATA[
declare @c varchar(1024), @name1 nvarchar(1024), @name2 nvarchar(1024)
select @c = case @nh_theo when '0' then 'loai_vt' when '1' then 'nh_vt1' else '' end
if (@c = 'nh_vt1') and (cast(@tt_sx1 as tinyint) + cast(@tt_sx2 as tinyint) + cast(@tt_sx3 as tinyint) <> 0) begin
  set @c = @tt_sx1 + ',' + @tt_sx2 + ',' + @tt_sx3
  set @c = replace(replace(replace(@c, '1', 'nh_vt1'), '2', 'nh_vt2'), '3', 'nh_vt3')
  set @c = replace(replace(replace(@c, '0,', ''), ',0', ''), '0', '')
end

select @ngay_ct1 as date_from, @ngay_ct2 as date_to

exec rs_rptSalesSummaryByPrice @ngay_ct1, @ngay_ct2, @so_ct1, @so_ct2, @ma_kh, @ma_vt, @ma_kho, @ma_nvbh, @ma_vv,
  @ma_nx, @ma_bp, @ma_hd, @nh_vt1, @nh_vt2, @nh_vt3, @c, @tk_dt, @tk_vt, @ma_gd, @ds_ma_ct, @tinh_ps, @ma_dvcs, @maxLength,
  '2', 'ma_vt', @loai_du_lieu, @@language, @@userID, @@admin, @transactionList, ']]>&Identity;<![CDATA[', '@@sysDatabaseName', '#$query'
]]>
      </text>
    </command>

    <command event="Checking">
      <text>
        <![CDATA[/* <flatten type="Javascript"> */
var x = parseInt(this.getItemValue('tt_sx1')), y = parseInt(this.getItemValue('tt_sx2')), z = parseInt(this.getItemValue('tt_sx3'));
if ((x == y && x != 0) || (x == z && x != 0) || (y == z && y != 0)){
  this._checked = false;
  $func.hideWait(this.get_id());
  $message.show(String.format($df.getResources(this._language, 'Message.RequiredField'), this.getItem('tt_sx1').field.Label), String.format('$find(\'{0}\').focus(\'{1}\');', this.get_id(), 'tt_sx1'));
}
/* </flatten> */]]>
      </text>
    </command>
  </commands>

  <script>
    <text>
      &JavascriptReportFilter;
      &OutlineEntry;
      &ScriptQueryFilterString;
      &SetReportFormStockRight;
      <![CDATA[
function active$VoucherFilter$(f) {
  f.add_onResponseComplete(on$Filter$ResponseComplete);
  f._tabContainer.add_activeTabChanged(onChange$VoucherFilter$Tab);
  f._tabContainer._loaded = true;
  changeLookupReadonly(f, 'ma_dvcs');
  var o = f.getItem('maxLength');
  o.value = o.maxLength;]]>&FilterExpression;<![CDATA[
  onChange$GroupBy(f.getItem('nh_theo'));
}
/* <flatten type="Javascript"> */
function close$VoucherFilter$(sender) {
  try {sender.remove_onResponseComplete(on$Filter$ResponseComplete);} catch (ex) {}
  try {sender._tabContainer.remove_activeTabChanged(onChange$VoucherFilter$Tab);} catch (ex) {}
}
function on$Filter$ResponseComplete(sender, e) {
  var f = e.object, context = e.type.Context, result = e.type.Result;
  switch (context) {
    case 'Checking':
      var wile = $func.findMemvarIndex('transactionGrid', f._memvars);
      if (wile > -1) Array.removeAt(f._memvars, wile);
      var g = f.grid, d1 = f.getItem('ngay_ct1').value, d2 = f.getItem('ngay_ct2').value, s = f.getItemValue('ma_kho');
      g._hiddenFields = [{Fields: 'gia_nt2, tien_nt2', Value: (f.getItemValue('mau_bc')) == '10'}];
      if (s == '') s = f._language == 'v' ? ', Kho: tất cả kho' : ', Site: All Sites';
      else {
        var v = f.getItemValue('ten_kho%l');
        s = (f._language == 'v' ? ', Kho: ' : ', Site: ') + s;
        if (v != '') s += ' - ' + v;
      }
      g._alterTitle = [null, [['%d1', d1, true], ['%d2', d2, true], ['%s', s, true]]];
      g._queryFilterString = getQueryFilterString(f, 'ngay_ct1, ngay_ct2, so_ct1, so_ct2, maxLength, ma_kho, ma_nvbh, tk_vt, ma_nx, ma_vv, ma_bp, ma_hd, ma_dvcs, mau_bc, loai_du_lieu, tinh_ps, ma_gd, ds_ma_ct, ma_kh, tk_dt, transactionList');
      remove$GridReport$Filter(g);
      break;
    default:
      break;
  }
}
function onChange$VoucherFilter$Tab(sender, e) {sender.parentForm.focusWhenTabChanged(['ma_nvbh', 'nh_theo', ['transactionGrid'], 'ma_nx']);}
function onChange$GroupBy(o) {
  var f = o.parentForm, v = (f.getItemValue('nh_theo') == '1' ? false : true);
  f.getItem('tt_sx1').disabled = f.getItem('tt_sx3').disabled = f.getItem('tt_sx2').disabled = v;
  if (v) {
    f.setItemValue('tt_sx1', 0);
    f.setItemValue('tt_sx2', 0);
    f.setItemValue('tt_sx3', 0);
  }
}
/* </flatten> */
]]>
    </text>
  </script>

