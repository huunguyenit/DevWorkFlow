<UserControl x:Class="UI.Views.Bottom.ProblemsPanel"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:md="http://materialdesigninxaml.net/winfx/xaml/themes"
             xmlns:bottom="clr-namespace:UI.ViewModels.Bottom">

    <DockPanel Background="{StaticResource EditorBgBrush}">
        <Border DockPanel.Dock="Top" Background="{StaticResource CodePaneHeaderBrush}"
                Padding="8,3" BorderBrush="{StaticResource IdeBorderBrush}" BorderThickness="0,0,0,1">
            <DockPanel>
                <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                    <TextBlock Text="PROBLEMS" FontSize="11" FontWeight="SemiBold"
                               Foreground="{StaticResource FgMutedBrush}"/>
                    <Border Background="#FFEBEE" CornerRadius="2" Padding="4,0" Margin="8,0,0,0">
                        <TextBlock Text="{Binding ErrorCount, StringFormat=E {0}}" FontSize="10"
                                   Foreground="#C62828" FontWeight="SemiBold"/>
                    </Border>
                    <Border Background="#FFF8E1" CornerRadius="2" Padding="4,0" Margin="4,0,0,0">
                        <TextBlock Text="{Binding WarningCount, StringFormat=W {0}}" FontSize="10"
                                   Foreground="#F57F17" FontWeight="SemiBold"/>
                    </Border>
                    <Border Background="#E3F2FD" CornerRadius="2" Padding="4,0" Margin="4,0,0,0">
                        <TextBlock Text="{Binding HintCount, StringFormat=H {0}}" FontSize="10"
                                   Foreground="#1565C0" FontWeight="SemiBold"/>
                    </Border>
                </StackPanel>
                <Button DockPanel.Dock="Right" Content="Clear" FontSize="10" Padding="8,2"
                        Command="{Binding ClearProblemsCommand}"
                        Style="{StaticResource IdeToolButtonStyle}"
                        HorizontalAlignment="Right" Margin="0"/>
            </DockPanel>
        </Border>

        <DataGrid ItemsSource="{Binding Problems}"
                  Style="{StaticResource IdeDataGridStyle}"
                  CanUserDeleteRows="False"
                  IsReadOnly="True"
                  BorderThickness="0"
                  Background="Transparent"
                  FontSize="11"
                  RowHeight="26"
                  MouseDoubleClick="ProblemsGrid_MouseDoubleClick">
            <DataGrid.Columns>
                <DataGridTextColumn Header="" Binding="{Binding SeverityBadge}" Width="28"/>
                <DataGridTextColumn Header="Description" Binding="{Binding Description}" Width="*"/>
                <DataGridTextColumn Header="File" Binding="{Binding File}" Width="160"/>
                <DataGridTextColumn Header="Line" Binding="{Binding Line}" Width="48"/>
                <DataGridTextColumn Header="Col" Binding="{Binding Column}" Width="40"/>
                <DataGridTextColumn Header="Type" Binding="{Binding Type}" Width="72"/>
            </DataGrid.Columns>
        </DataGrid>
    </DockPanel>
</UserControl>
