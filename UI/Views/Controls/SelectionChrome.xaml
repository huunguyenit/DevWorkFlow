<UserControl x:Class="UI.Views.Controls.SelectionChrome"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             IsHitTestVisible="True">
    <Grid>
        <Border BorderBrush="#1565C0" BorderThickness="1.5" Background="#181565C0"
                IsHitTestVisible="False"/>

        <!-- 8 handles: NW N NE W E SW S SE — chỉ E kéo span -->
        <Ellipse Width="7" Height="7" Fill="White" Stroke="#1565C0" StrokeThickness="1"
                 HorizontalAlignment="Left" VerticalAlignment="Top" Margin="-3,-3,0,0"
                 IsHitTestVisible="False"/>
        <Ellipse Width="7" Height="7" Fill="White" Stroke="#1565C0" StrokeThickness="1"
                 HorizontalAlignment="Center" VerticalAlignment="Top" Margin="0,-3,0,0"
                 IsHitTestVisible="False"/>
        <Ellipse Width="7" Height="7" Fill="White" Stroke="#1565C0" StrokeThickness="1"
                 HorizontalAlignment="Right" VerticalAlignment="Top" Margin="0,-3,-3,0"
                 IsHitTestVisible="False"/>
        <Ellipse Width="7" Height="7" Fill="White" Stroke="#1565C0" StrokeThickness="1"
                 HorizontalAlignment="Left" VerticalAlignment="Center" Margin="-3,0,0,0"
                 IsHitTestVisible="False"/>
        <Thumb Width="8" Height="16" HorizontalAlignment="Right" VerticalAlignment="Center"
               Cursor="SizeWE" Margin="0,0,-4,0"
               DragStarted="East_DragStarted" DragDelta="East_DragDelta" DragCompleted="East_DragCompleted">
            <Thumb.Template>
                <ControlTemplate TargetType="Thumb">
                    <Border Background="#1565C0" CornerRadius="1" Opacity="0.85"/>
                </ControlTemplate>
            </Thumb.Template>
        </Thumb>
        <Ellipse Width="7" Height="7" Fill="White" Stroke="#1565C0" StrokeThickness="1"
                 HorizontalAlignment="Right" VerticalAlignment="Center" Margin="0,0,-3,0"
                 IsHitTestVisible="False"/>
        <Ellipse Width="7" Height="7" Fill="White" Stroke="#1565C0" StrokeThickness="1"
                 HorizontalAlignment="Left" VerticalAlignment="Bottom" Margin="-3,0,0,-3"
                 IsHitTestVisible="False"/>
        <Ellipse Width="7" Height="7" Fill="White" Stroke="#1565C0" StrokeThickness="1"
                 HorizontalAlignment="Center" VerticalAlignment="Bottom" Margin="0,0,0,-3"
                 IsHitTestVisible="False"/>
        <Ellipse Width="7" Height="7" Fill="White" Stroke="#1565C0" StrokeThickness="1"
                 HorizontalAlignment="Right" VerticalAlignment="Bottom" Margin="0,0,-3,-3"
                 IsHitTestVisible="False"/>
    </Grid>
</UserControl>
