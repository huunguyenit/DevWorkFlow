  <commands>
    <command event="Loading">
      <text>
        <![CDATA[
declare @message nvarchar(1024)
select @message = ''
]]>&GetReportFormLimitRight;<![CDATA[
select @message + 'active$VoucherFilter$(this);' as message
return
]]>
      </text>
    </command>
    &XMLWhenFilterClosing;
    &XMLWhenFilterQuerying;
    &XMLGetParameter;
    <command event="Processing">
      <text>
        <![CDATA[
declare @voucherList varchar(512)
select @voucherList = rtrim(parameter) from @@sysDatabaseName..wcommand where sysid = ']]>&Identity;<![CDATA['

select cast(@tu_ngay as smalldatetime) as tu_ngay, cast(@den_ngay as smalldatetime) as den_ngay
exec rs_rptReceiptTransactionList @tu_ngay, @den_ngay, @ma_vt, @ma_kh, @ma_kho, @kho_hang_dc, @ma_vv, @ma_nx, @tk_vt, @ma_loai_vt,
  @ma_nh, @ma_nh2, @ma_nh3, @ma_gd, @voucherList, @so_ct1, @so_ct2, @ma_hd, @ma_bp, @lenh_sx, @ma_sp, @ma_dvcs, @maxLength, @maxLength_mo, 1, 'a.ma_kh', @loai_du_lieu, @@language, @@userID, @@admin, @transactionList, ']]>&Controller;<![CDATA[', '@@sysDatabaseName', '#$query'
]]>
      </text>
    </command>
