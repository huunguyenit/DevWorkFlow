    <field name="thue_suat" type="Decimal" dataFormatString="@exchangeRateViewFormat" readOnly="true" width="0" hidden="true">
      <header v="Thuế suất giá trị gia tăng" e="VAT Rate"></header>
      <items style="Numeric"/>
    </field>
    <field name="tk_thue" width="0" readOnly="true" hidden="true" aliasName="a">
