<UserControl x:Class="UI.Views.Pages.FormBuilderPage"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:md="http://materialdesigninxaml.net/winfx/xaml/themes"
             xmlns:design="clr-namespace:UI.ViewModels.Design"
             xmlns:ctrl="clr-namespace:UI.Views.Controls"
             xmlns:lang="clr-namespace:DevWorkFlow.Domain.Language;assembly=DevWorkFlow.Domain">

    <UserControl.Resources>
        <BooleanToVisibilityConverter x:Key="BoolToVis"/>

        <!-- Cell: Label + key icon + required (*) đỏ -->
        <DataTemplate x:Key="CellLabelTemplate" DataType="{x:Type design:DesignCellVm}">
            <Grid Width="{Binding WidthDip}" MinHeight="22">
                <Border Padding="4,4" VerticalAlignment="Center"
                        Background="Transparent" Cursor="Hand"
                        PreviewMouseLeftButtonDown="Cell_PreviewMouseLeftButtonDown"
                        MouseLeftButtonDown="Cell_MouseLeftButtonDown">
                    <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                        <md:PackIcon Kind="KeyVariant" Width="12" Height="12" Margin="0,0,3,0"
                                     Foreground="#C9A227" VerticalAlignment="Center">
                            <md:PackIcon.Style>
                                <Style TargetType="md:PackIcon">
                                    <Setter Property="Visibility" Value="Collapsed"/>
                                    <Style.Triggers>
                                        <DataTrigger Binding="{Binding IsPrimaryKey}" Value="True">
                                            <Setter Property="Visibility" Value="Visible"/>
                                        </DataTrigger>
                                    </Style.Triggers>
                                </Style>
                            </md:PackIcon.Style>
                        </md:PackIcon>
                        <TextBlock Text="{Binding Text}"
                                   TextWrapping="NoWrap" TextTrimming="CharacterEllipsis"
                                   FontSize="12" Foreground="#222"
                                   VerticalAlignment="Center" MaxHeight="18"/>
                        <TextBlock Text=" *" FontSize="13" FontWeight="Bold" Foreground="#E53935"
                                   VerticalAlignment="Center" Margin="1,0,0,0">
                            <TextBlock.Style>
                                <Style TargetType="TextBlock">
                                    <Setter Property="Visibility" Value="Collapsed"/>
                                    <Style.Triggers>
                                        <DataTrigger Binding="{Binding IsRequired}" Value="True">
                                            <Setter Property="Visibility" Value="Visible"/>
                                        </DataTrigger>
                                    </Style.Triggers>
                                </Style>
                            </TextBlock.Style>
                        </TextBlock>
                    </StackPanel>
                </Border>
                <ctrl:SelectionChrome IsHitTestVisible="True"
                                     EastDragStarted="Chrome_EastDragStarted"
                                     EastDragDelta="Chrome_EastDragDelta"
                                     EastDragCompleted="Chrome_EastDragCompleted">
                    <ctrl:SelectionChrome.Style>
                        <Style TargetType="ctrl:SelectionChrome">
                            <Setter Property="Visibility" Value="Collapsed"/>
                            <Style.Triggers>
                                <DataTrigger Binding="{Binding IsSelected}" Value="True">
                                    <Setter Property="Visibility" Value="Visible"/>
                                </DataTrigger>
                            </Style.Triggers>
                        </Style>
                    </ctrl:SelectionChrome.Style>
                </ctrl:SelectionChrome>
            </Grid>
        </DataTemplate>

        <!-- Cell: Input — design textbox (không nhập liệu); click/enter → properties -->
        <DataTemplate x:Key="CellInputTemplate" DataType="{x:Type design:DesignCellVm}">
            <Grid Width="{Binding WidthDip}" MinHeight="22">
                <Border Padding="2,2" VerticalAlignment="Center"
                        MinHeight="22" Background="#01000000" Cursor="Hand"
                        PreviewMouseLeftButtonDown="Cell_PreviewMouseLeftButtonDown"
                        MouseLeftButtonDown="Cell_MouseLeftButtonDown">
                    <Grid Background="Transparent" IsHitTestVisible="True">
                        <CheckBox IsChecked="False" VerticalAlignment="Center" Margin="4,0"
                                  IsHitTestVisible="False">
                            <CheckBox.Style>
                                <Style TargetType="CheckBox">
                                    <Setter Property="Visibility" Value="Collapsed"/>
                                    <Style.Triggers>
                                        <DataTrigger Binding="{Binding IsCheckbox}" Value="True">
                                            <Setter Property="Visibility" Value="Visible"/>
                                        </DataTrigger>
                                    </Style.Triggers>
                                </Style>
                            </CheckBox.Style>
                        </CheckBox>
                        <ComboBox FontSize="12" VerticalAlignment="Center" Margin="2,0"
                                  IsHitTestVisible="False" Text="{Binding DropDownText}">
                            <ComboBox.Style>
                                <Style TargetType="ComboBox">
                                    <Setter Property="Visibility" Value="Collapsed"/>
                                    <Style.Triggers>
                                        <DataTrigger Binding="{Binding IsDropDownEditor}" Value="True">
                                            <Setter Property="Visibility" Value="Visible"/>
                                        </DataTrigger>
                                    </Style.Triggers>
                                </Style>
                            </ComboBox.Style>
                        </ComboBox>
                        <Border VerticalAlignment="Center" HorizontalAlignment="Stretch"
                                BorderBrush="#90A4AE" MinHeight="20">
                            <Border.Style>
                                <Style TargetType="Border">
                                    <Setter Property="Visibility" Value="Collapsed"/>
                                    <Setter Property="BorderThickness" Value="0,0,0,1"/>
                                    <Style.Triggers>
                                        <DataTrigger Binding="{Binding IsTextEditor}" Value="True">
                                            <Setter Property="Visibility" Value="Visible"/>
                                        </DataTrigger>
                                        <DataTrigger Binding="{Binding ShowInputBorder}" Value="False">
                                            <Setter Property="BorderThickness" Value="0"/>
                                        </DataTrigger>
                                    </Style.Triggers>
                                </Style>
                            </Border.Style>
                            <DockPanel LastChildFill="True">
                                <md:PackIcon DockPanel.Dock="Right" Kind="Magnify" Width="14" Height="14"
                                             Margin="3,0,2,1" VerticalAlignment="Center" Foreground="#1565C0">
                                    <md:PackIcon.Style>
                                        <Style TargetType="md:PackIcon">
                                            <Setter Property="Visibility" Value="Collapsed"/>
                                            <Style.Triggers>
                                                <DataTrigger Binding="{Binding ShowLookupIcon}" Value="True">
                                                    <Setter Property="Visibility" Value="Visible"/>
                                                </DataTrigger>
                                            </Style.Triggers>
                                        </Style>
                                    </md:PackIcon.Style>
                                </md:PackIcon>
                                <md:PackIcon DockPanel.Dock="Right" Kind="Calendar" Width="14" Height="14"
                                             Margin="3,0,1,1" VerticalAlignment="Center" Foreground="#C62828">
                                    <md:PackIcon.Style>
                                        <Style TargetType="md:PackIcon">
                                            <Setter Property="Visibility" Value="Collapsed"/>
                                            <Style.Triggers>
                                                <DataTrigger Binding="{Binding ShowDateIcon}" Value="True">
                                                    <Setter Property="Visibility" Value="Visible"/>
                                                </DataTrigger>
                                            </Style.Triggers>
                                        </Style>
                                    </md:PackIcon.Style>
                                </md:PackIcon>
                                <TextBox Text="{Binding Value}" IsReadOnly="True"
                                         IsHitTestVisible="False" Focusable="False"
                                         FontSize="12" Padding="2,1" Background="Transparent"
                                         BorderThickness="0"
                                         VerticalAlignment="Center" VerticalContentAlignment="Center"
                                         ToolTip="{Binding FormatHint}">
                                    <TextBox.Style>
                                        <Style TargetType="TextBox">
                                            <Setter Property="TextAlignment" Value="Left"/>
                                            <Style.Triggers>
                                                <DataTrigger Binding="{Binding TextAlign}" Value="Right">
                                                    <Setter Property="TextAlignment" Value="Right"/>
                                                </DataTrigger>
                                                <DataTrigger Binding="{Binding IsUpperCase}" Value="True">
                                                    <Setter Property="CharacterCasing" Value="Upper"/>
                                                </DataTrigger>
                                            </Style.Triggers>
                                        </Style>
                                    </TextBox.Style>
                                </TextBox>
                            </DockPanel>
                        </Border>
                    </Grid>
                </Border>
                <ctrl:SelectionChrome
                    EastDragStarted="Chrome_EastDragStarted"
                    EastDragDelta="Chrome_EastDragDelta"
                    EastDragCompleted="Chrome_EastDragCompleted">
                    <ctrl:SelectionChrome.Style>
                        <Style TargetType="ctrl:SelectionChrome">
                            <Setter Property="Visibility" Value="Collapsed"/>
                            <Style.Triggers>
                                <DataTrigger Binding="{Binding IsSelected}" Value="True">
                                    <Setter Property="Visibility" Value="Visible"/>
                                </DataTrigger>
                            </Style.Triggers>
                        </Style>
                    </ctrl:SelectionChrome.Style>
                </ctrl:SelectionChrome>
            </Grid>
        </DataTemplate>

        <!-- Cell: Description / Footer -->
        <DataTemplate x:Key="CellDescTemplate" DataType="{x:Type design:DesignCellVm}">
            <Border Width="{Binding WidthDip}" Padding="4,4" VerticalAlignment="Center">
                <TextBlock Text="{Binding Text}"
                           TextWrapping="NoWrap" TextTrimming="CharacterEllipsis"
                           FontSize="12" Foreground="#444"
                           VerticalAlignment="Center" MaxHeight="18"/>
            </Border>
        </DataTemplate>

        <DataTemplate x:Key="CellEmptyTemplate" DataType="{x:Type design:DesignCellVm}">
            <Border Width="{Binding WidthDip}" Height="24"/>
        </DataTemplate>

        <Style x:Key="DesignCellContentStyle" TargetType="ContentControl">
            <Setter Property="ContentTemplate" Value="{StaticResource CellEmptyTemplate}"/>
            <Style.Triggers>
                <DataTrigger Binding="{Binding IsLabel}" Value="True">
                    <Setter Property="ContentTemplate" Value="{StaticResource CellLabelTemplate}"/>
                </DataTrigger>
                <DataTrigger Binding="{Binding IsInput}" Value="True">
                    <Setter Property="ContentTemplate" Value="{StaticResource CellInputTemplate}"/>
                </DataTrigger>
                <DataTrigger Binding="{Binding IsDescription}" Value="True">
                    <Setter Property="ContentTemplate" Value="{StaticResource CellDescTemplate}"/>
                </DataTrigger>
            </Style.Triggers>
        </Style>

        <Style x:Key="EditorModeTabStyle" TargetType="Button" BasedOn="{StaticResource ActionButtonStyle}">
            <Setter Property="Height" Value="26"/>
            <Setter Property="Padding" Value="12,0"/>
            <Setter Property="Margin" Value="0,0,4,0"/>
            <Setter Property="FontSize" Value="11"/>
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="Foreground" Value="{StaticResource FgMutedBrush}"/>
            <Setter Property="BorderBrush" Value="{StaticResource IdeBorderBrush}"/>
            <Setter Property="BorderThickness" Value="1"/>
        </Style>

        <Style x:Key="EditorModeTabActiveStyle" TargetType="Button" BasedOn="{StaticResource EditorModeTabStyle}">
            <Setter Property="Background" Value="#E3F2FD"/>
            <Setter Property="Foreground" Value="#1565C0"/>
            <Setter Property="BorderBrush" Value="#1565C0"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
        </Style>

        <DataTemplate x:Key="FormRowItemTemplate" DataType="{x:Type design:DesignFormRowVm}">
            <StackPanel Orientation="Horizontal" Height="{Binding HeightDip}">
                <ItemsControl ItemsSource="{Binding Cells}">
                    <ItemsControl.ItemsPanel>
                        <ItemsPanelTemplate>
                            <StackPanel Orientation="Horizontal"/>
                        </ItemsPanelTemplate>
                    </ItemsControl.ItemsPanel>
                    <ItemsControl.ItemTemplate>
                        <DataTemplate DataType="{x:Type design:DesignCellVm}">
                            <ContentControl Content="{Binding}"
                                            Style="{StaticResource DesignCellContentStyle}"
                                            Background="Transparent"
                                            PreviewMouseLeftButtonDown="Cell_PreviewMouseLeftButtonDown"
                                            Cursor="Hand"/>
                        </DataTemplate>
                    </ItemsControl.ItemTemplate>
                </ItemsControl>
            </StackPanel>
        </DataTemplate>
    </UserControl.Resources>

    <Grid Background="{StaticResource WorkspaceBgBrush}">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*" MinHeight="180"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <!-- Toolbar -->
        <Border Grid.Row="0"
                Background="{StaticResource CodePaneHeaderBrush}"
                BorderBrush="{StaticResource IdeBorderBrush}"
                BorderThickness="0,0,0,1"
                Padding="12,8">
            <DockPanel>
                <StackPanel DockPanel.Dock="Left" Orientation="Horizontal">
                    <md:PackIcon Kind="Monitor" Width="16" Height="16"
                                 Foreground="{StaticResource PrimaryBrush}"
                                 VerticalAlignment="Center"/>
                    <TextBlock Text="{Binding LoadedTitle, FallbackValue='Design'}"
                               FontSize="14" FontWeight="SemiBold"
                               Foreground="{StaticResource FgBrightBrush}"
                               VerticalAlignment="Center" Margin="8,0,16,0"/>
                    <TextBlock Text="{Binding LoadedFilePath}"
                               FontSize="11" Foreground="{StaticResource FgMutedBrush}"
                               VerticalAlignment="Center" TextTrimming="CharacterEllipsis"
                               MaxWidth="480"
                               Visibility="{Binding LoadedFilePath, Converter={StaticResource NullOrEmptyToVisibilityConverter}}"/>
                </StackPanel>

                <StackPanel DockPanel.Dock="Right" Orientation="Horizontal" HorizontalAlignment="Right">
                    <Button Command="{Binding SetEditorModeCommand}"
                            CommandParameter="{x:Static lang:ErpEditorMode.Source}">
                        <Button.Style>
                            <Style TargetType="Button" BasedOn="{StaticResource EditorModeTabStyle}">
                                <Style.Triggers>
                                    <DataTrigger Binding="{Binding IsSourceMode}" Value="True">
                                        <Setter Property="Background" Value="#ECEFF1"/>
                                        <Setter Property="Foreground" Value="#37474F"/>
                                        <Setter Property="BorderBrush" Value="#78909C"/>
                                        <Setter Property="FontWeight" Value="SemiBold"/>
                                    </DataTrigger>
                                </Style.Triggers>
                            </Style>
                        </Button.Style>
                        <TextBlock Text="Source Mode"/>
                    </Button>
                    <Button Command="{Binding SetEditorModeCommand}"
                            CommandParameter="{x:Static lang:ErpEditorMode.Insight}">
                        <Button.Style>
                            <Style TargetType="Button" BasedOn="{StaticResource EditorModeTabStyle}">
                                <Style.Triggers>
                                    <DataTrigger Binding="{Binding IsInsightMode}" Value="True">
                                        <Setter Property="Background" Value="#E3F2FD"/>
                                        <Setter Property="Foreground" Value="#1565C0"/>
                                        <Setter Property="BorderBrush" Value="#1565C0"/>
                                        <Setter Property="FontWeight" Value="SemiBold"/>
                                    </DataTrigger>
                                </Style.Triggers>
                            </Style>
                        </Button.Style>
                        <StackPanel Orientation="Horizontal">
                            <md:PackIcon Kind="LightbulbOnOutline" Width="14" Height="14" VerticalAlignment="Center"/>
                            <TextBlock Text="Insight Mode" Margin="4,0,0,0"/>
                        </StackPanel>
                    </Button>
                    <Button Command="{Binding SetEditorModeCommand}"
                            CommandParameter="{x:Static lang:ErpEditorMode.Designer}"
                            Visibility="{Binding ShowDesignerTab, Converter={StaticResource BoolToVis}}">
                        <Button.Style>
                            <Style TargetType="Button" BasedOn="{StaticResource EditorModeTabStyle}">
                                <Style.Triggers>
                                    <DataTrigger Binding="{Binding IsDesignerMode}" Value="True">
                                        <Setter Property="Background" Value="#E8F5E9"/>
                                        <Setter Property="Foreground" Value="#2E7D32"/>
                                        <Setter Property="BorderBrush" Value="#66BB6A"/>
                                        <Setter Property="FontWeight" Value="SemiBold"/>
                                    </DataTrigger>
                                </Style.Triggers>
                            </Style>
                        </Button.Style>
                        <StackPanel Orientation="Horizontal">
                            <md:PackIcon Kind="Monitor" Width="14" Height="14" VerticalAlignment="Center"/>
                            <TextBlock Text="Designer Mode" Margin="4,0,0,0"/>
                        </StackPanel>
                    </Button>
                    <Border Width="1" Background="{StaticResource IdeBorderBrush}" Margin="8,2,8,2"/>
                    <Button Style="{StaticResource ActionButtonStyle}"
                            Content="Parse" Command="{Binding ParseCommand}" Margin="0,0,4,0"/>
                    <Button Style="{StaticResource ActionButtonStyle}"
                            Content="Lưu" Command="{Binding SaveCommand}"
                            Background="{StaticResource SuccessBrush}" Margin="0,0,4,0"/>
                    <Button Style="{StaticResource ActionButtonStyle}"
                            Content="Xoá" Command="{Binding ClearCommand}"
                            Background="#8A8A8A"/>
                </StackPanel>
            </DockPanel>
        </Border>

        <!-- Document center: Source / Insight / Designer -->
        <Grid Grid.Row="1">
            <!-- Source + Insight editor (3-column khi Insight) -->
            <ctrl:InsightEditorSurface
                Visibility="{Binding ShowEditorSurface, Converter={StaticResource BoolToVis}}"/>

            <!-- Designer Mode -->
            <Border Background="{StaticResource DesignSurfaceBrush}"
                    Visibility="{Binding ShowDesignerModeSurface, Converter={StaticResource BoolToVis}}">
            <DockPanel>
                <Border DockPanel.Dock="Top" Background="White"
                        BorderBrush="{StaticResource IdeBorderBrush}" BorderThickness="0,0,0,1"
                        Padding="10,6">
                    <DockPanel>
                        <StackPanel DockPanel.Dock="Left" Orientation="Horizontal">
                            <TextBlock Text="DESIGN" FontSize="11" FontWeight="Bold"
                                       Foreground="{StaticResource FgMutedBrush}"/>
                            <TextBlock Text="  ·  " Foreground="{StaticResource FgMutedBrush}"/>
                            <TextBlock Text="{Binding Design.Title, FallbackValue='(chưa parse)'}"
                                       FontSize="12" Foreground="{StaticResource FgBrush}"/>
                            <TextBlock Text="{Binding Document.DisplayKind, StringFormat='  [{0}]'}"
                                       FontSize="11" Foreground="{StaticResource PrimaryBrush}"
                                       Margin="8,0,0,0"/>
                            <TextBlock Text="{Binding Design.LayoutBadge, StringFormat='  ·  {0}'}"
                                       FontSize="11" Foreground="{StaticResource FgMutedBrush}"
                                       Margin="4,0,0,0"/>
                        </StackPanel>

                        <!-- Công cụ design góc phải -->
                        <StackPanel DockPanel.Dock="Right" Orientation="Horizontal"
                                    HorizontalAlignment="Right">
                            <Button Content="+ Cột" Height="24" Padding="8,0" Margin="0,0,6,0"
                                    ToolTip="Thêm một cột vào bảng"
                                    Command="{Binding AddColumnCommand}"
                                    Visibility="{Binding Design.IsForm, Converter={StaticResource BoolToVis}}"
                                    Style="{StaticResource ActionButtonStyle}"/>
                            <Button Content="◀ Tách" Height="24" Padding="8,0" Margin="0,0,4,0"
                                    ToolTip="Giảm span ô đang chọn (tách cột)"
                                    Command="{Binding DecreaseSpanCommand}"
                                    Visibility="{Binding Design.IsForm, Converter={StaticResource BoolToVis}}"
                                    Style="{StaticResource ActionButtonStyle}"/>
                            <Button Content="Gộp ▶" Height="24" Padding="8,0" Margin="0,0,6,0"
                                    ToolTip="Tăng span ô đang chọn (hợp nhất cột kiểu Excel)"
                                    Command="{Binding IncreaseSpanCommand}"
                                    Visibility="{Binding Design.IsForm, Converter={StaticResource BoolToVis}}"
                                    Style="{StaticResource ActionButtonStyle}"/>

                            <!-- Zoom / Grid (Bước 5) -->
                            <Border Width="1" Background="{StaticResource IdeBorderBrush}" Margin="4,4,8,4"/>
                            <Button Content="−" Width="28" Height="24" Padding="0" Margin="0,0,2,0"
                                    ToolTip="Zoom out (Ctrl+Wheel)"
                                    Command="{Binding Viewport.ZoomOutCommand}"
                                    Style="{StaticResource ActionButtonStyle}"/>
                            <Button Content="{Binding Viewport.ZoomText}" MinWidth="48" Height="24" Padding="6,0"
                                    Margin="0,0,2,0" ToolTip="Reset 100%"
                                    Command="{Binding Viewport.ZoomResetCommand}"
                                    Style="{StaticResource ActionButtonStyle}"/>
                            <Button Content="+" Width="28" Height="24" Padding="0" Margin="0,0,6,0"
                                    ToolTip="Zoom in (Ctrl+Wheel)"
                                    Command="{Binding Viewport.ZoomInCommand}"
                                    Style="{StaticResource ActionButtonStyle}"/>
                            <Button Height="24" Padding="8,0" Margin="0,0,6,0"
                                    ToolTip="Bật/tắt lưới chấm"
                                    Command="{Binding Viewport.ToggleGridCommand}"
                                    Style="{StaticResource ActionButtonStyle}">
                                <StackPanel Orientation="Horizontal">
                                    <md:PackIcon Kind="Grid" Width="14" Height="14" VerticalAlignment="Center"/>
                                    <TextBlock Text="Grid" Margin="4,0,0,0" FontSize="11" VerticalAlignment="Center"/>
                                </StackPanel>
                            </Button>
                            <Button Height="24" Padding="8,0" Margin="0,0,4,0"
                                    ToolTip="Snap To Grid (click để bật/tắt)"
                                    Command="{Binding Viewport.ToggleSnapCommand}"
                                    Style="{StaticResource ActionButtonStyle}">
                                <TextBlock Text="{Binding Viewport.SnapStatusText}" FontSize="11"/>
                            </Button>
                            <Button Content="Size" Height="24" Padding="6,0" Margin="0,0,6,0"
                                    ToolTip="Đổi bước snap: 2/4/5/8/10 px"
                                    Command="{Binding Viewport.CycleSnapSizeCommand}"
                                    Style="{StaticResource ActionButtonStyle}"/>
                            <Button Height="24" Padding="8,0" Margin="0,0,4,0"
                                    ToolTip="Hiện/ẩn guideline (kéo từ thước)"
                                    Command="{Binding Viewport.ToggleGuidelinesCommand}"
                                    Style="{StaticResource ActionButtonStyle}">
                                <StackPanel Orientation="Horizontal">
                                    <md:PackIcon Kind="Ruler" Width="14" Height="14" VerticalAlignment="Center"/>
                                    <TextBlock Text="Guides" Margin="4,0,0,0" FontSize="11" VerticalAlignment="Center"/>
                                </StackPanel>
                            </Button>
                            <Button Content="Clear" Height="24" Padding="6,0" Margin="0,0,6,0"
                                    ToolTip="Xóa mọi guideline"
                                    Command="{Binding Viewport.ClearGuidelinesCommand}"
                                    Style="{StaticResource ActionButtonStyle}"/>
                            <TextBlock Text="{Binding SelectionCountText}" FontSize="11"
                                       Foreground="{StaticResource PrimaryBrush}"
                                       VerticalAlignment="Center" Margin="0,0,8,0"/>

                            <Button Command="{Binding ToggleLanguageCommand}"
                                    ToolTip="{Binding LanguageTooltip}"
                                    Width="36" Height="24" Padding="0"
                                    Cursor="Hand">
                                <Button.Style>
                                    <Style TargetType="Button" BasedOn="{StaticResource ActionButtonStyle}">
                                        <Setter Property="Background" Value="#1565C0"/>
                                        <Setter Property="Foreground" Value="White"/>
                                        <Setter Property="FontWeight" Value="Bold"/>
                                        <Setter Property="FontSize" Value="12"/>
                                    </Style>
                                </Button.Style>
                                <TextBlock Text="{Binding LanguageCode}" HorizontalAlignment="Center"/>
                            </Button>
                        </StackPanel>
                    </DockPanel>
                </Border>

                <ctrl:DesignViewport
                    Zoom="{Binding Viewport.Zoom, Mode=TwoWay}"
                    ShowGrid="{Binding Viewport.ShowGrid}"
                    GridSizePx="{Binding Viewport.GridSizePx}"
                    ScrollOffsetX="{Binding Viewport.ScrollOffsetX, Mode=TwoWay}"
                    ScrollOffsetY="{Binding Viewport.ScrollOffsetY, Mode=TwoWay}"
                    ShowGuidelines="{Binding Viewport.ShowGuidelines}"
                    Guidelines="{Binding Viewport.Guidelines}"
                    ActiveGuideXs="{Binding Viewport.ActiveGuideXs}"
                    ActiveGuideYs="{Binding Viewport.ActiveGuideYs}"
                    SizeBadgeText="{Binding Viewport.SizeBadgeText}"
                    MouseMarkerX="{Binding Viewport.MouseContentX, Mode=TwoWay}"
                    MouseMarkerY="{Binding Viewport.MouseContentY, Mode=TwoWay}"
                    SelectionMarkerX="{Binding Viewport.SelectionMarkerX}"
                    SelectionMarkerY="{Binding Viewport.SelectionMarkerY}"
                    SnapEnabled="{Binding Viewport.SnapEnabled}"
                    SnapSizePx="{Binding Viewport.SnapSizePx}">
                        <Grid>
                            <!-- FORM -->
                            <Border HorizontalAlignment="Left" VerticalAlignment="Top"
                                    Background="#E8F1FA" BorderBrush="#7BA3C9" BorderThickness="1"
                                    Visibility="{Binding Design.IsForm, Converter={StaticResource BoolToVis}}">
                                <DockPanel LastChildFill="True">
                                    <Border DockPanel.Dock="Top" Background="#B8D0E8" Padding="10,7">
                                        <TextBlock Text="{Binding Design.Title}" FontWeight="SemiBold" FontSize="13"
                                                   Foreground="#1A1A1A"/>
                                    </Border>

                                    <StackPanel Margin="10">
                                        <!-- Vùng trên: ColumnGuides + dòng -->
                                        <Grid Width="{Binding Design.FormTableWidthDip}"
                                              HorizontalAlignment="Left" VerticalAlignment="Top">
                                            <ctrl:ColumnGuides Ticks="{Binding Design.RulerTicks}"
                                                               TopInset="0"/>
                                            <ItemsControl ItemsSource="{Binding Design.FormRows}"
                                                          ItemTemplate="{StaticResource FormRowItemTemplate}"/>
                                        </Grid>

                                        <!-- Vùng tab: categoryIndex = n — height cố định theo view/@height -->
                                        <Border Margin="0,10,0,0" BorderBrush="#7BA3C9" BorderThickness="1"
                                                Background="#E8F1FA"
                                                Visibility="{Binding Design.HasCategories, Converter={StaticResource BoolToVis}}">
                                            <DockPanel>
                                                <ItemsControl DockPanel.Dock="Top"
                                                              ItemsSource="{Binding Design.CategoryTabs}"
                                                              Background="#E8F1FA">
                                                    <ItemsControl.ItemsPanel>
                                                        <ItemsPanelTemplate>
                                                            <StackPanel Orientation="Horizontal"/>
                                                        </ItemsPanelTemplate>
                                                    </ItemsControl.ItemsPanel>
                                                    <ItemsControl.ItemTemplate>
                                                        <DataTemplate DataType="{x:Type design:DesignCategoryTabVm}">
                                                            <Button Content="{Binding Header}"
                                                                    Command="{Binding DataContext.SelectCategoryCommand, RelativeSource={RelativeSource AncestorType=UserControl}}"
                                                                    CommandParameter="{Binding}"
                                                                    Padding="12,6" Margin="0,0,1,0" Cursor="Hand"
                                                                    BorderThickness="0,0,0,2" FontSize="12">
                                                                <Button.Style>
                                                                    <Style TargetType="Button">
                                                                        <Setter Property="Background" Value="#D3E0EE"/>
                                                                        <Setter Property="Foreground" Value="#333"/>
                                                                        <Setter Property="BorderBrush" Value="Transparent"/>
                                                                        <Style.Triggers>
                                                                            <DataTrigger Binding="{Binding IsSelected}" Value="True">
                                                                                <Setter Property="Background" Value="#E8F1FA"/>
                                                                                <Setter Property="Foreground" Value="#1565C0"/>
                                                                                <Setter Property="BorderBrush" Value="#1565C0"/>
                                                                                <Setter Property="FontWeight" Value="SemiBold"/>
                                                                            </DataTrigger>
                                                                        </Style.Triggers>
                                                                    </Style>
                                                                </Button.Style>
                                                            </Button>
                                                        </DataTemplate>
                                                    </ItemsControl.ItemTemplate>
                                                </ItemsControl>

                                                <!-- Nội dung tab: BG trùng form; height cố định = view/@height cho mọi tab -->
                                                <Border Background="#E8F1FA"
                                                        Height="{Binding Design.CategoryContentHeightDip}">
                                                    <ScrollViewer VerticalScrollBarVisibility="Auto"
                                                                  HorizontalScrollBarVisibility="Disabled"
                                                                  Background="#E8F1FA"
                                                                  Padding="8,8,8,8">
                                                        <Grid Background="#E8F1FA"
                                                              DataContext="{Binding Design.SelectedCategory}"
                                                              Width="{Binding FormTableWidthDip}"
                                                              HorizontalAlignment="Left">
                                                            <ctrl:ColumnGuides Ticks="{Binding RulerTicks}"
                                                                               TopInset="0"/>
                                                            <ItemsControl ItemsSource="{Binding Rows}"
                                                                          ItemTemplate="{StaticResource FormRowItemTemplate}"
                                                                          Background="Transparent"/>
                                                        </Grid>
                                                    </ScrollViewer>
                                                </Border>
                                            </DockPanel>
                                        </Border>

                                        <!-- Vùng dưới: categoryIndex = -1 -->
                                        <Grid Margin="0,10,0,0"
                                              Width="{Binding Design.FormTableWidthDip}"
                                              HorizontalAlignment="Left"
                                              Visibility="{Binding Design.HasBottomRows, Converter={StaticResource BoolToVis}}">
                                            <ctrl:ColumnGuides Ticks="{Binding Design.RulerTicks}"/>
                                            <ItemsControl ItemsSource="{Binding Design.BottomRows}"
                                                          ItemTemplate="{StaticResource FormRowItemTemplate}"/>
                                        </Grid>
                                    </StackPanel>
                                </DockPanel>
                            </Border>

                            <!-- GRID -->
                            <Border Background="White" BorderBrush="{StaticResource IdeBorderBrush}"
                                BorderThickness="1" MinWidth="480"
                                HorizontalAlignment="Left" VerticalAlignment="Top"
                                Visibility="{Binding Design.IsGrid, Converter={StaticResource BoolToVis}}">
                            <DockPanel>
                                <StackPanel DockPanel.Dock="Top" Margin="12,10,12,4">
                                    <TextBlock Text="{Binding Design.Title}" FontSize="16" FontWeight="SemiBold"/>
                                    <TextBlock Text="{Binding Design.SubTitle}" FontSize="12"
                                               Foreground="{StaticResource FgMutedBrush}" Margin="0,2,0,8"/>
                                    <ItemsControl ItemsSource="{Binding Design.ToolbarItems}">
                                        <ItemsControl.ItemsPanel>
                                            <ItemsPanelTemplate>
                                                <WrapPanel/>
                                            </ItemsPanelTemplate>
                                        </ItemsControl.ItemsPanel>
                                        <ItemsControl.ItemTemplate>
                                            <DataTemplate>
                                                <Border Margin="0,0,10,6">
                                                    <Border.Style>
                                                        <Style TargetType="Border">
                                                            <Style.Triggers>
                                                                <DataTrigger Binding="{Binding IsSeparator}" Value="True">
                                                                    <Setter Property="Width" Value="12"/>
                                                                    <Setter Property="Background" Value="Transparent"/>
                                                                </DataTrigger>
                                                            </Style.Triggers>
                                                        </Style>
                                                    </Border.Style>
                                                    <TextBlock Text="{Binding Title}" FontSize="12"
                                                               Foreground="{StaticResource PrimaryBrush}"
                                                               Visibility="{Binding IsSeparator, Converter={StaticResource BoolToVis}, ConverterParameter=Inverse}">
                                                        <TextBlock.Style>
                                                            <Style TargetType="TextBlock">
                                                                <Style.Triggers>
                                                                    <DataTrigger Binding="{Binding IsSeparator}" Value="True">
                                                                        <Setter Property="Visibility" Value="Collapsed"/>
                                                                    </DataTrigger>
                                                                </Style.Triggers>
                                                            </Style>
                                                        </TextBlock.Style>
                                                    </TextBlock>
                                                </Border>
                                            </DataTemplate>
                                        </ItemsControl.ItemTemplate>
                                    </ItemsControl>
                                    <TextBlock Text="Xem 1-3/3 bản ghi | Làm mới" FontSize="11"
                                               Foreground="{StaticResource FgMutedBrush}" Margin="0,4,0,6"/>
                                </StackPanel>

                                <!-- Header columns -->
                                <Border DockPanel.Dock="Top" Background="#E3F2FD"
                                        BorderBrush="#90CAF9" BorderThickness="0,1,0,1" Padding="0,6">
                                    <ItemsControl ItemsSource="{Binding Design.Columns}">
                                        <ItemsControl.ItemsPanel>
                                            <ItemsPanelTemplate>
                                                <StackPanel Orientation="Horizontal"/>
                                            </ItemsPanelTemplate>
                                        </ItemsControl.ItemsPanel>
                                        <ItemsControl.ItemTemplate>
                                            <DataTemplate>
                                                <StackPanel Orientation="Horizontal" Width="{Binding WidthDip}" Margin="8,0">
                                                    <md:PackIcon Kind="KeyVariant" Width="11" Height="11" Margin="0,0,3,0"
                                                                 Foreground="#C9A227" VerticalAlignment="Center">
                                                        <md:PackIcon.Style>
                                                            <Style TargetType="md:PackIcon">
                                                                <Setter Property="Visibility" Value="Collapsed"/>
                                                                <Style.Triggers>
                                                                    <DataTrigger Binding="{Binding IsPrimaryKey}" Value="True">
                                                                        <Setter Property="Visibility" Value="Visible"/>
                                                                    </DataTrigger>
                                                                </Style.Triggers>
                                                            </Style>
                                                        </md:PackIcon.Style>
                                                    </md:PackIcon>
                                                    <TextBlock Text="{Binding Header}"
                                                               FontWeight="SemiBold" FontSize="12"
                                                               TextTrimming="CharacterEllipsis"/>
                                                </StackPanel>
                                            </DataTemplate>
                                        </ItemsControl.ItemTemplate>
                                    </ItemsControl>
                                </Border>

                                <ItemsControl ItemsSource="{Binding Design.SampleRows}" Margin="0,0,0,8">
                                    <ItemsControl.ItemTemplate>
                                        <DataTemplate>
                                            <Border BorderBrush="#EEEEEE" BorderThickness="0,0,0,1" Padding="0,5"
                                                    Background="White">
                                                <ItemsControl ItemsSource="{Binding Values}">
                                                    <ItemsControl.ItemsPanel>
                                                        <ItemsPanelTemplate>
                                                            <StackPanel Orientation="Horizontal"/>
                                                        </ItemsPanelTemplate>
                                                    </ItemsControl.ItemsPanel>
                                                    <ItemsControl.ItemTemplate>
                                                        <DataTemplate>
                                                            <TextBlock Text="{Binding}" Width="140" Margin="8,0"
                                                                       FontSize="12" Foreground="#1565C0"
                                                                       TextTrimming="CharacterEllipsis"/>
                                                        </DataTemplate>
                                                    </ItemsControl.ItemTemplate>
                                                </ItemsControl>
                                            </Border>
                                        </DataTemplate>
                                    </ItemsControl.ItemTemplate>
                                </ItemsControl>
                            </DockPanel>
                        </Border>

                        <!-- LOOKUP -->
                        <Border MaxWidth="560" HorizontalAlignment="Left" VerticalAlignment="Top"
                                Background="White" BorderBrush="{StaticResource IdeBorderBrush}"
                                BorderThickness="1"
                                Visibility="{Binding Design.IsLookup, Converter={StaticResource BoolToVis}}">
                            <DockPanel>
                                <Border DockPanel.Dock="Top" Background="#F5F5F5" Padding="10,6"
                                        BorderBrush="{StaticResource IdeBorderBrush}" BorderThickness="0,0,0,1">
                                    <DockPanel>
                                        <TextBlock Text="{Binding Design.Title}" FontWeight="SemiBold"
                                                   FontSize="13" VerticalAlignment="Center"/>
                                        <TextBlock DockPanel.Dock="Right" Text="✕  Đóng"
                                                   Foreground="{StaticResource FgMutedBrush}"
                                                   HorizontalAlignment="Right" FontSize="12"/>
                                    </DockPanel>
                                </Border>

                                <Border DockPanel.Dock="Top" Padding="10,8">
                                    <StackPanel>
                                        <StackPanel Orientation="Horizontal">
                                            <TextBox Width="200" Text="Tìm nhanh" FontSize="12"
                                                     Padding="6,4" BorderBrush="{StaticResource IdeBorderBrush}"
                                                     BorderThickness="1"/>
                                            <md:PackIcon Kind="Magnify" Width="18" Height="18" Margin="8,0"
                                                         Foreground="{StaticResource PrimaryBrush}"
                                                         VerticalAlignment="Center"/>
                                            <TextBlock Text="Chọn:" VerticalAlignment="Center" Margin="12,0,6,0" FontSize="12"/>
                                            <Border BorderBrush="{StaticResource PrimaryBrush}" BorderThickness="1"
                                                    Padding="8,3" Background="#E3F2FD">
                                                <TextBlock Text="{Binding Design.SearchFieldLabel}" FontSize="12"
                                                           Foreground="{StaticResource PrimaryBrush}"/>
                                            </Border>
                                        </StackPanel>
                                    </StackPanel>
                                </Border>

                                <Border DockPanel.Dock="Top" Background="#E3F2FD" Padding="0,6">
                                    <ItemsControl ItemsSource="{Binding Design.Columns}">
                                        <ItemsControl.ItemsPanel>
                                            <ItemsPanelTemplate>
                                                <StackPanel Orientation="Horizontal"/>
                                            </ItemsPanelTemplate>
                                        </ItemsControl.ItemsPanel>
                                        <ItemsControl.ItemTemplate>
                                            <DataTemplate>
                                                <TextBlock Text="{Binding Header}" Width="{Binding Width}"
                                                           FontWeight="SemiBold" FontSize="12" Margin="8,0"/>
                                            </DataTemplate>
                                        </ItemsControl.ItemTemplate>
                                    </ItemsControl>
                                </Border>

                                <TextBlock DockPanel.Dock="Bottom" Margin="10,6"
                                           Text="Xem 1-3/3 bản ghi | Làm mới"
                                           FontSize="11" Foreground="{StaticResource FgMutedBrush}"/>

                                <ItemsControl ItemsSource="{Binding Design.SampleRows}">
                                    <ItemsControl.ItemTemplate>
                                        <DataTemplate>
                                            <Border BorderBrush="#EEEEEE" BorderThickness="0,0,0,1" Padding="0,5">
                                                <ItemsControl ItemsSource="{Binding Values}">
                                                    <ItemsControl.ItemsPanel>
                                                        <ItemsPanelTemplate>
                                                            <StackPanel Orientation="Horizontal"/>
                                                        </ItemsPanelTemplate>
                                                    </ItemsControl.ItemsPanel>
                                                    <ItemsControl.ItemTemplate>
                                                        <DataTemplate>
                                                            <TextBlock Text="{Binding}" Width="160" Margin="8,0"
                                                                       FontSize="12" Foreground="#1565C0"/>
                                                        </DataTemplate>
                                                    </ItemsControl.ItemTemplate>
                                                </ItemsControl>
                                            </Border>
                                        </DataTemplate>
                                    </ItemsControl.ItemTemplate>
                                </ItemsControl>
                            </DockPanel>
                        </Border>
                        </Grid>
                </ctrl:DesignViewport>
            </DockPanel>
            </Border>
        </Grid>

        <!-- XML source đã chuyển sang Bottom dock IDE (Bước 4) -->

        <Border Grid.Row="2" Background="{StaticResource CodePaneHeaderBrush}"
                BorderBrush="{StaticResource IdeBorderBrush}" BorderThickness="0,1,0,0"
                Padding="12,4">
            <TextBlock Text="{Binding StatusMessage}" FontSize="11"
                       Foreground="{StaticResource FgMutedBrush}" TextTrimming="CharacterEllipsis"/>
        </Border>

    </Grid>
</UserControl>
