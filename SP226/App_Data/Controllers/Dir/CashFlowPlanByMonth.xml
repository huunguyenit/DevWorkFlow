  <script>
    <text>
      <![CDATA[
function initForm(f) {
  $get("baseCurrencyID").innerHTML = f._baseCurrency;
  f._controlFocus = f.getItem('ma_bp');
}
function activeForm(f) {
  setFormDefaultValue(f);
  f.add_onResponseComplete(on$Form$ResponseComplete);    
  onChange$CashFlowPlanByMonth$Dir$Handlers(f, true);
  f._tabContainer.add_activeTabChanged(onTabChanged);
  f._tabContainer._loaded = true;
}
function scatterForm(f) {setFormDefaultValue(f);}
function closeForm(f) {
  if (f._tabContainer) try {f._tabContainer.remove_activeTabChanged(onTabChanged);} catch (ex) {}
  try {onChange$CashFlowPlanByMonth$Dir$Handlers(f, false);} catch (ex) {}
  try {f.remove_onResponseComplete(on$Form$ResponseComplete);} catch (ex) {}
}
function setFormDefaultValue(f) {
  if (f._action == 'New') {
    var d = new Date(f.grid._year.toString());
    f.setItemValues('nam, ma_dvcs', [f.grid._year, f._unitCode]);
    f.getItem('ten_dvcs%l').value = f._unitName;
  }
}
function onTabChanged(sender, e) {sender.parentForm.focusWhenTabChanged(['tien_nt01', 'tien_nt04', 'tien_nt07', 'tien_nt10']);}
function onChange$CashFlowPlanByMonth$Dir$Handlers(f, type) {
  for (var i = 1; i <= 12; i++) {
    var c = $func.numberFormat(i, '00');
    if (type) {
      $addHandler(f.getItem('tien' + c), 'change', on$ObjectBaseCurrencyCashFlowPlanByMonth$DirChange);
      $addHandler(f.getItem('tien_nt' + c), 'change', on$ObjectForeignCurrencyCashFlowPlanByMonth$DirChange);
    }
    else {
      $removeHandler(f.getItem('tien_nt' + c), 'change', on$ObjectForeignCurrencyCashFlowPlanByMonth$DirChange);
      $removeHandler(f.getItem('tien' + c), 'change', on$ObjectBaseCurrencyCashFlowPlanByMonth$DirChange);
    }
  }
}
function on$ObjectBaseCurrencyCashFlowPlanByMonth$DirChange(e) {on$ObjectCurrencyCashFlowPlanByMonth$DirChange(e.target.parentForm, true);}
function on$ObjectForeignCurrencyCashFlowPlanByMonth$DirChange(e) {on$ObjectCurrencyCashFlowPlanByMonth$DirChange(e.target.parentForm, false);}
function on$ObjectCurrencyCashFlowPlanByMonth$DirChange(f, type) {
  var e = (type ? '[t_tien]:=' : '[t_tien_nt]:=');
  for (var i = 1; i <= 12; i++) {e+= '[' + (type ? 'tien' : 'tien_nt') + $func.numberFormat(i, '00') + ']' + (i == 12 ? '' : '+');}
  f.executeExpression([e]);
}
function on$Form$ResponseComplete(sender, e) {
  var f = e.object, context = e.type.Context, result = e.type.Result;
  switch (context) {
    case 'Loading':
      break;
    case 'Scattering':
      setFormDefaultValue(f);
      break;
    default:
      break;
  }
}
]]>
    </text>
  </script>

