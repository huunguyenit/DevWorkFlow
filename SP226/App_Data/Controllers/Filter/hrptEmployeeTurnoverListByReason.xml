    <command event="Processing">
      <text>
        <![CDATA[
select @ngay_nghi_tu as ngay_nghi_tu, @ngay_nghi_den as ngay_nghi_den
exec hs_rptEmployeeTurnoverListByReasons @tu_ngay, @den_ngay, @ma_bp, @nh_bp1, @nh_bp2, @nh_bp3 , @nh_nv1, @nh_nv2, @nh_nv3
  , @ma_vtr, @nh_vtr1, @nh_vtr2, @nh_vtr3, @ma_bac, @gioi_tinh, @loai, @ly_do, @ngay_nghi_tu, @ngay_nghi_den, @@language, @@userID, @@admin, '@@sysDatabaseName'
]]>
      </text>
    </command>
  </commands>

  <script>
    <text>
      &OutlineEntry;
      <![CDATA[/* <flatten type="Javascript"> */
function active$VoucherFilter$(f) {
  f.add_onResponseComplete(on$Filter$ResponseComplete);
  if (!f.getItemValue('den_ngay')) f.setItemValue('den_ngay', new Date());
  if (!f.getItemValue('ngay_nghi_den')) f.setItemValue('ngay_nghi_den', new Date());
}
function close$VoucherFilter$(f) {try {f.remove_onResponseComplete(on$Filter$ResponseComplete);} catch (ex) {}}
function on$Filter$ResponseComplete(sender, e) {
  var f = e.object, context = e.type.Context, result = e.type.Result;
  switch (context) {
    case 'Checking':
      var g = f.grid, s = '', d1 = f.getItem('ngay_nghi_tu').value, d2 = f.getItem('ngay_nghi_den').value, v1 = f.getItemValue('ngay_nghi_tu'), v2 = f.getItemValue('ngay_nghi_den');
      if (v1 == null && v2 != null) s = f._language == 'v' ? ('Ngày nghỉ đến: ' + d2) : ('Date of Leaving to: ' + d2);
      else if (v1 != null && v2 == null) s = f._language == 'v' ? ('Ngày nghỉ từ ngày: ' + d1) : ('Date of Leaving from: ' + d1);
      else s = f._language == 'v' ? ('Ngày nghỉ từ ' + d1 + ' đến ngày ' + d2) : ('Date of Leaving from ' + d1 + ' to ' + d2);
      g._alterTitle = [null, [['%s', s, true]]];
      break;
    default:
      break;
  }
}
/* </flatten> */]]>
    </text>
  </script>

  &OutlineCss;
