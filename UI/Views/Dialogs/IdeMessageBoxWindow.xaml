<Window x:Class="UI.Views.Dialogs.IdeMessageBoxWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:md="http://materialdesigninxaml.net/winfx/xaml/themes"
        Title="{Binding TitleText}"
        Width="480" MinWidth="360" MinHeight="180"
        SizeToContent="Height"
        ResizeMode="NoResize"
        ShowInTaskbar="False"
        WindowStyle="SingleBorderWindow"
        Background="White"
        SnapsToDevicePixels="True"
        UseLayoutRounding="True"
        TextOptions.TextFormattingMode="Display"
        TextOptions.TextRenderingMode="ClearType"
        KeyDown="Window_KeyDown">

    <Window.Resources>
        <BooleanToVisibilityConverter x:Key="BoolToVis"/>
    </Window.Resources>

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <Border Grid.Row="0"
                Background="{Binding HeaderBrush}"
                Padding="16,12">
            <DockPanel>
                <md:PackIcon DockPanel.Dock="Left"
                             Kind="{Binding IconKind}"
                             Width="22" Height="22"
                             Foreground="{Binding AccentBrush}"
                             VerticalAlignment="Center"
                             Margin="0,0,10,0"/>
                <TextBlock Text="{Binding TitleText}"
                           FontSize="15"
                           FontWeight="SemiBold"
                           Foreground="#24292F"
                           VerticalAlignment="Center"/>
            </DockPanel>
        </Border>

        <TextBox Grid.Row="1"
                 Margin="18,14,18,8"
                 MaxHeight="280"
                 Text="{Binding MessageText, Mode=OneWay}"
                 TextWrapping="Wrap"
                 AcceptsReturn="True"
                 IsReadOnly="True"
                 IsReadOnlyCaretVisible="True"
                 HorizontalScrollBarVisibility="Disabled"
                 VerticalScrollBarVisibility="Auto"
                 BorderThickness="0"
                 Padding="0"
                 Background="Transparent"
                 Foreground="#24292F"
                 FontSize="13"/>

        <Border Grid.Row="2"
                BorderBrush="#E6E8EE"
                BorderThickness="0,1,0,0"
                Padding="16,10"
                Background="#FAFBFC">
            <Grid>
                <!-- Thông báo: OK -->
                <StackPanel Orientation="Horizontal" HorizontalAlignment="Right"
                            Visibility="{Binding IsOkOnly, Converter={StaticResource BoolToVis}}">
                    <Button Content="OK"
                            MinWidth="88"
                            Height="32"
                            Padding="16,0"
                            IsDefault="True"
                            IsCancel="True"
                            Click="Ok_Click"
                            Cursor="Hand"
                            Background="{Binding AccentBrush}"
                            Foreground="White"
                            BorderThickness="0"
                            FontWeight="SemiBold"/>
                </StackPanel>

                <!-- Xác nhận: Y / N -->
                <StackPanel Orientation="Horizontal" HorizontalAlignment="Right"
                            Visibility="{Binding IsConfirm, Converter={StaticResource BoolToVis}}">
                    <Button Content="N"
                            MinWidth="72"
                            Height="32"
                            Margin="0,0,8,0"
                            Padding="16,0"
                            IsCancel="True"
                            Click="No_Click"
                            Cursor="Hand"
                            Background="#EEF1F5"
                            Foreground="#24292F"
                            BorderBrush="#D0D7DE"
                            BorderThickness="1"
                            FontWeight="SemiBold"
                            ToolTip="No (N)"/>
                    <Button Content="Y"
                            MinWidth="72"
                            Height="32"
                            Padding="16,0"
                            IsDefault="True"
                            Click="Yes_Click"
                            Cursor="Hand"
                            Background="{Binding AccentBrush}"
                            Foreground="White"
                            BorderThickness="0"
                            FontWeight="SemiBold"
                            ToolTip="Yes (Y)"/>
                </StackPanel>
            </Grid>
        </Border>
    </Grid>
</Window>
