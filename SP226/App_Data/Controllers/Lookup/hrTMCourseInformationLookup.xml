<?xml version="1.0" encoding="utf-8"?>

<!DOCTYPE lookup [
  <!ENTITY FilterInitialize SYSTEM "..\Include\FilterInitialize.xml">
  <!ENTITY % Control.Filter SYSTEM "..\Include\Filter.ent">
  %Control.Filter;
  <!ENTITY Controller "'hrTMRequest'">

  <!ENTITY % CheckRelative SYSTEM "..\Include\CheckRelative.ent">
  %CheckRelative;
  <!ENTITY CheckRelativeParameter "'hrTMCourseInformationLookup', 'Lookup', 'hrTMCourseInformation'">
  <!ENTITY CheckRelativeQuery "set @$primeFilter = '1 = 0'">
]>

<lookup table="hrdtyc" code="so_ct" name="stt_rec" order="ngay_ct, so_ct, stt_rec" xmlns="urn:schemas-fast-com:data-lookup">
  <header v="Chọn yêu cầu đào tạo" e="Select Training Request"></header>
  <fields>
    <field name="so_ct" align="right" allowFilter="true">
      <header v="Số phiếu" e="Number"></header>
      <query>&InsertCommandFilter;</query>
    </field>
    <field name="stt_rec">
      <header v="" e=""></header>
    </field>
    <field name="ngay_ct" type="DateTime" dataFormatString="dd/MM/yyyy" allowFilter="true">
      <header v="Ngày yêu cầu" e="Request Date"></header>
      <query>&InsertCommandFilter;</query>
    </field>
    <field name="ma_bp" allowFilter="true">
      <header v="Bộ phận" e="Department"></header>
      <query>&InsertCommandFilter;</query>
    </field>
    <field name="dien_giai" allowFilter="true">
      <header v="Nội dung" e="Content"></header>
      <query>&InsertCommandFilter;</query>
    </field>
  </fields>

  <queries>
    <query event="Declare">
      <text>&DeclareCommandFilter;</text>
    </query>

    <query event="Finding">
      <text>
        <![CDATA[
declare @unit varchar(128), @subID nvarchar(64)
select @subID = '%#20$' + rtrim(@ma_mh) + '%', @unit = case when @ma_dvcs = '' then @@unit else @ma_dvcs end
]]>&FilterInitialize;&CheckRelativeProcess;<![CDATA[
exec FastBusiness$App$Voucher$Finding 'H07', 'hridtyc', 'hrdtyc', 'hridtyc', 'ngay_ct', '''''', '{0}', '',
  @@refresh, @@pageIndex, @@pageCount, @@lastPage, @@lastCount, @@firstItem, @@lastItem, '', @subID, 'stt_rec',
  'so_ct,stt_rec,ngay_ct,ma_bp,dien_giai',
  'so_ct,stt_rec,ngay_ct,ma_bp,dien_giai',
  '', 'ngay_ct, so_ct', 1, @@userID, 1,
  @ngay_ct1, @ngay_ct2, '', '', '2', '0', @unit, default, default, default, default, default, default, default, @$primeJoin, @$primeFilter]]>
      </text>
    </query>
  </queries>
</lookup>