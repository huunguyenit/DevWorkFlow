    <field name="tien_nt" type="Decimal" readOnly="true" dataFormatString="@foreignCurrencyAmountViewFormat" clientDefault="0" width="0" hidden="true">
      <header v="Tiền tính thuế nk nt" e="FC Import Taxed Amount"></header>
      <items style="Numeric"/>
    </field>
    <field name="tien" type="Decimal" dataFormatString="@baseCurrencyAmountViewFormat" clientDefault="0" width="0" hidden="true" allowContain="true">
      <header v="Tiền tính thuế nk" e="Import Taxed Amount"></header>
      <items style="Numeric"/>
    </field>

    <field name="ma_thue_nk" width="0" hidden="true" readOnly="true" aliasName="a">
      <header v="Mã thuế nk" e="Import Tax Code"></header>
    </field>
    <field name="thue_suat_nk" type="Decimal" dataFormatString="#0.00" readOnly="true" width="0" hidden="true">
