<ResourceDictionary
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:md="http://materialdesigninxaml.net/winfx/xaml/themes">

    <!-- FBO Studio shell — object-oriented controls + soft interaction -->

    <SolidColorBrush x:Key="IdeRibbonBgBrush" Color="#F3F3F3"/>
    <SolidColorBrush x:Key="IdeMenuBgBrush" Color="#F3F3F3"/>
    <SolidColorBrush x:Key="IdeDockHeaderBgBrush" Color="#EEEEF2"/>
    <SolidColorBrush x:Key="IdeTabActiveBgBrush" Color="#FFFFFF"/>
    <SolidColorBrush x:Key="IdeTabInactiveBgBrush" Color="#E8E8EC"/>
    <SolidColorBrush x:Key="IdePlaceholderFgBrush" Color="#888888"/>
    <SolidColorBrush x:Key="IdeHoverBrush" Color="#E8EEF5"/>
    <SolidColorBrush x:Key="IdePressBrush" Color="#D6E4F5"/>
    <SolidColorBrush x:Key="IdeFocusRingBrush" Color="#0078D4"/>
    <SolidColorBrush x:Key="IdeAccentSoftBrush" Color="#E3F2FD"/>
    <SolidColorBrush x:Key="IdeSuccessSoftBrush" Color="#E8F5E9"/>
    <SolidColorBrush x:Key="IdeSemanticSoftBrush" Color="#F3E5F5"/>

    <Style x:Key="IdeMenuBarStyle" TargetType="Menu">
        <Setter Property="Background" Value="{StaticResource IdeMenuBgBrush}"/>
        <Setter Property="Foreground" Value="{StaticResource FgBrush}"/>
        <Setter Property="FontSize" Value="12"/>
        <Setter Property="Padding" Value="4,2"/>
        <Setter Property="BorderThickness" Value="0"/>
    </Style>

    <!-- Ribbon command — animated lift / scale / glow -->
    <Style x:Key="IdeRibbonButtonStyle" TargetType="Button">
        <Setter Property="Background" Value="Transparent"/>
        <Setter Property="BorderThickness" Value="1"/>
        <Setter Property="BorderBrush" Value="Transparent"/>
        <Setter Property="Padding" Value="6,4"/>
        <Setter Property="Margin" Value="2,0"/>
        <Setter Property="MinWidth" Value="52"/>
        <Setter Property="MinHeight" Value="52"/>
        <Setter Property="Cursor" Value="Hand"/>
        <Setter Property="FontSize" Value="10"/>
        <Setter Property="Foreground" Value="{StaticResource FgBrush}"/>
        <Setter Property="FocusVisualStyle" Value="{x:Null}"/>
        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="Button">
                    <Border x:Name="bd"
                            Background="{TemplateBinding Background}"
                            BorderBrush="{TemplateBinding BorderBrush}"
                            BorderThickness="{TemplateBinding BorderThickness}"
                            Padding="{TemplateBinding Padding}"
                            CornerRadius="5"
                            SnapsToDevicePixels="True"
                            RenderTransformOrigin="0.5,0.5">
                        <Border.RenderTransform>
                            <TransformGroup>
                                <ScaleTransform x:Name="scaleTx" ScaleX="1" ScaleY="1"/>
                                <TranslateTransform x:Name="liftTx" Y="0"/>
                            </TransformGroup>
                        </Border.RenderTransform>
                        <Grid>
                            <Border x:Name="glow"
                                    Background="{StaticResource IdeAccentSoftBrush}"
                                    CornerRadius="5"
                                    Opacity="0"/>
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"
                                              RecognizesAccessKey="True"/>
                        </Grid>
                    </Border>
                    <ControlTemplate.Triggers>
                        <EventTrigger RoutedEvent="MouseEnter">
                            <BeginStoryboard>
                                <Storyboard>
                                    <DoubleAnimation Storyboard.TargetName="scaleTx" Storyboard.TargetProperty="ScaleX"
                                                     To="1.06" Duration="0:0:0.12">
                                        <DoubleAnimation.EasingFunction>
                                            <QuadraticEase EasingMode="EaseOut"/>
                                        </DoubleAnimation.EasingFunction>
                                    </DoubleAnimation>
                                    <DoubleAnimation Storyboard.TargetName="scaleTx" Storyboard.TargetProperty="ScaleY"
                                                     To="1.06" Duration="0:0:0.12">
                                        <DoubleAnimation.EasingFunction>
                                            <QuadraticEase EasingMode="EaseOut"/>
                                        </DoubleAnimation.EasingFunction>
                                    </DoubleAnimation>
                                    <DoubleAnimation Storyboard.TargetName="liftTx" Storyboard.TargetProperty="Y"
                                                     To="-1.5" Duration="0:0:0.12">
                                        <DoubleAnimation.EasingFunction>
                                            <QuadraticEase EasingMode="EaseOut"/>
                                        </DoubleAnimation.EasingFunction>
                                    </DoubleAnimation>
                                    <DoubleAnimation Storyboard.TargetName="glow" Storyboard.TargetProperty="Opacity"
                                                     To="1" Duration="0:0:0.14"/>
                                </Storyboard>
                            </BeginStoryboard>
                        </EventTrigger>
                        <EventTrigger RoutedEvent="MouseLeave">
                            <BeginStoryboard>
                                <Storyboard>
                                    <DoubleAnimation Storyboard.TargetName="scaleTx" Storyboard.TargetProperty="ScaleX"
                                                     To="1" Duration="0:0:0.14">
                                        <DoubleAnimation.EasingFunction>
                                            <QuadraticEase EasingMode="EaseOut"/>
                                        </DoubleAnimation.EasingFunction>
                                    </DoubleAnimation>
                                    <DoubleAnimation Storyboard.TargetName="scaleTx" Storyboard.TargetProperty="ScaleY"
                                                     To="1" Duration="0:0:0.14">
                                        <DoubleAnimation.EasingFunction>
                                            <QuadraticEase EasingMode="EaseOut"/>
                                        </DoubleAnimation.EasingFunction>
                                    </DoubleAnimation>
                                    <DoubleAnimation Storyboard.TargetName="liftTx" Storyboard.TargetProperty="Y"
                                                     To="0" Duration="0:0:0.14"/>
                                    <DoubleAnimation Storyboard.TargetName="glow" Storyboard.TargetProperty="Opacity"
                                                     To="0" Duration="0:0:0.12"/>
                                </Storyboard>
                            </BeginStoryboard>
                        </EventTrigger>
                        <EventTrigger RoutedEvent="PreviewMouseLeftButtonDown">
                            <BeginStoryboard>
                                <Storyboard>
                                    <DoubleAnimation Storyboard.TargetName="scaleTx" Storyboard.TargetProperty="ScaleX"
                                                     To="0.94" Duration="0:0:0.06"/>
                                    <DoubleAnimation Storyboard.TargetName="scaleTx" Storyboard.TargetProperty="ScaleY"
                                                     To="0.94" Duration="0:0:0.06"/>
                                    <DoubleAnimation Storyboard.TargetName="liftTx" Storyboard.TargetProperty="Y"
                                                     To="0.5" Duration="0:0:0.06"/>
                                </Storyboard>
                            </BeginStoryboard>
                        </EventTrigger>
                        <EventTrigger RoutedEvent="PreviewMouseLeftButtonUp">
                            <BeginStoryboard>
                                <Storyboard>
                                    <DoubleAnimation Storyboard.TargetName="scaleTx" Storyboard.TargetProperty="ScaleX"
                                                     To="1.06" Duration="0:0:0.1">
                                        <DoubleAnimation.EasingFunction>
                                            <QuadraticEase EasingMode="EaseOut"/>
                                        </DoubleAnimation.EasingFunction>
                                    </DoubleAnimation>
                                    <DoubleAnimation Storyboard.TargetName="scaleTx" Storyboard.TargetProperty="ScaleY"
                                                     To="1.06" Duration="0:0:0.1">
                                        <DoubleAnimation.EasingFunction>
                                            <QuadraticEase EasingMode="EaseOut"/>
                                        </DoubleAnimation.EasingFunction>
                                    </DoubleAnimation>
                                    <DoubleAnimation Storyboard.TargetName="liftTx" Storyboard.TargetProperty="Y"
                                                     To="-1.5" Duration="0:0:0.1"/>
                                </Storyboard>
                            </BeginStoryboard>
                        </EventTrigger>
                        <Trigger Property="IsMouseOver" Value="True">
                            <Setter TargetName="bd" Property="BorderBrush" Value="#A8C0D8"/>
                            <Setter Property="Foreground" Value="{StaticResource PrimaryDarkBrush}"/>
                        </Trigger>
                        <Trigger Property="IsPressed" Value="True">
                            <Setter TargetName="bd" Property="BorderBrush" Value="{StaticResource PrimaryBrush}"/>
                            <Setter TargetName="glow" Property="Background" Value="{StaticResource IdePressBrush}"/>
                        </Trigger>
                        <Trigger Property="IsEnabled" Value="False">
                            <Setter Property="Opacity" Value="0.4"/>
                        </Trigger>
                    </ControlTemplate.Triggers>
                </ControlTemplate>
            </Setter.Value>
        </Setter>
    </Style>

    <!-- Save / primary CTA trên ribbon -->
    <Style x:Key="IdeRibbonPrimaryButtonStyle" TargetType="Button" BasedOn="{StaticResource IdeRibbonButtonStyle}">
        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="Button">
                    <Border x:Name="bd"
                            Background="Transparent"
                            BorderBrush="Transparent"
                            BorderThickness="1"
                            Padding="{TemplateBinding Padding}"
                            CornerRadius="5"
                            SnapsToDevicePixels="True"
                            RenderTransformOrigin="0.5,0.5">
                        <Border.RenderTransform>
                            <TransformGroup>
                                <ScaleTransform x:Name="scaleTx" ScaleX="1" ScaleY="1"/>
                                <TranslateTransform x:Name="liftTx" Y="0"/>
                            </TransformGroup>
                        </Border.RenderTransform>
                        <Grid>
                            <Border x:Name="glow"
                                    Background="#D6EBFF"
                                    CornerRadius="5"
                                    Opacity="0.55"/>
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"
                                              RecognizesAccessKey="True"/>
                        </Grid>
                    </Border>
                    <ControlTemplate.Triggers>
                        <EventTrigger RoutedEvent="MouseEnter">
                            <BeginStoryboard>
                                <Storyboard>
                                    <DoubleAnimation Storyboard.TargetName="scaleTx" Storyboard.TargetProperty="ScaleX"
                                                     To="1.07" Duration="0:0:0.12">
                                        <DoubleAnimation.EasingFunction>
                                            <QuadraticEase EasingMode="EaseOut"/>
                                        </DoubleAnimation.EasingFunction>
                                    </DoubleAnimation>
                                    <DoubleAnimation Storyboard.TargetName="scaleTx" Storyboard.TargetProperty="ScaleY"
                                                     To="1.07" Duration="0:0:0.12">
                                        <DoubleAnimation.EasingFunction>
                                            <QuadraticEase EasingMode="EaseOut"/>
                                        </DoubleAnimation.EasingFunction>
                                    </DoubleAnimation>
                                    <DoubleAnimation Storyboard.TargetName="liftTx" Storyboard.TargetProperty="Y"
                                                     To="-1.5" Duration="0:0:0.12"/>
                                    <DoubleAnimation Storyboard.TargetName="glow" Storyboard.TargetProperty="Opacity"
                                                     To="1" Duration="0:0:0.12"/>
                                </Storyboard>
                            </BeginStoryboard>
                        </EventTrigger>
                        <EventTrigger RoutedEvent="MouseLeave">
                            <BeginStoryboard>
                                <Storyboard>
                                    <DoubleAnimation Storyboard.TargetName="scaleTx" Storyboard.TargetProperty="ScaleX"
                                                     To="1" Duration="0:0:0.14"/>
                                    <DoubleAnimation Storyboard.TargetName="scaleTx" Storyboard.TargetProperty="ScaleY"
                                                     To="1" Duration="0:0:0.14"/>
                                    <DoubleAnimation Storyboard.TargetName="liftTx" Storyboard.TargetProperty="Y"
                                                     To="0" Duration="0:0:0.14"/>
                                    <DoubleAnimation Storyboard.TargetName="glow" Storyboard.TargetProperty="Opacity"
                                                     To="0.55" Duration="0:0:0.12"/>
                                </Storyboard>
                            </BeginStoryboard>
                        </EventTrigger>
                        <EventTrigger RoutedEvent="PreviewMouseLeftButtonDown">
                            <BeginStoryboard>
                                <Storyboard>
                                    <DoubleAnimation Storyboard.TargetName="scaleTx" Storyboard.TargetProperty="ScaleX"
                                                     To="0.94" Duration="0:0:0.06"/>
                                    <DoubleAnimation Storyboard.TargetName="scaleTx" Storyboard.TargetProperty="ScaleY"
                                                     To="0.94" Duration="0:0:0.06"/>
                                </Storyboard>
                            </BeginStoryboard>
                        </EventTrigger>
                        <EventTrigger RoutedEvent="PreviewMouseLeftButtonUp">
                            <BeginStoryboard>
                                <Storyboard>
                                    <DoubleAnimation Storyboard.TargetName="scaleTx" Storyboard.TargetProperty="ScaleX"
                                                     To="1.07" Duration="0:0:0.1"/>
                                    <DoubleAnimation Storyboard.TargetName="scaleTx" Storyboard.TargetProperty="ScaleY"
                                                     To="1.07" Duration="0:0:0.1"/>
                                </Storyboard>
                            </BeginStoryboard>
                        </EventTrigger>
                        <Trigger Property="IsMouseOver" Value="True">
                            <Setter TargetName="bd" Property="BorderBrush" Value="{StaticResource PrimaryBrush}"/>
                            <Setter Property="Foreground" Value="{StaticResource PrimaryDarkBrush}"/>
                        </Trigger>
                        <Trigger Property="IsPressed" Value="True">
                            <Setter TargetName="glow" Property="Background" Value="#B3D7F5"/>
                        </Trigger>
                        <Trigger Property="IsEnabled" Value="False">
                            <Setter Property="Opacity" Value="0.4"/>
                        </Trigger>
                    </ControlTemplate.Triggers>
                </ControlTemplate>
            </Setter.Value>
        </Setter>
    </Style>

    <!-- Run SQL — success accent -->
    <Style x:Key="IdeRibbonSuccessButtonStyle" TargetType="Button" BasedOn="{StaticResource IdeRibbonButtonStyle}">
        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="Button">
                    <Border x:Name="bd"
                            Background="Transparent"
                            BorderBrush="Transparent"
                            BorderThickness="1"
                            Padding="{TemplateBinding Padding}"
                            CornerRadius="5"
                            SnapsToDevicePixels="True"
                            RenderTransformOrigin="0.5,0.5">
                        <Border.RenderTransform>
                            <TransformGroup>
                                <ScaleTransform x:Name="scaleTx" ScaleX="1" ScaleY="1"/>
                                <TranslateTransform x:Name="liftTx" Y="0"/>
                            </TransformGroup>
                        </Border.RenderTransform>
                        <Grid>
                            <Border x:Name="glow"
                                    Background="{StaticResource IdeSuccessSoftBrush}"
                                    CornerRadius="5"
                                    Opacity="0.5"/>
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"
                                              RecognizesAccessKey="True"/>
                        </Grid>
                    </Border>
                    <ControlTemplate.Triggers>
                        <EventTrigger RoutedEvent="MouseEnter">
                            <BeginStoryboard>
                                <Storyboard>
                                    <DoubleAnimation Storyboard.TargetName="scaleTx" Storyboard.TargetProperty="ScaleX"
                                                     To="1.07" Duration="0:0:0.12">
                                        <DoubleAnimation.EasingFunction>
                                            <QuadraticEase EasingMode="EaseOut"/>
                                        </DoubleAnimation.EasingFunction>
                                    </DoubleAnimation>
                                    <DoubleAnimation Storyboard.TargetName="scaleTx" Storyboard.TargetProperty="ScaleY"
                                                     To="1.07" Duration="0:0:0.12">
                                        <DoubleAnimation.EasingFunction>
                                            <QuadraticEase EasingMode="EaseOut"/>
                                        </DoubleAnimation.EasingFunction>
                                    </DoubleAnimation>
                                    <DoubleAnimation Storyboard.TargetName="liftTx" Storyboard.TargetProperty="Y"
                                                     To="-1.5" Duration="0:0:0.12"/>
                                    <DoubleAnimation Storyboard.TargetName="glow" Storyboard.TargetProperty="Opacity"
                                                     To="1" Duration="0:0:0.12"/>
                                </Storyboard>
                            </BeginStoryboard>
                        </EventTrigger>
                        <EventTrigger RoutedEvent="MouseLeave">
                            <BeginStoryboard>
                                <Storyboard>
                                    <DoubleAnimation Storyboard.TargetName="scaleTx" Storyboard.TargetProperty="ScaleX"
                                                     To="1" Duration="0:0:0.14"/>
                                    <DoubleAnimation Storyboard.TargetName="scaleTx" Storyboard.TargetProperty="ScaleY"
                                                     To="1" Duration="0:0:0.14"/>
                                    <DoubleAnimation Storyboard.TargetName="liftTx" Storyboard.TargetProperty="Y"
                                                     To="0" Duration="0:0:0.14"/>
                                    <DoubleAnimation Storyboard.TargetName="glow" Storyboard.TargetProperty="Opacity"
                                                     To="0.5" Duration="0:0:0.12"/>
                                </Storyboard>
                            </BeginStoryboard>
                        </EventTrigger>
                        <EventTrigger RoutedEvent="PreviewMouseLeftButtonDown">
                            <BeginStoryboard>
                                <Storyboard>
                                    <DoubleAnimation Storyboard.TargetName="scaleTx" Storyboard.TargetProperty="ScaleX"
                                                     To="0.94" Duration="0:0:0.06"/>
                                    <DoubleAnimation Storyboard.TargetName="scaleTx" Storyboard.TargetProperty="ScaleY"
                                                     To="0.94" Duration="0:0:0.06"/>
                                </Storyboard>
                            </BeginStoryboard>
                        </EventTrigger>
                        <EventTrigger RoutedEvent="PreviewMouseLeftButtonUp">
                            <BeginStoryboard>
                                <Storyboard>
                                    <DoubleAnimation Storyboard.TargetName="scaleTx" Storyboard.TargetProperty="ScaleX"
                                                     To="1.07" Duration="0:0:0.1"/>
                                    <DoubleAnimation Storyboard.TargetName="scaleTx" Storyboard.TargetProperty="ScaleY"
                                                     To="1.07" Duration="0:0:0.1"/>
                                </Storyboard>
                            </BeginStoryboard>
                        </EventTrigger>
                        <Trigger Property="IsMouseOver" Value="True">
                            <Setter TargetName="bd" Property="BorderBrush" Value="{StaticResource SuccessBrush}"/>
                        </Trigger>
                        <Trigger Property="IsEnabled" Value="False">
                            <Setter Property="Opacity" Value="0.4"/>
                        </Trigger>
                    </ControlTemplate.Triggers>
                </ControlTemplate>
            </Setter.Value>
        </Setter>
    </Style>

    <Style x:Key="IdeRibbonGroupLabelStyle" TargetType="TextBlock">
        <Setter Property="FontSize" Value="9"/>
        <Setter Property="Foreground" Value="{StaticResource FgMutedBrush}"/>
        <Setter Property="HorizontalAlignment" Value="Center"/>
        <Setter Property="Margin" Value="0,2,0,0"/>
    </Style>

    <Style x:Key="IdeRibbonSeparatorStyle" TargetType="Rectangle">
        <Setter Property="Width" Value="1"/>
        <Setter Property="Fill" Value="{StaticResource IdeBorderBrush}"/>
        <Setter Property="Margin" Value="8,2,8,2"/>
        <Setter Property="Opacity" Value="0.85"/>
    </Style>

    <!-- Compact tool button (Designer toolbar / object actions) -->
    <Style x:Key="IdeToolButtonStyle" TargetType="Button">
        <Setter Property="Background" Value="White"/>
        <Setter Property="Foreground" Value="{StaticResource FgBrush}"/>
        <Setter Property="BorderBrush" Value="{StaticResource IdeBorderBrush}"/>
        <Setter Property="BorderThickness" Value="1"/>
        <Setter Property="Padding" Value="8,3"/>
        <Setter Property="Margin" Value="0,0,4,0"/>
        <Setter Property="MinHeight" Value="26"/>
        <Setter Property="FontSize" Value="11"/>
        <Setter Property="Cursor" Value="Hand"/>
        <Setter Property="RenderTransformOrigin" Value="0.5,0.5"/>
        <Setter Property="RenderTransform">
            <Setter.Value>
                <ScaleTransform ScaleX="1" ScaleY="1"/>
            </Setter.Value>
        </Setter>
        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="Button">
                    <Border x:Name="bd"
                            Background="{TemplateBinding Background}"
                            BorderBrush="{TemplateBinding BorderBrush}"
                            BorderThickness="{TemplateBinding BorderThickness}"
                            Padding="{TemplateBinding Padding}"
                            CornerRadius="3"
                            SnapsToDevicePixels="True">
                        <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                    </Border>
                    <ControlTemplate.Triggers>
                        <Trigger Property="IsMouseOver" Value="True">
                            <Setter TargetName="bd" Property="Background" Value="{StaticResource IdeHoverBrush}"/>
                            <Setter TargetName="bd" Property="BorderBrush" Value="{StaticResource PrimaryBrush}"/>
                        </Trigger>
                        <Trigger Property="IsPressed" Value="True">
                            <Setter TargetName="bd" Property="Background" Value="{StaticResource IdePressBrush}"/>
                            <Setter Property="RenderTransform">
                                <Setter.Value>
                                    <ScaleTransform ScaleX="0.97" ScaleY="0.97"/>
                                </Setter.Value>
                            </Setter>
                        </Trigger>
                        <Trigger Property="IsEnabled" Value="False">
                            <Setter Property="Opacity" Value="0.45"/>
                        </Trigger>
                    </ControlTemplate.Triggers>
                </ControlTemplate>
            </Setter.Value>
        </Setter>
    </Style>

    <!-- Primary CTA (Save / Chọn Program) -->
    <Style x:Key="IdePrimaryToolButtonStyle" TargetType="Button" BasedOn="{StaticResource IdeToolButtonStyle}">
        <Setter Property="Background" Value="{StaticResource PrimaryBrush}"/>
        <Setter Property="Foreground" Value="White"/>
        <Setter Property="BorderBrush" Value="{StaticResource PrimaryDarkBrush}"/>
        <Setter Property="FontWeight" Value="SemiBold"/>
        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="Button">
                    <Border x:Name="bd"
                            Background="{TemplateBinding Background}"
                            BorderBrush="{TemplateBinding BorderBrush}"
                            BorderThickness="1"
                            Padding="{TemplateBinding Padding}"
                            CornerRadius="3">
                        <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                    </Border>
                    <ControlTemplate.Triggers>
                        <Trigger Property="IsMouseOver" Value="True">
                            <Setter TargetName="bd" Property="Background" Value="{StaticResource PrimaryLightBrush}"/>
                        </Trigger>
                        <Trigger Property="IsPressed" Value="True">
                            <Setter TargetName="bd" Property="Background" Value="{StaticResource PrimaryDarkBrush}"/>
                            <Setter Property="RenderTransform">
                                <Setter.Value>
                                    <ScaleTransform ScaleX="0.97" ScaleY="0.97"/>
                                </Setter.Value>
                            </Setter>
                        </Trigger>
                        <Trigger Property="IsEnabled" Value="False">
                            <Setter Property="Opacity" Value="0.45"/>
                        </Trigger>
                    </ControlTemplate.Triggers>
                </ControlTemplate>
            </Setter.Value>
        </Setter>
    </Style>

    <!-- Dock / explorer tab strip -->
    <Style x:Key="IdeDockTabButtonStyle" TargetType="Button">
        <Setter Property="Background" Value="Transparent"/>
        <Setter Property="Foreground" Value="{StaticResource FgMutedBrush}"/>
        <Setter Property="BorderBrush" Value="Transparent"/>
        <Setter Property="BorderThickness" Value="0,0,0,2"/>
        <Setter Property="Padding" Value="10,6"/>
        <Setter Property="Margin" Value="0,0,1,0"/>
        <Setter Property="FontSize" Value="11"/>
        <Setter Property="Cursor" Value="Hand"/>
        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="Button">
                    <Border x:Name="bd"
                            Background="{TemplateBinding Background}"
                            BorderBrush="{TemplateBinding BorderBrush}"
                            BorderThickness="{TemplateBinding BorderThickness}"
                            Padding="{TemplateBinding Padding}">
                        <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                    </Border>
                    <ControlTemplate.Triggers>
                        <Trigger Property="IsMouseOver" Value="True">
                            <Setter TargetName="bd" Property="Background" Value="#F5F7FA"/>
                            <Setter Property="Foreground" Value="{StaticResource FgBrush}"/>
                        </Trigger>
                        <Trigger Property="IsPressed" Value="True">
                            <Setter TargetName="bd" Property="Background" Value="{StaticResource IdePressBrush}"/>
                        </Trigger>
                    </ControlTemplate.Triggers>
                </ControlTemplate>
            </Setter.Value>
        </Setter>
    </Style>

    <!-- Segmented editor mode (Source / Insight / Designer) -->
    <Style x:Key="IdeSegmentButtonStyle" TargetType="Button">
        <Setter Property="Background" Value="Transparent"/>
        <Setter Property="Foreground" Value="{StaticResource FgMutedBrush}"/>
        <Setter Property="BorderThickness" Value="0"/>
        <Setter Property="Padding" Value="12,5"/>
        <Setter Property="Margin" Value="0"/>
        <Setter Property="MinHeight" Value="28"/>
        <Setter Property="FontSize" Value="11"/>
        <Setter Property="Cursor" Value="Hand"/>
        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="Button">
                    <Border x:Name="bd"
                            Background="{TemplateBinding Background}"
                            Padding="{TemplateBinding Padding}"
                            CornerRadius="3">
                        <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                    </Border>
                    <ControlTemplate.Triggers>
                        <Trigger Property="IsMouseOver" Value="True">
                            <Setter TargetName="bd" Property="Background" Value="#EEF2F6"/>
                            <Setter Property="Foreground" Value="{StaticResource FgBrush}"/>
                        </Trigger>
                        <Trigger Property="IsPressed" Value="True">
                            <Setter TargetName="bd" Property="Background" Value="{StaticResource IdePressBrush}"/>
                        </Trigger>
                    </ControlTemplate.Triggers>
                </ControlTemplate>
            </Setter.Value>
        </Setter>
    </Style>

    <Style x:Key="IdeDockHeaderStyle" TargetType="Border">
        <Setter Property="Background" Value="{StaticResource IdeDockHeaderBgBrush}"/>
        <Setter Property="BorderBrush" Value="{StaticResource IdeBorderBrush}"/>
        <Setter Property="BorderThickness" Value="0,0,0,1"/>
        <Setter Property="Padding" Value="8,4"/>
        <Setter Property="Height" Value="28"/>
    </Style>

    <Style x:Key="IdeEditorColumnHeaderStyle" TargetType="Border">
        <Setter Property="Background" Value="#F5F7FA"/>
        <Setter Property="BorderBrush" Value="{StaticResource IdeBorderBrush}"/>
        <Setter Property="BorderThickness" Value="0,0,0,1"/>
        <Setter Property="Padding" Value="10,5"/>
    </Style>

    <Style x:Key="IdeDocumentTabStyle" TargetType="RadioButton">
        <Setter Property="Background" Value="{StaticResource IdeTabInactiveBgBrush}"/>
        <Setter Property="Foreground" Value="{StaticResource FgBrush}"/>
        <Setter Property="BorderBrush" Value="{StaticResource IdeBorderBrush}"/>
        <Setter Property="BorderThickness" Value="1,1,1,0"/>
        <Setter Property="Padding" Value="12,6"/>
        <Setter Property="Margin" Value="0,0,1,0"/>
        <Setter Property="FontSize" Value="12"/>
        <Setter Property="Cursor" Value="Hand"/>
        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="RadioButton">
                    <Border x:Name="bd"
                            Background="{TemplateBinding Background}"
                            BorderBrush="{TemplateBinding BorderBrush}"
                            BorderThickness="{TemplateBinding BorderThickness}"
                            Padding="{TemplateBinding Padding}">
                        <ContentPresenter VerticalAlignment="Center"/>
                    </Border>
                    <ControlTemplate.Triggers>
                        <Trigger Property="IsChecked" Value="True">
                            <Setter TargetName="bd" Property="Background" Value="{StaticResource IdeTabActiveBgBrush}"/>
                            <Setter TargetName="bd" Property="BorderBrush" Value="#007ACC"/>
                            <Setter TargetName="bd" Property="BorderThickness" Value="1,2,1,0"/>
                        </Trigger>
                        <Trigger Property="IsMouseOver" Value="True">
                            <Setter TargetName="bd" Property="Background" Value="#F7F9FC"/>
                        </Trigger>
                    </ControlTemplate.Triggers>
                </ControlTemplate>
            </Setter.Value>
        </Setter>
    </Style>

    <Style x:Key="IdeTabCloseButtonStyle" TargetType="Button">
        <Setter Property="Width" Value="18"/>
        <Setter Property="Height" Value="18"/>
        <Setter Property="Padding" Value="0"/>
        <Setter Property="Margin" Value="8,0,0,0"/>
        <Setter Property="Background" Value="Transparent"/>
        <Setter Property="BorderThickness" Value="0"/>
        <Setter Property="Foreground" Value="{StaticResource FgMutedBrush}"/>
        <Setter Property="Cursor" Value="Hand"/>
        <Setter Property="FontSize" Value="10"/>
        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="Button">
                    <Border x:Name="bd" Background="{TemplateBinding Background}"
                            CornerRadius="2" Width="16" Height="16">
                        <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                    </Border>
                    <ControlTemplate.Triggers>
                        <Trigger Property="IsMouseOver" Value="True">
                            <Setter TargetName="bd" Property="Background" Value="#E0E0E0"/>
                            <Setter Property="Foreground" Value="{StaticResource FgBrightBrush}"/>
                        </Trigger>
                        <Trigger Property="IsPressed" Value="True">
                            <Setter TargetName="bd" Property="Background" Value="#FFCDD2"/>
                            <Setter Property="Foreground" Value="#C62828"/>
                        </Trigger>
                    </ControlTemplate.Triggers>
                </ControlTemplate>
            </Setter.Value>
        </Setter>
    </Style>

    <Style x:Key="IdePlaceholderTextStyle" TargetType="TextBlock">
        <Setter Property="Foreground" Value="{StaticResource IdePlaceholderFgBrush}"/>
        <Setter Property="FontSize" Value="12"/>
        <Setter Property="TextWrapping" Value="Wrap"/>
        <Setter Property="HorizontalAlignment" Value="Center"/>
        <Setter Property="VerticalAlignment" Value="Center"/>
        <Setter Property="Margin" Value="12"/>
    </Style>

    <!-- Object-style input (form / property / resolved value) -->
    <Style x:Key="IdeInputStyle" TargetType="TextBox">
        <Setter Property="Background" Value="White"/>
        <Setter Property="Foreground" Value="{StaticResource FgBrush}"/>
        <Setter Property="CaretBrush" Value="{StaticResource FgBrightBrush}"/>
        <Setter Property="BorderBrush" Value="{StaticResource IdeBorderBrush}"/>
        <Setter Property="BorderThickness" Value="1"/>
        <Setter Property="Padding" Value="8,5"/>
        <Setter Property="FontSize" Value="{StaticResource FontSizeNormal}"/>
        <Setter Property="FontFamily" Value="{StaticResource AppFont}"/>
        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="TextBox">
                    <Border x:Name="bd"
                            Background="{TemplateBinding Background}"
                            BorderBrush="{TemplateBinding BorderBrush}"
                            BorderThickness="{TemplateBinding BorderThickness}"
                            CornerRadius="3"
                            Padding="{TemplateBinding Padding}"
                            SnapsToDevicePixels="True">
                        <ScrollViewer x:Name="PART_ContentHost" Margin="0"/>
                    </Border>
                    <ControlTemplate.Triggers>
                        <Trigger Property="IsMouseOver" Value="True">
                            <Setter TargetName="bd" Property="BorderBrush" Value="#90A4AE"/>
                        </Trigger>
                        <Trigger Property="IsKeyboardFocused" Value="True">
                            <Setter TargetName="bd" Property="BorderBrush" Value="{StaticResource IdeFocusRingBrush}"/>
                            <Setter TargetName="bd" Property="BorderThickness" Value="1.5"/>
                        </Trigger>
                        <Trigger Property="IsEnabled" Value="False">
                            <Setter TargetName="bd" Property="Background" Value="#F5F5F5"/>
                            <Setter Property="Opacity" Value="0.7"/>
                        </Trigger>
                    </ControlTemplate.Triggers>
                </ControlTemplate>
            </Setter.Value>
        </Setter>
    </Style>

    <Style x:Key="IdeMonoInputStyle" TargetType="TextBox" BasedOn="{StaticResource IdeInputStyle}">
        <Setter Property="FontFamily" Value="{StaticResource MonoFont}"/>
        <Setter Property="FontSize" Value="12"/>
        <Setter Property="Padding" Value="6,4"/>
    </Style>

</ResourceDictionary>
