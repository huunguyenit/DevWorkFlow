  <!ENTITY TSTran.Nested.Message.e "&Nested.Message.Exists.e;">
]]>
<![%Conditional.TS2Tran.Nested;[
  <!ENTITY TS2Tran.Nested.Key.a "&PrimaryField; = @&PrimaryField;">
  <!ENTITY TS2Tran.Nested.Key.b "if 1 = 0 begin">

  <!ENTITY TS2Tran.Nested.Message.v "&Nested.Message.Exists.v;">
  <!ENTITY TS2Tran.Nested.Message.e "&Nested.Message.Exists.e;">
]]>

<!ENTITY Item.Nested.Key.a "((ma_vt like rtrim(@ma_vt) + '&#37;') or rtrim(@ma_vt) like rtrim(ma_vt) + '&#37;')">
<!ENTITY Item.Nested.Key.b "if 1 = 1 begin">
<!ENTITY Customer.Nested.Key.a "((ma_kh like rtrim(@ma_kh) + '&#37;') or rtrim(@ma_kh) like rtrim(ma_kh) + '&#37;')">
<!ENTITY Customer.Nested.Key.b "if 1 = 1 begin">
<!ENTITY Job.Nested.Key.a "((ma_vv like rtrim(@ma_vv) + '&#37;') or rtrim(@ma_vv) like rtrim(ma_vv) + '&#37;')">
<!ENTITY Job.Nested.Key.b "if 1 = 1 begin">
<!ENTITY Contract.Nested.Key.a "((ma_hd like rtrim(@ma_hd) + '&#37;') or rtrim(@ma_hd) like rtrim(ma_hd) + '&#37;')">
<!ENTITY Contract.Nested.Key.b "if 1 = 1 begin">
<!ENTITY LoanContract.Nested.Key.a "((ma_ku like rtrim(@ma_ku) + '&#37;') or rtrim(@ma_ku) like rtrim(ma_ku) + '&#37;')">
<!ENTITY LoanContract.Nested.Key.b "if 1 = 1 begin">
<!ENTITY Expense.Nested.Key.a "((ma_phi like rtrim(@ma_phi) + '&#37;') or rtrim(@ma_phi) like rtrim(ma_phi) + '&#37;')">
<!ENTITY Expense.Nested.Key.b "if 1 = 1 begin">
<!ENTITY ManagementObject1.Nested.Key.a "((ma_dtqt like rtrim(@ma_dtqt) + '&#37;') or rtrim(@ma_dtqt) like rtrim(ma_dtqt) + '&#37;')">
<!ENTITY ManagementObject1.Nested.Key.b "if 1 = 1 begin">
<!ENTITY ManagementObject2.Nested.Key.a "((ma_dtqt like rtrim(@ma_dtqt) + '&#37;') or rtrim(@ma_dtqt) like rtrim(ma_dtqt) + '&#37;')">
<!ENTITY ManagementObject2.Nested.Key.b "if 1 = 1 begin">
<!ENTITY ManagementObject3.Nested.Key.a "((ma_dtqt like rtrim(@ma_dtqt) + '&#37;') or rtrim(@ma_dtqt) like rtrim(ma_dtqt) + '&#37;')">
<!ENTITY ManagementObject3.Nested.Key.b "if 1 = 1 begin">
<!ENTITY FATran.Nested.Key.a "((so_the_ts like rtrim(@so_the_ts) + '&#37;') or rtrim(@so_the_ts) like rtrim(so_the_ts) + '&#37;')">
<!ENTITY FATran.Nested.Key.b "if 1 = 1 begin">
<!ENTITY TSTran.Nested.Key.a "((so_the_ts like rtrim(@so_the_ts) + '&#37;') or rtrim(@so_the_ts) like rtrim(so_the_ts) + '&#37;')">
<!ENTITY TSTran.Nested.Key.b "if 1 = 1 begin">
<!ENTITY TS2Tran.Nested.Key.a "((&PrimaryField; like rtrim(@&PrimaryField;) + '&#37;') or rtrim(@&PrimaryField;) like rtrim(&PrimaryField;) + '&#37;')">
<!ENTITY TS2Tran.Nested.Key.b "if 1 = 1 begin">

<!ENTITY Item.Nested.Message.v "&Nested.Message.Invalid.v;">
<!ENTITY Item.Nested.Message.e "&Nested.Message.Invalid.e;">
