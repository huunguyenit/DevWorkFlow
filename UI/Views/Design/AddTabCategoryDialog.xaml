<Window x:Class="UI.Views.Design.AddTabCategoryDialog"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Thêm Tab (Category)"
        Width="440" MinWidth="360"
        SizeToContent="Height"
        ResizeMode="NoResize"
        ShowInTaskbar="False"
        WindowStartupLocation="CenterOwner"
        WindowStyle="SingleBorderWindow"
        Background="White"
        SnapsToDevicePixels="True"
        UseLayoutRounding="True"
        TextOptions.TextFormattingMode="Display"
        KeyDown="Window_KeyDown">

    <Grid Margin="18,14">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="Auto"/>
            <ColumnDefinition Width="*"/>
        </Grid.ColumnDefinitions>

        <TextBlock Grid.Row="0" Grid.Column="0" Text="Loại tab" VerticalAlignment="Center"
                   Margin="0,0,10,8" FontSize="12"/>
        <ComboBox Grid.Row="0" Grid.Column="1" x:Name="KindCombo" Margin="0,0,0,8"
                  SelectionChanged="KindCombo_SelectionChanged">
            <ComboBoxItem Content="Normal" Tag="Normal" IsSelected="True"/>
            <ComboBoxItem Content="Grid" Tag="Grid"/>
            <ComboBoxItem Content="Post" Tag="Post"/>
            <ComboBoxItem Content="List" Tag="List"/>
        </ComboBox>

        <TextBlock Grid.Row="1" Grid.Column="0" Text="Header (V)" VerticalAlignment="Center"
                   Margin="0,0,10,8" FontSize="12"/>
        <TextBox Grid.Row="1" Grid.Column="1" x:Name="HeaderVBox" Margin="0,0,0,8"
                 Padding="4,3" FontSize="12"/>

        <TextBlock Grid.Row="2" Grid.Column="0" Text="Header (E)" VerticalAlignment="Center"
                   Margin="0,0,10,8" FontSize="12"/>
        <TextBox Grid.Row="2" Grid.Column="1" x:Name="HeaderEBox" Margin="0,0,0,8"
                 Padding="4,3" FontSize="12"/>

        <TextBlock Grid.Row="3" Grid.Column="0" Text="Controller" VerticalAlignment="Center"
                   Margin="0,0,10,8" FontSize="12" x:Name="ControllerLabel"/>
        <TextBox Grid.Row="3" Grid.Column="1" x:Name="ControllerBox" Margin="0,0,0,8"
                 Padding="4,3" FontSize="12"/>

        <TextBlock Grid.Row="4" Grid.Column="0" Grid.ColumnSpan="2" x:Name="ErrorText"
                   Foreground="#C62828" FontSize="11" TextWrapping="Wrap"
                   Margin="0,0,0,8" Visibility="Collapsed"/>

        <Border Grid.Row="5" Grid.Column="0" Grid.ColumnSpan="2"
                BorderBrush="#E6E8EE" BorderThickness="0,1,0,0" Margin="0,6,0,0"/>

        <StackPanel Grid.Row="6" Grid.Column="0" Grid.ColumnSpan="2" Orientation="Horizontal"
                    HorizontalAlignment="Right" Margin="0,10,0,0">
            <Button Content="Hủy" MinWidth="80" Height="30" Margin="0,0,8,0"
                    IsCancel="True" Cursor="Hand"/>
            <Button Content="Thêm" MinWidth="80" Height="30" IsDefault="True"
                    Click="Ok_Click" Cursor="Hand"
                    Background="#1565C0" Foreground="White" BorderThickness="0" FontWeight="SemiBold"/>
        </StackPanel>
    </Grid>
</Window>
