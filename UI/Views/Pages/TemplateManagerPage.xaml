<UserControl x:Class="UI.Views.Pages.TemplateManagerPage"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:md="http://materialdesigninxaml.net/winfx/xaml/themes">

    <Grid Margin="16">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <!-- Title -->
        <TextBlock Grid.Row="0" Text="{Binding Title}" Style="{StaticResource PageTitleStyle}"/>

        <!-- Toolbar -->
        <Grid Grid.Row="1" Margin="0,0,0,8">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="Auto"/>
            </Grid.ColumnDefinitions>
            <TextBox Grid.Column="0"
                     Text="{Binding SearchText, UpdateSourceTrigger=PropertyChanged}"
                     md:HintAssist.Hint="🔍  Tìm kiếm..."
                     Style="{StaticResource MaterialDesignOutlinedTextBox}"
                     Width="300" HorizontalAlignment="Left"/>
            <StackPanel Grid.Column="1" Orientation="Horizontal">
                <Button Style="{StaticResource ActionButtonStyle}"
                        Content="+ Tạo mới" Command="{Binding NewCommand}"
                        Background="{StaticResource PrimaryBrush}" Foreground="White"/>
                <Button Style="{StaticResource ActionButtonStyle}"
                        Content="Mở Form" Command="{Binding OpenFormCommand}"
                        Margin="4,0"/>
                <Button Style="{StaticResource ActionButtonStyle}"
                        Content="Xoá" Command="{Binding DeleteCommand}"
                        Background="{StaticResource ErrorBrush}" Foreground="White"/>
                <Button Style="{StaticResource MaterialDesignIconButton}"
                        Command="{Binding RefreshCommand}"
                        ToolTip="Làm mới" Margin="4,0">
                    <md:PackIcon Kind="Refresh"/>
                </Button>
            </StackPanel>
        </Grid>

        <!-- DataGrid -->
        <md:Card Grid.Row="2" Style="{StaticResource CardStyle}" Padding="0">
            <DataGrid ItemsSource="{Binding FilteredItems}"
                      SelectedItem="{Binding SelectedItem}"
                      AutoGenerateColumns="False"
                      IsReadOnly="True"
                      SelectionMode="Single"
                      GridLinesVisibility="Horizontal"
                      RowStyle="{StaticResource DataGridRowStyle}"
                      Style="{StaticResource MaterialDesignDataGrid}">
                <DataGrid.Columns>
                    <DataGridTemplateColumn Header="" Width="40">
                        <DataGridTemplateColumn.CellTemplate>
                            <DataTemplate>
                                <md:PackIcon Kind="{Binding IconKind, FallbackValue=File}"
                                             Width="18" Height="18"
                                             Foreground="{StaticResource PrimaryBrush}"
                                             VerticalAlignment="Center" HorizontalAlignment="Center"/>
                            </DataTemplate>
                        </DataGridTemplateColumn.CellTemplate>
                    </DataGridTemplateColumn>
                    <DataGridTextColumn Header="Tên"          Binding="{Binding Name}"         Width="*"/>
                    <DataGridTextColumn Header="Loại"         Binding="{Binding TemplateType}"  Width="100"/>
                    <DataGridTextColumn Header="ID"           Binding="{Binding Id}"            Width="200"/>
                </DataGrid.Columns>
            </DataGrid>
        </md:Card>

        <!-- Status -->
        <Border Grid.Row="3" Background="#E8F5E9" Padding="8,4" Margin="0,8,0,0" CornerRadius="4">
            <TextBlock Text="{Binding StatusMessage}" FontSize="12" Foreground="{StaticResource SuccessBrush}"/>
        </Border>
    </Grid>
</UserControl>
