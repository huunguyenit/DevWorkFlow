<UserControl x:Class="UI.Views.Pages.SqlStudioPage"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:md="http://materialdesigninxaml.net/winfx/xaml/themes"
             xmlns:ctrl="clr-namespace:UI.Views.Controls">
    <UserControl.InputBindings>
        <KeyBinding Key="F5" Command="{Binding ExecuteCommand}"/>
        <KeyBinding Key="S" Modifiers="Control" Command="{Binding SaveCommand}"/>
    </UserControl.InputBindings>

    <DockPanel>
        <!-- Toolbar -->
        <Border DockPanel.Dock="Top" Background="{StaticResource IdeRibbonBgBrush}"
                BorderBrush="{StaticResource IdeBorderBrush}" BorderThickness="0,0,0,1"
                Padding="8,4">
            <DockPanel>
                <StackPanel Orientation="Horizontal" DockPanel.Dock="Left">
                    <Button Style="{StaticResource IdeRibbonButtonStyle}"
                            Command="{Binding ExecuteCommand}"
                            ToolTip="Execute (F5) — nếu bôi đen thì chỉ chạy vùng chọn">
                        <StackPanel Orientation="Horizontal">
                            <md:PackIcon Kind="Play" Width="16" Height="16" VerticalAlignment="Center"/>
                            <TextBlock Text="{Binding ExecuteButtonLabel}" Margin="6,0,0,0" VerticalAlignment="Center"/>
                        </StackPanel>
                    </Button>
                    <Button Style="{StaticResource IdeRibbonButtonStyle}"
                            Command="{Binding CancelCommand}" ToolTip="Cancel" Margin="4,0,0,0">
                        <StackPanel Orientation="Horizontal">
                            <md:PackIcon Kind="Stop" Width="16" Height="16" VerticalAlignment="Center"/>
                            <TextBlock Text="Cancel" Margin="6,0,0,0" VerticalAlignment="Center"/>
                        </StackPanel>
                    </Button>
                    <Button Style="{StaticResource IdeRibbonButtonStyle}"
                            Command="{Binding SaveCommand}" ToolTip="Save (Ctrl+S)" Margin="4,0,0,0">
                        <StackPanel Orientation="Horizontal">
                            <md:PackIcon Kind="ContentSaveOutline" Width="16" Height="16" VerticalAlignment="Center"/>
                            <TextBlock Text="Save" Margin="6,0,0,0" VerticalAlignment="Center"/>
                        </StackPanel>
                    </Button>

                    <Rectangle Width="1" Fill="{StaticResource IdeBorderBrush}" Margin="10,2"/>

                    <TextBlock Text="Target:" VerticalAlignment="Center" Margin="0,0,6,0"
                               Foreground="{StaticResource FgMutedBrush}" FontSize="11"/>
                    <ComboBox Style="{StaticResource IdeComboBoxStyle}"
                              Margin="0"
                              MinWidth="280" MaxWidth="420"
                              ItemsSource="{Binding ConnectionTargets}"
                              SelectedItem="{Binding SelectedTarget, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                              VerticalAlignment="Center"
                              ToolTip="Sys hoặc App DB (1 sys có thể nhiều app)">
                        <ComboBox.ItemTemplate>
                            <DataTemplate>
                                <TextBlock Text="{Binding Display}" TextTrimming="CharacterEllipsis"/>
                            </DataTemplate>
                        </ComboBox.ItemTemplate>
                    </ComboBox>
                </StackPanel>

                <TextBlock Text="{Binding Status}" DockPanel.Dock="Right"
                           VerticalAlignment="Center" HorizontalAlignment="Right"
                           Foreground="{StaticResource FgMutedBrush}" FontSize="11"
                           TextTrimming="CharacterEllipsis" Margin="12,0,0,0"/>
            </DockPanel>
        </Border>

        <!--
            Không còn Results/Messages riêng ở đây: kết quả mọi lần chạy SQL (tab SQL lẫn F5 từ
            Form Source) đều ra panel Result/Message dùng chung ở dock dưới.
        -->
        <ctrl:MonacoEditorHost x:Name="SqlEditor" EditorLanguage="sql"
            BoundText="{Binding ScriptText, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
            SelectedScript="{Binding SelectedScript, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"/>
    </DockPanel>
</UserControl>
